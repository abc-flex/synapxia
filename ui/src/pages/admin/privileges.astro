---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getPrivileges } from "@/lib/privileges";

// Fetch privileges from API
let privileges: any[] = [];
let errorMessage: string | null = null;

try {
  const apiLists = await getPrivileges();
  privileges = apiLists;
} catch (error) {
  console.error('Failed to fetch privileges:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch privileges from API';
  // Fallback to empty array to still render the page
  privileges = [];
}

const columns = [
  { key: "role", label: "Role", visible: false},
  { key: "module", label: "Module", visible: true },
  { key: "option", label: "Option", visible: true },
  { key: "can_edit", label: "Can Edit", visible: true },
];
const data = privileges.map((item) => ({
  role: item.role,
  module: item.module,
  option: item.option,
  can_edit: item.can_edit,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));
const tableFields = [
  { key: "role", label: "Role", required: true },
  { key: "module", label: "Module", required: true },
  { key: "option", label: "Option", required: true },
  { key: "can_edit", label: "Can Edit", type: "checkbox" as const },
];
const fieldKeys = tableFields.map((f) => f.key);
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <Breadcrumb
      moduleName="Administration"
      pageName="Privileges"
      pageTitle="Privileges"
      homeLink="/"
      moduleNameKey="modules.ADMIN"
      pageNameKey="menu_options.privileges"
    />

    <CrudModal
      mode="create"
      modalId="privilege-create-modal"
      entityName="Privilege"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="privilege-edit-modal"
      entityName="Privilege"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="privilege-delete-modal"
      entityName="Privilege"
      fields={tableFields}
      showTrigger={false}
    />

    <div
      id="privileges-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage } from "/scripts/crudClient.js";

      initCrudPage({
        dataId: "privileges-data",
        editModalId: "privilege-edit-modal",
        deleteModalId: "privilege-delete-modal",
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="border-0 p-0">
        <DataTable
          columns={columns}
          data={data}
          tableId="privileges"
          i18Item="privilege"
          columnFilter="role"
          masterPage="/admin/roles"
          mdItem="role"
        />
      </div>
    </div>
  </div>
</BaseLayout>
