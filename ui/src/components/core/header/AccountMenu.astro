---
import { t } from "@/i18n";
import { getLocale } from "@/utils/getLocale";

const locale = getLocale(Astro);

interface MenuItem {
  label: string;
  href?: string;
  icon?: string;
}

interface Props {
  name?: string;
  email?: string;
  avatarUrl?: string;
  initials?: string;
  menuItems?: MenuItem[];
  signOutLabel?: string;
}

const {
  name = "Musharof Chowdhury",
  email = "randomuser@pimjo.com",
  avatarUrl,
  initials = "MC",
  menuItems = [
    { label: "account_menu.edit_profile" },
    { label: "account_menu.account_settings" },
    { label: "account_menu.support" },
  ],
  signOutLabel = "account_menu.sign_out",
} = Astro.props as Props;
---

<details class="account-menu relative" aria-label="Account menu">
  <summary class="account-trigger group" role="button">
    <span class="mr-3 h-11 w-11 overflow-hidden rounded-full bg-indigo-100 text-indigo-700 font-semibold flex items-center justify-center">
      {avatarUrl ? <img src={avatarUrl} alt={name} class="h-full w-full object-cover" /> : initials}
    </span>
    <span class="mr-1 block text-sm font-medium text-gray-700 dark:text-gray-400">{name.split(" ")[0]}</span>
    <img src="/src/components/icons/ChevronDown.svg" alt="" class="h-5 w-5 text-gray-500 dark:text-gray-400 transition duration-200 group-open:rotate-180" />
  </summary>

  <div class="account-dropdown">
    <div class="mb-4">
      <span class="block text-sm font-semibold text-gray-800 dark:text-white/90">{name}</span>
      <span class="mt-1 block text-xs text-gray-500 dark:text-gray-400">{email}</span>
    </div>

    <ul class="flex flex-col gap-1 border-b border-gray-200 pb-3 dark:border-gray-800">
      {menuItems.map((item) => (
        <li>
          <a href={item.href || "#"} class="account-link group">
            <span class="account-link-icon" aria-hidden="true">•</span>
            <span data-i18n={item.label}>{t(locale, item.label)}</span>
          </a>
        </li>
      ))}
    </ul>

    <button class="account-link mt-3 w-full text-left" type="button">
      <span class="account-link-icon" aria-hidden="true">↩</span>
      <span data-i18n={signOutLabel}>{t(locale, signOutLabel)}</span>
    </button>
  </div>
</details>
