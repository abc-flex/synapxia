---
import { t } from "@/i18n";
import { getLocale } from "@/utils/getLocale";
import BellIcon from "@/components/icons/bell.svg?raw";

const locale = getLocale(Astro);

interface NotificationItem {
  id: string | number;
  title: string;
  subtitle?: string;
  timeAgo?: string;
  avatarUrl?: string;
  status?: "active" | "inactive" | "away";
  statusColor?: string;
}

interface Props {
  items?: NotificationItem[];
  badge?: boolean;
  title?: string;
}

const {
  items = [
    {
      id: 1,
      title: "Terry Franci requests permission to change Project - Nganter App",
      subtitle: "Project",
      timeAgo: "5 min ago",
      avatarUrl: "https://i.pravatar.cc/64?img=12",
      status: "active",
    },
    {
      id: 2,
      title: "Alena Franci requests permission to change Project - Nganter App",
      subtitle: "Project",
      timeAgo: "8 min ago",
      avatarUrl: "https://i.pravatar.cc/64?img=32",
      status: "away",
    },
    {
      id: 3,
      title:
        "Jocelyn Kenter requests permission to change Project - Nganter App",
      subtitle: "Project",
      timeAgo: "15 min ago",
      avatarUrl: "https://i.pravatar.cc/64?img=47",
      status: "inactive",
    },
    {
      id: 4,
      title:
        "Brandon Philips requests permission to change Project - Nganter App",
      subtitle: "Project",
      timeAgo: "1 hr ago",
      avatarUrl: "https://i.pravatar.cc/64?img=18",
      status: "active",
    },
  ],
  badge = true,
  title = t(locale, "notification_menu.title"),
} = Astro.props as Props;

const statusColors: Record<string, string> = {
  active: "bg-emerald-500",
  away: "bg-amber-400",
  inactive: "bg-gray-400",
};
---

<details class="notification-menu relative" aria-label="Notifications">
  <summary class="notification-trigger group" role="button">
    {
      badge ? (
        <span class="notify-dot" aria-hidden="true">
          <span class="notify-ping" />
        </span>
      ) : null
    }
    <Fragment set:html={BellIcon} />
  </summary>

  <div class="notification-dropdown">
    <div class="flex items-center justify-between pb-3">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white/90">
        {title}
      </h3>
      <button
        class="text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300"
        type="button"
        onclick="this.closest('details').removeAttribute('open')"
      >
        ✕
      </button>
    </div>

    <div class="notification-list custom-scrollbar">
      {
        items.map((item) => (
          <article class="notification-item" key={item.id}>
            <div class="notification-avatar">
              {item.avatarUrl ? (
                <img src={item.avatarUrl} alt={item.title} />
              ) : (
                <div class="placeholder-avatar">•</div>
              )}
              <span
                class={`status-dot ${item.statusColor || statusColors[item.status || "inactive"]}`}
              />
            </div>
            <div class="notification-body">
              <p class="notification-title">{item.title}</p>
              <p class="notification-meta">
                {item.subtitle} · {item.timeAgo}
              </p>
            </div>
          </article>
        ))
      }
    </div>

    <a href="#" class="notification-footer">View All Notification</a>
  </div>
</details>
