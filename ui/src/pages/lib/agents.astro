---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import Toast from "../../components/Toast.astro";
import CardGallery from "../../components/lib/gallery/CardGallery.astro";
import AgentCard from "../../components/lib/AgentCard.astro";
import AgentDetailModal from "../../components/lib/AgentDetailModal.astro";
import { getAssetsbyCategory } from "@/lib/assets";
import { getCharacterizations } from "@/lib/characterizations";
import { getListItemsbyList } from "@/lib/list_items";
import { getCurrentUser } from "@/lib/auth";
import { getFavoritesByUser } from "@/lib/favorites";
import { getActions, summarizeVotes } from "@/lib/actions";
import { summarizeDiscussionCounts } from "@/lib/foro";
import { getLocale } from "@/utils/getLocale";
import { formatRelative } from "@/lib/datatable";

const CATEGORY = "AGENTS";
const locale = getLocale(Astro);

// Tolerant list parser for the TOOLS feature (array literal, comma- or
// newline-separated) → string[].
const parseList = (raw: unknown): string[] => {
  if (!raw) return [];
  let s = String(raw).trim();
  if (s.startsWith("[") && s.endsWith("]")) s = s.slice(1, -1);
  return s
    .split(/[,\n]/)
    .map((t) => t.trim().replace(/^['"]|['"]$/g, "").trim())
    .filter(Boolean);
};

const truncate = (raw: string, max = 140): string => {
  const s = (raw ?? "").trim().replace(/\s+/g, " ");
  return s.length > max ? `${s.slice(0, max)}…` : s;
};

// ── Agent assets (assets in the AGENTS category) ───────────────────────────
let agents: any[] = [];
let errorMessage: string | null = null;
try {
  agents = await getAssetsbyCategory(CATEGORY);
} catch (error) {
  console.error("Failed to fetch agents:", error);
  errorMessage = error instanceof Error ? error.message : "Failed to fetch agents from API";
  agents = [];
}

// ── Characterizations → map<assetId, {feature: {value, detail}}> ───────────
type CharCols = { value: string; detail: string };
let charsByAsset = new Map<number, Record<string, CharCols>>();
try {
  const chars = await getCharacterizations(0, 1000);
  for (const c of chars) {
    const aid = Number(c.asset);
    const bag = charsByAsset.get(aid) ?? {};
    bag[c.feature] = { value: c.value ?? "", detail: c.detail ?? "" };
    charsByAsset.set(aid, bag);
  }
} catch {
  charsByAsset = new Map();
}

// ── Current user's favorites (SSR) → pre-fill the card stars ───────────────
let favIds = new Set<number>();
let myUserId: number | null = null;
try {
  const me = await getCurrentUser();
  myUserId = Number(me.id);
  const favs = await getFavoritesByUser(myUserId);
  favIds = new Set(favs.map((f) => Number(f.asset)));
} catch {
  favIds = new Set();
}

// ── Vote tallies (SSR) → pre-fill each card's score + the user's own vote ──
let votesByAsset: Map<number, { score: number; positive: number; negative: number; myVote: string | null }> = new Map();
let discussByAsset = new Map<number, number>();
try {
  const allActions = await getActions(0, 1000);
  votesByAsset = summarizeVotes(allActions, myUserId ?? undefined);
  discussByAsset = summarizeDiscussionCounts(allActions);
} catch {
  votesByAsset = new Map();
  discussByAsset = new Map();
}

// ── Status list (ASSET_STATUS) for labels + the status filter ──────────────
let status: any[] = [];
try {
  status = await getListItemsbyList("ASSET_STATUS");
} catch {
  status = [];
}
const statuses = status.map((s) => ({ value: s.value, label: s.label }));

const resolveStatusLabel = (raw: string): string => {
  if (!raw) return "";
  const direct = status.find((s) => s.value === raw);
  if (direct) return direct.label;
  const stripped = status.find((s) => s.value.replace(/^\d+-/, "") === raw);
  return stripped?.label ?? raw;
};

// Galleries are published-only browse surfaces: hide anything not PUBLISHED
// (tolerant of the legacy `N-` ordinal prefix on the status code).
const isPublished = (raw: unknown): boolean =>
  String(raw ?? "").replace(/^\d+-/, "").toUpperCase() === "PUBLISHED";

// ── Flatten rows for the cards ─────────────────────────────────────────────
const rows = agents.filter((item) => isPublished(item.status)).map((item) => {
  const chars = charsByAsset.get(Number(item.id)) ?? {};
  const tags = Array.isArray(item.tags) ? item.tags : [];
  // Tools + instructions live in the `detail` column (the array / full text);
  // `value` is just a short summary.
  const tools = parseList(chars.TOOLS?.detail || chars.TOOLS?.value);
  const instructions = chars.INSTRUCTIONS?.detail || chars.INSTRUCTIONS?.value || "";
  return {
    id: item.id,
    name: item.name,
    description: item.description ?? "",
    subtitle: formatRelative(item.updated_at ?? item.created_at, locale),
    subtitleTs: item.updated_at ?? item.created_at,
    statusValue: item.status,
    statusLabel: resolveStatusLabel(item.status),
    favorite: favIds.has(item.id) ? "yes" : "no",
    votePositive: votesByAsset.get(Number(item.id))?.positive ?? 0,
    voteNegative: votesByAsset.get(Number(item.id))?.negative ?? 0,
    myVote: votesByAsset.get(Number(item.id))?.myVote ?? "",
    discussCount: discussByAsset.get(Number(item.id)) ?? 0,
    model: chars.SUGGESTED_MODEL?.value,
    tools,
    instructionsPreview: truncate(instructions),
    tags,
    searchText: [item.name, item.description, tools.join(" "), instructions, tags.join(" ")]
      .filter(Boolean)
      .join(" "),
  };
});
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto w-full max-w-full">
    <Breadcrumb
      moduleName="AI Library"
      pageName="Agent Index"
      pageTitle="Agent Index"
      homeLink="/"
      moduleNameKey="modules.LIB"
      pageNameKey="menu_options.agents"
      pageTitleKey="menu_options.agents"
    />

    {/* Read-only "big card" view (opened by a whole-card click) */}
    <AgentDetailModal modalId="agent-view-modal" statuses={statuses} />

    <CardGallery
      galleryId="agents-gallery"
      emptyKey="agent_modal.empty"
      statuses={[]}
      proposeHref={`/lib/propose?category=${CATEGORY}`}
    >
      {rows.map((r) => (
        <AgentCard
          id={r.id}
          name={r.name}
          subtitle={r.subtitle}
          subtitleTs={r.subtitleTs}
          description={r.description}
          statusLabel={r.statusLabel}
          statusValue={r.statusValue}
          favorite={r.favorite}
          searchText={r.searchText}
          editModalId="agent-detail-modal"
          detailModalId="agent-view-modal"
          model={r.model}
          tools={r.tools}
          instructionsPreview={r.instructionsPreview}
          tags={r.tags}
          votable={true}
          votePositive={r.votePositive}
          voteNegative={r.voteNegative}
          myVote={r.myVote}
          discussCount={r.discussCount}
        />
      ))}
    </CardGallery>
  </div>

  <script>
    // Bundled module (Astro resolves @/ + TS and dedupes it). We deliberately
    // avoid the inline `<script type="module">` + `/src/...` import pattern,
    // which 404s in the production build (see memory/CHANGELOG.md 2026-06-15).
    import { initCardGallery } from "@/lib/catalogGallery";
    import { loadClientTranslations } from "@/utils/i18nClient";
    import { installGlobalToast } from "@/lib/toast";

    initCardGallery({ galleryId: "agents-gallery", pageSize: 12 });
    loadClientTranslations();

    // Top-layer toast: renders above the native <dialog> detail modal (a plain
    // body-appended toast loses to the modal's browser top layer).
    installGlobalToast();
  </script>
</BaseLayout>
