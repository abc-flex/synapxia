---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getPrivileges } from "@/lib/privileges";
import { getRoles } from "@/lib/roles";
import { getModules } from "@/lib/modules";
import { getOptions } from "@/lib/options";


// Fetch privileges from API
let privileges: any[] = [];
let errorMessage: string | null = null;

try {
  const apiLists = await getPrivileges();
  privileges = apiLists;
} catch (error) {
  console.error('Failed to fetch privileges:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch privileges from API';
  // Fallback to empty array to still render the page
  privileges = [];
}

// Fetch roles from API for select field
let roles: any[] = [];
try {
  const apiRoles = await getRoles();
  roles = apiRoles;
} catch (error) {
  console.error('Failed to fetch roles:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch roles from API';
  // Fallback to empty array to still render the page
  roles = [];
}

// Fetch modules from API for select field
let modules: any[] = [];
try {
  const apiModules = await getModules();
  modules = apiModules;
} catch (error) {
  console.error('Failed to fetch modules:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch modules from API';
  // Fallback to empty array to still render the page
  modules = [];
}

// Fetch options from API for select field
let options: any[] = [];
try {
  const apiOptions = await getOptions();
  options = apiOptions;
} catch (error) {
  console.error('Failed to fetch options:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch options from API';
  // Fallback to empty array to still render the page
  options = [];
}

const columns = [
  { key: "role", label: "privilege_modal.role", visible: false},
  { key: "module", label: "privilege_modal.module", visible: true },
  { key: "option", label: "privilege_modal.option", visible: true },
  { key: "can_edit", label: "privilege_modal.can_edit", visible: true },
];
const data = privileges.map((item) => ({
  id: `${item.role}::${item.module}::${item.option}`,
  role: item.role,
  module: item.module,
  option: item.option,
  can_edit: item.can_edit,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));
const tableFields = [
  { key: "role", label: "privilege_modal.role", type: "select" as const, options: roles, pk: true, required: true },
  { key: "module", label: "privilege_modal.module", type: "select" as const, options: modules, pk: true, required: true },
  { key: "option", label: "privilege_modal.option", type: "select" as const, options: options, pk: true, required: true },
  { key: "can_edit", label: "privilege_modal.can_edit", type: "checkbox" as const },
];
const fieldKeys = ["id", ...tableFields.map((f) => f.key)];
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <!-- Breadcrumb Start -->
    <Breadcrumb
      moduleName="Administration"
      pageName="Privileges"
      pageTitle="Privileges"
      homeLink="/"
      moduleNameKey="modules.ADMIN"
      pageNameKey="menu_options.privileges"
      pageTitleKey="menu_options.privileges"
    />
    <!-- Breadcrumb End -->

    <CrudModal
      mode="create"
      modalId="privilege-create-modal"
      entityName="Privilege"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="privilege-edit-modal"
      entityName="Privilege"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="privilege-delete-modal"
      entityName="Privilege"
      fields={tableFields}
      showTrigger={false}
    />

    <div
      id="privileges-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage } from "/scripts/crudClient.js";
      import {
        createPrivilege,
        updatePrivilege,
        deletePrivilege,
      } from "/src/lib/privileges";

      initCrudPage({
        dataId: "privileges-data",
        editModalId: "privilege-edit-modal",
        deleteModalId: "privilege-delete-modal",
      });

      // Helper function to show toast notifications
      function showToast(message, variant = "info") {
        const toast = document.createElement("div");
        toast.className = `fixed top-4 right-4 z-50 max-w-md p-4 rounded-lg border shadow-lg transition-all duration-300 ${
          variant === "error"
            ? "bg-red-50 text-red-800 border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800"
            : "bg-green-50 text-green-800 border-green-200 dark:bg-green-900/20 dark:text-green-400 dark:border-green-800"
        }`;
        toast.innerHTML = `
          <div class="flex items-start gap-3">
            <div class="flex-1 text-sm font-medium">${message}</div>
            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="this.parentElement.parentElement.remove()">✕</button>
          </div>
        `;
        document.body.appendChild(toast);

        // Auto-remove after 5 seconds
        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateX(100%)";
          setTimeout(() => toast.remove(), 300);
        }, 5000);
      }

      // Handle CRUD form submissions
      document.addEventListener("crud-submit", async (e) => {
        const { modalId, mode, data } = e.detail;

        try {
          // Parse composite ID: "role::module::option"
          const [role, module, option] = data.id.split("::");
          if (mode === "create") {
            // Create new privilege
            await createPrivilege({
              role: data.role,
              module: data.module,
              option: data.option,
              can_edit: data.can_edit || false,
            });
            showToast("Privilege created successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "edit") {
            // Update existing privilege
            await updatePrivilege(role, module, option, {
              can_edit: data.can_edit || false,
              is_active: data.is_active !== false,
            });
            showToast("Privilege updated successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "delete") {
            await deletePrivilege(role, module, option);
            showToast("Privilege deleted successfully!");
            setTimeout(() => window.location.reload(), 1000);
          }
        } catch (error) {
          console.error("CRUD operation failed:", error);
          showToast(error instanceof Error ? error.message : "An error occurred", "error");
        }
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="border-0 p-0">
        <DataTable
          columns={columns}
          data={data}
          tableId="privileges"
          i18Item="privilege"
          columnFilter="role"
          filterOptions={roles}
          masterPage="/admin/roles"
          mdItem="role"
        />
      </div>
    </div>
  </div>
</BaseLayout>
