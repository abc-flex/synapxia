---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import TreeChart from "../../components/treeview/TreeChart.astro";
import shareSvg from "@/images/icons/share.svg?raw";
import { getBusinessUnits } from "@/lib/business_units";
import { getListItemsbyList } from "@/lib/list_items";

// Fetch business_units from API
let business_units: any[] = [];
let errorMessage: string | null = null;
try {
  const apiBusinessUnits = await getBusinessUnits();
  business_units = apiBusinessUnits;
} catch (error) {
  console.error('Failed to fetch business_units:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch business_units from API';
  // Fallback to empty array to still render the page
  business_units = [];
}

// Fetch items_list from API for select field
let types: any[] = [];
types = await getListItemsbyList('BIZ_UNIT_TYPE');

const columns = [
  { key: "code", label: "business_unit_modal.code", visible: false },
  { key: "name", label: "business_unit_modal.name", as: "title", subtitleKey: "code", subtitleFormat: "text" },
  { key: "type", label: "business_unit_modal.type", visible: false },
  { key: "type_name", label: "business_unit_modal.type" },
  { key: "parent", label: "business_unit_modal.parent", visible: false },
  { key: "parent_name", label: "business_unit_modal.parent" },
];

// Fetch business_units for select field
const units = business_units.map((item) => ({
  value: item.code,
  name: item.name,
}));

const data = business_units.map((item) => ({
  id: item.code,
  code: item.code,
  name: item.name,
  description: item.description,
  type: item.type,
  type_name: types.find((s) => String(s.value) === String(item.type))?.label || item.type,
  parent: item.parent,
  parent_name: units.find((u) => u.value === item.parent)?.name || item.parent,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));
const formFields = [
  { key: "code", label: "business_unit_modal.code", pk: true, required: true, placeholder: "e.g. ADMIN" },
  { key: "name", label: "business_unit_modal.name", required: true, placeholder: "e.g. Administration" },
  { key: "type", label: "business_unit_modal.type", type: "select" as const, options: types, required: false, filterLang: true },
  { key: "parent", label: "business_unit_modal.parent", type: "select" as const, options: units, required: false },
  {
    key: "description",
    label: "business_unit_modal.description",
    type: "textarea" as const,
    placeholder: "Optional details of business unit",
    required: false,
  },
];
const fieldKeys = formFields.map((f) => f.key);
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto w-full max-w-full md:p-0">
    <!-- Breadcrumb Start -->
    <Breadcrumb
      moduleName="Administration"
      pageName="BusinessUnits"
      pageTitle="Business Units"
      homeLink="/"
      moduleNameKey="modules.ADMIN"
      pageNameKey="menu_options.business_units"
      pageTitleKey="menu_options.business_units"
    />
    <!-- Breadcrumb End -->

    <CrudModal
      mode="create"
      modalId="business_unit-create-modal"
      entityName="BusinessUnit"
      fields={formFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="business_unit-edit-modal"
      entityName="BusinessUnit"
      fields={formFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="business_unit-delete-modal"
      entityName="BusinessUnit"
      fields={formFields}
      showTrigger={false}
    />

    <div
      id="business_units-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage } from "/scripts/crudClient.js";
      import {
        createBusinessUnit,
        updateBusinessUnit,
        deleteBusinessUnit,
      } from "/src/lib/business_units";

      initCrudPage({
        dataId: "business_units-data",
        editModalId: "business_unit-edit-modal",
        deleteModalId: "business_unit-delete-modal",
      });

      // Helper function to show toast notifications
      function showToast(message, variant = "info") {
        const toast = document.createElement("div");
        toast.className = `fixed top-4 right-4 z-50 max-w-md p-4 rounded-lg border shadow-lg transition-all duration-300 ${
          variant === "error"
            ? "bg-red-50 text-red-800 border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800"
            : "bg-green-50 text-green-800 border-green-200 dark:bg-green-900/20 dark:text-green-400 dark:border-green-800"
        }`;
        toast.innerHTML = `
          <div class="flex items-start gap-3">
            <div class="flex-1 text-sm font-medium">${message}</div>
            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="this.parentElement.parentElement.remove()">✕</button>
          </div>
        `;
        document.body.appendChild(toast);

        // Auto-remove after 5 seconds
        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateX(100%)";
          setTimeout(() => toast.remove(), 300);
        }, 5000);
      }

      // Handle CRUD form submissions
      document.addEventListener("crud-submit", async (e) => {
        const { modalId, mode, data } = e.detail;

        try {
          if (mode === "create") {
            // Create new business unit
            await createBusinessUnit({
              code: data.code,
              name: data.name,
              description: data.description,
              type: data.type,
              parent: data.parent,
              is_active: data.is_active !== false,
            });

            showToast("Business Unit created successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "edit") {
            // Update existing business unit
            await updateBusinessUnit(data.id, {
              name: data.name,
              description: data.description,
              type: data.type,
              parent: data.parent,
              is_active: data.is_active !== false,
            });

            showToast("Business Unit updated successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "delete") {
            // Delete business unit
            await deleteBusinessUnit(data.id);

            showToast("Business Unit deleted successfully!");
            setTimeout(() => window.location.reload(), 1000);
          }
        } catch (error) {
          console.error("CRUD operation failed:", error);
          showToast(error.message || "An error occurred", "error");
        }
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="space-y-5 sm:space-y-6">
        <!-- ====== Table Start -->
        <DataTable
          columns={columns}
          data={data}
          tableId="business_units"
          i18Item="business_unit"
        >
          <button
            slot="toolbar-actions"
            type="button"
            class="inline-flex items-center gap-2 rounded-lg border border-gray-300 px-3 py-2 sm:py-1.5 text-sm text-gray-700 hover:bg-gray-100 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-800"
            data-modal-open="hierarchy-modal"
            data-i18n-title="menu_options.hierarchy"
            title="View Hierarchy"
          >
            <span class="w-5 h-5 inline-block">
              <Fragment set:html={shareSvg} />
            </span>
          </button>
        </DataTable>
        <!-- ====== Table End -->
      </div>
    </div>

    <!-- ====== View Hierarchy Modal -->
    <dialog
      id="hierarchy-modal"
      class="modal h-[calc(100dvh-2rem)] max-h-[calc(100dvh-2rem)] w-[1100px] max-w-[calc(100vw-2rem)] rounded-2xl border border-gray-200 bg-white p-0 shadow-2xl backdrop:bg-black/40 dark:border-gray-800 dark:bg-gray-900"
    >
      <div class="flex h-full max-h-[calc(100dvh-2rem)] w-full flex-col">
        <div
          class="flex items-center justify-between border-b border-gray-100 px-5 py-4 dark:border-gray-800"
        >
          <h2
            class="text-lg font-semibold text-gray-900 dark:text-white"
            data-i18n="menu_options.hierarchy"
          >
            View Hierarchy
          </h2>
          <button
            type="button"
            class="p-1 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300"
            data-modal-close="hierarchy-modal"
            aria-label="crud_modal.close"
            data-i18n-aria-label="crud_modal.close"
          >
            ✕
          </button>
        </div>
        <div class="flex-1 overflow-auto p-4">
          {business_units.length > 0 ? (
            <TreeChart items={business_units} height="calc(100dvh - 11rem)" orient="TB" boxed />
          ) : (
            <p class="p-6 text-center text-sm text-gray-500 dark:text-gray-400">
              No hay datos para visualizar
            </p>
          )}
        </div>
      </div>
    </dialog>

    <script>
      (() => {
        const modal = document.getElementById("hierarchy-modal");
        if (!modal) return;

        const open = () => {
          if (!modal.open) {
            modal.showModal();
            // The tree chart is rendered inside a hidden dialog, so ECharts
            // initialized at 0×0. Force a resize once the modal is visible.
            requestAnimationFrame(() =>
              window.dispatchEvent(new Event("resize")),
            );
          }
        };
        const close = () => {
          if (modal.open) modal.close();
        };

        document.addEventListener("click", (event) => {
          if (event.target.closest('[data-modal-open="hierarchy-modal"]')) {
            event.preventDefault();
            open();
          }
          if (event.target.closest('[data-modal-close="hierarchy-modal"]')) {
            event.preventDefault();
            close();
          }
        });

        // Close on backdrop click
        modal.addEventListener("click", (event) => {
          const rect = modal.getBoundingClientRect();
          const inDialog =
            rect.top <= event.clientY &&
            event.clientY <= rect.top + rect.height &&
            rect.left <= event.clientX &&
            event.clientX <= rect.left + rect.width;
          if (!inDialog) close();
        });

        modal.addEventListener("cancel", (e) => {
          e.preventDefault();
          close();
        });
      })();
    </script>
  </div>
</BaseLayout>
