        <mxCell id="z0z0WhfIwxSmAdAU9hbX-6" parent="V_u68xMH0kcSv7V8Yznh-1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;size=0.18018018018018017;align=left;fontSize=11;" value="&lt;div&gt;&lt;span class=&quot;ͼt&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span class=&quot;ͼt&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&amp;nbsp;In&amp;nbsp;&lt;b&gt;Asset_Permissions&lt;/b&gt;&amp;nbsp;table:&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;span class=&quot;ͼt&quot;&gt;&amp;nbsp;- &lt;b&gt;target_type&lt;/b&gt;&amp;nbsp;defines who receives the permission: USER, ROLE, PROJECT, TEAM,&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;UNIT or PUBLIC&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&amp;nbsp;- &lt;b&gt;target_code&lt;/b&gt;&amp;nbsp;stores the recipient identifier:&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;span class=&quot;ͼt&quot;&gt;&amp;nbsp; &amp;nbsp; *&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;For PROJECT, TEAM, UNIT or ROLE, it stores&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;the code from the corresponding table.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&amp;nbsp; &amp;nbsp; * For USER, it stores TO_CHAR (users.id)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &amp;nbsp; * For PUBLIC, it stores&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&#39;ALL&#39;.&lt;/span&gt;&lt;/font&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
