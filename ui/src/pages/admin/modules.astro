---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getModules } from "@/lib/modules";

// Fetch modules from API
let modules: any[] = [];
let errorMessage: string | null = null;

try {
  const apiModules = await getModules();
  modules = apiModules;
} catch (error) {
  console.error('Failed to fetch modules:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch modules from API';
  // Fallback to empty array to still render the page
  modules = [];
}

const columns = [
  { key: "code", label: "Code", visible: true },
  { key: "name", label: "Name", visible: true },
  { key: "sort_order", label: "#", visible: true },
];
const data = modules.map((item) => ({
  id: item.code,
  code: item.code,
  name: item.name,
  description: item.description,
  sort_order: item.sort_order,
  icon: item.icon,
  is_active: item.is_active,
}));

const moduleFields = [
  { key: "code", label: "Code", required: true, placeholder: "e.g. ADMIN" },
  { key: "name", label: "Name", required: true, placeholder: "Administration" },
  {
    key: "sort_order",
    label: "Sort Order",
    type: "number" as const,
    placeholder: "10",
  },
  { key: "icon", label: "Icon Path", placeholder: "Heroicon path" },
  {
    key: "description",
    label: "Description",
    type: "textarea" as const,
    placeholder: "Optional details",
  },
];
const fieldKeys = moduleFields.map((f) => f.key);
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <Breadcrumb
      moduleName="Administration"
      pageName="Modules"
      pageTitle="Modules"
      homeLink="/"
      moduleNameKey="modules.ADMIN"
      pageNameKey="menu_options.modules"
    />

    <CrudModal
      mode="create"
      modalId="module-create-modal"
      entityName="Module"
      fields={moduleFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="module-edit-modal"
      entityName="Module"
      fields={moduleFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="module-delete-modal"
      entityName="Module"
      fields={moduleFields}
      showTrigger={false}
    />

    <div
      id="modules-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage } from "/scripts/crudClient.js";
      initCrudPage({
        dataId: "modules-data",
        editModalId: "module-edit-modal",
        deleteModalId: "module-delete-modal",
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="space-y-5 sm:space-y-6">
        <DataTable
          columns={columns}
          data={data}
          tableId="modules"
          i18Item="module"
        />
      </div>
    </div>
  </div>
</BaseLayout>
