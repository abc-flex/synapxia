---
/**
 * Reusable Toast notification component
 * Displays messages with optional dismiss functionality
 */

interface Props {
  message: string;
  variant?: 'error' | 'info';
  open?: boolean;
}

const { message, variant = 'error', open = true } = Astro.props;

const variantStyles = {
  error: 'bg-red-50 text-red-800 border-red-200 dark:bg-red-950 dark:text-red-200 dark:border-red-800',
  info: 'bg-blue-50 text-blue-800 border-blue-200 dark:bg-blue-950 dark:text-blue-200 dark:border-blue-800'
};

const iconStyles = {
  error: 'text-red-500 dark:text-red-400',
  info: 'text-blue-500 dark:text-blue-400'
};
---

<div
  id="toast-notification"
  class:list={[
    'fixed top-4 right-4 z-50 max-w-md p-4 rounded-lg border shadow-lg transition-all duration-300',
    variantStyles[variant],
    open ? 'opacity-100 translate-x-0' : 'opacity-0 translate-x-full pointer-events-none'
  ]}
  role="alert"
  aria-live="assertive"
  aria-atomic="true"
>
  <div class="flex items-start gap-3">
    <div class="flex-shrink-0">
      {variant === 'error' && (
        <svg class:list={['w-5 h-5', iconStyles[variant]]} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      )}
      {variant === 'info' && (
        <svg class:list={['w-5 h-5', iconStyles[variant]]} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      )}
    </div>
    <div class="flex-1 text-sm font-medium">
      {message}
    </div>
    <button
      type="button"
      class="flex-shrink-0 ml-2 -mr-1 -mt-1 inline-flex rounded-lg p-1.5 hover:bg-red-200 dark:hover:bg-red-800/30 focus:ring-2 focus:ring-red-300 transition-colors"
      aria-label="Close"
      data-i18n-aria-label="common.close"
      onclick="this.closest('#toast-notification').style.display = 'none'"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>
  </div>
</div>

<script>
  // Auto-dismiss after 10 seconds
  const toast = document.getElementById('toast-notification');
  if (toast) {
    setTimeout(() => {
      toast.style.display = 'none';
    }, 10000);
  }
</script>
