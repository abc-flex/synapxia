---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import lists from "../../data/items_list.json";
import modules from "../../data/modules.json";
import options from "../../data/options.json";

const title = "SynapxIA";
const primaryNav = modules.map((module) => ({
  code: module.code,
  name: module.name,
  icon: `${module.icon}`,
}));
const itemsNav = options.map((option) => ({
  module: option.module,
  name: option.name,
  path: option.path,
}));

const columns = [
  { key: "sort_order", label: "#", visible: true },
  { key: "list", label: "List", visible: false},
  { key: "value", label: "Value", visible: true },
  { key: "label", label: "Label", visible: true },
];
const data = lists.map((item) => ({
  id: item.value,
  list: item.list,
  value: item.value,
  label: item.label,
  sort_order: item.sort_order,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));
const tableFields = [
  { key: "list", label: "List", required: true },
  { key: "value", label: "Value", required: true },
  { key: "label", label: "Label", required: true },
  { key: "sort_order", label: "sort_order", required: true },
  { key: "is_active", label: "Active", type: "checkbox" as const },
];
const fieldKeys = tableFields.map((f) => f.key);
---

<BaseLayout title={title} navModules={primaryNav} navOptions={itemsNav}>
  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <Breadcrumb
      moduleName="Administration"
      pageName="ItemsList"
      pageTitle="Items Lists"
      homeLink="/"
      moduleNameKey="modules.ADMIN"
      pageNameKey="menu_options.items_list"
    />

    <CrudModal
      mode="create"
      modalId="itemlist-create-modal"
      entityName="ItemList"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="itemlist-edit-modal"
      entityName="ItemList"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="itemlist-delete-modal"
      entityName="ItemList"
      fields={tableFields}
      showTrigger={false}
    />

    <div
      id="itemslist-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage, openEditModal, openDeleteModal } from "/scripts/crudClient.js";

      initCrudPage({
        dataId: "itemslist-data",
        editModalId: "itemlist-edit-modal",
        deleteModalId: "itemlist-delete-modal",
      });
    </script>

    <div class="space-y-5 sm:space-y-6 bg-white dark:bg-gray-900 rounded-lg shadow-sm p-6">
      <div class="space-y-5 sm:space-y-6">
        <div class="border-0 p-0">
          <DataTable
            columns={columns}
            data={data}
            tableId="items_list"
            i18Item="itemlist"
            columnFilter="list"
            masterPage="/admin/lists"
            mdItem="list"
          />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
