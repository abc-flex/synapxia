---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getProfiles } from "@/lib/profiles";

// Fetch profiles from API
let profiles: any[] = [];
let errorMessage: string | null = null;

try {
  const apiProfiles = await getProfiles();
  profiles = apiProfiles;
} catch (error) {
  console.error('Failed to fetch profiles:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch profiles from API';
  // Fallback to empty array to still render the page
  profiles = [];
}

const columns = [
  { key: "code", label: "profile_modal.code", as: "title", subtitleKey: "name", subtitleFormat: "text" },
  { key: "name", label: "profile_modal.name", visible: false },
];
const data = profiles.map((item) => ({
  id: item.code,
  code: item.code,
  name: item.name,
  description: item.description,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));
const tableFields = [
  { key: "code", label: "profile_modal.code", pk: true, required: true, placeholder: "e.g. ADMIN" },
  { key: "name", label: "profile_modal.name", required: true, placeholder: "e.g. Administration" },
  {
    key: "description",
    label: "profile_modal.description",
    type: "textarea" as const,  
    placeholder: "Optional details of profile",
  },
];
const fieldKeys = tableFields.map((f) => f.key);
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto w-full max-w-full md:p-0">
    <!-- Breadcrumb Start -->
    <Breadcrumb
      moduleName="Administration"
      pageName="Profiles"
      pageTitle="Profiles"
      homeLink="/"
      moduleNameKey="modules.ADMIN"
      pageNameKey="menu_options.profiles"
      pageTitleKey="menu_options.profiles"
    />
    <!-- Breadcrumb End -->

    <CrudModal
      mode="create"
      modalId="profile-create-modal"
      entityName="Profile"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="profile-edit-modal"
      entityName="Profile"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="profile-delete-modal"
      entityName="Profile"
      fields={tableFields}
      showTrigger={false}
    />

    <div
      id="profiles-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage } from "/scripts/crudClient.js";
      import {
        createProfile,
        updateProfile,
        deleteProfile,
      } from "/src/lib/profiles";

      initCrudPage({
        dataId: "profiles-data",
        editModalId: "profile-edit-modal",
        deleteModalId: "profile-delete-modal",
      });

      // Helper function to show toast notifications
      function showToast(message, variant = "info") {
        const toast = document.createElement("div");
        toast.className = `fixed top-4 right-4 z-50 max-w-md p-4 rounded-lg border shadow-lg transition-all duration-300 ${
          variant === "error"
            ? "bg-red-50 text-red-800 border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800"
            : "bg-green-50 text-green-800 border-green-200 dark:bg-green-900/20 dark:text-green-400 dark:border-green-800"
        }`;
        toast.innerHTML = `
          <div class="flex items-start gap-3">
            <div class="flex-1 text-sm font-medium">${message}</div>
            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="this.parentElement.parentElement.remove()">✕</button>
          </div>
        `;
        document.body.appendChild(toast);

        // Auto-remove after 5 seconds
        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateX(100%)";
          setTimeout(() => toast.remove(), 300);
        }, 5000);
      }

      // Handle CRUD form submissions
      document.addEventListener("crud-submit", async (e) => {
        const { modalId, mode, data } = e.detail;

        try {
          if (mode === "create") {
            // Create new profile
            await createProfile({
              code: data.code,
              name: data.name,
              description: data.description,
              is_active: data.is_active !== false,
            });

            showToast("Profile created successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "edit") {
            // Update existing profile
            await updateProfile(data.id, {
              name: data.name,
              description: data.description,
              is_active: data.is_active !== false,
            });

            showToast("Profile updated successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "delete") {
            // Delete profile
            await deleteProfile(data.id);

            showToast("Profile deleted successfully!");
            setTimeout(() => window.location.reload(), 1000);
          }
        } catch (error) {
          console.error("CRUD operation failed:", error);
          showToast(error.message || "An error occurred", "error");
        }
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="space-y-5 sm:space-y-6">
        <!-- ====== Table Start -->
        <DataTable
          columns={columns}
          data={data}
          tableId="profiles"
          i18Item="profile"
          detailPage="/admin/privileges"
          mdItem="privilege"
        />
        <!-- ====== Table End -->
      </div>
    </div>
  </div>
</BaseLayout>
