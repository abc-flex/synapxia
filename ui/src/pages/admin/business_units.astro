---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getBusinessUnits } from "@/lib/business_units";
import { getListItemsbyList } from "@/lib/list_items";

// Fetch business_units from API
let business_units: any[] = [];
let errorMessage: string | null = null;
try {
  const apiBusinessUnits = await getBusinessUnits();
  business_units = apiBusinessUnits;
} catch (error) {
  console.error('Failed to fetch business_units:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch business_units from API';
  // Fallback to empty array to still render the page
  business_units = [];
}

// Fetch items_list from API for select field
let types: any[] = [];
types = await getListItemsbyList('BIZ_UNIT_TYPE');

const columns = [
  { key: "code", label: "businessunit_modal.code" },
  { key: "name", label: "businessunit_modal.name" },
  { key: "type", label: "businessunit_modal.type" },
  { key: "parent", label: "businessunit_modal.parent" },
];
const data = business_units.map((item) => ({
  id: item.code,
  code: item.code,
  name: item.name,
  description: item.description,
  type: item.type,
  parent: item.parent,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));
const tableFields = [
  { key: "code", label: "businessunit_modal.code", required: true, placeholder: "e.g. ADMIN" },
  { key: "name", label: "businessunit_modal.name", required: true, placeholder: "e.g. Administration" },
  { key: "type", label: "businessunit_modal.type", type: "select" as const, options: types, required: false },
  { key: "parent", label: "businessunit_modal.parent", required: false },
  {
    key: "description",
    label: "businessunit_modal.description",
    type: "textarea" as const,
    placeholder: "Optional details of business unit",
  },
];
const fieldKeys = tableFields.map((f) => f.key);
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <!-- Breadcrumb Start -->
    <Breadcrumb
      moduleName="Administration"
      pageName="BusinessUnits"
      pageTitle="Business Units"
      homeLink="/"
      moduleNameKey="modules.ADMIN"
      pageNameKey="menu_options.business_units"
      pageTitleKey="menu_options.business_units"
    />
    <!-- Breadcrumb End -->

    <CrudModal
      mode="create"
      modalId="businessunit-create-modal"
      entityName="BusinessUnit"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="businessunit-edit-modal"
      entityName="BusinessUnit"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="businessunit-delete-modal"
      entityName="BusinessUnit"
      fields={tableFields}
      showTrigger={false}
    />

    <div
      id="business_units-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage } from "/scripts/crudClient.js";
      import {
        createBusinessUnit,
        updateBusinessUnit,
        deleteBusinessUnit,
      } from "/src/lib/business_units";

      initCrudPage({
        dataId: "business_units-data",
        editModalId: "businessunit-edit-modal",
        deleteModalId: "businessunit-delete-modal",
      });

      // Helper function to show toast notifications
      function showToast(message, variant = "info") {
        const toast = document.createElement("div");
        toast.className = `fixed top-4 right-4 z-50 max-w-md p-4 rounded-lg border shadow-lg transition-all duration-300 ${
          variant === "error"
            ? "bg-red-50 text-red-800 border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800"
            : "bg-green-50 text-green-800 border-green-200 dark:bg-green-900/20 dark:text-green-400 dark:border-green-800"
        }`;
        toast.innerHTML = `
          <div class="flex items-start gap-3">
            <div class="flex-1 text-sm font-medium">${message}</div>
            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="this.parentElement.parentElement.remove()">✕</button>
          </div>
        `;
        document.body.appendChild(toast);

        // Auto-remove after 5 seconds
        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateX(100%)";
          setTimeout(() => toast.remove(), 300);
        }, 5000);
      }

      // Handle CRUD form submissions
      document.addEventListener("crud-submit", async (e) => {
        const { modalId, mode, data } = e.detail;

        try {
          if (mode === "create") {
            // Create new business unit
            await createBusinessUnit({
              code: data.code,
              name: data.name,
              description: data.description,
              type: data.type,
              parent: data.parent,
              is_active: data.is_active !== false,
            });

            showToast("Business Unit created successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "edit") {
            // Update existing business unit
            await updateBusinessUnit(data.id, {
              name: data.name,
              description: data.description,
              type: data.type,
              parent: data.parent,
              is_active: data.is_active !== false,
            });

            showToast("Business Unit updated successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "delete") {
            // Delete business unit
            await deleteBusinessUnit(data.id);

            showToast("Business Unit deleted successfully!");
            setTimeout(() => window.location.reload(), 1000);
          }
        } catch (error) {
          console.error("CRUD operation failed:", error);
          showToast(error.message || "An error occurred", "error");
        }
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="space-y-5 sm:space-y-6">
        <!-- ====== Table Start -->
        <DataTable
          columns={columns}
          data={data}
          tableId="business_units"
          i18Item="businessunit"
        />
        <!-- ====== Table End -->
      </div>
    </div>
  </div>
</BaseLayout>
