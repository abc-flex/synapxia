# SynapxIA API — environment variables.
#
# This file is the single source of truth for what the API needs at runtime,
# in BOTH local dev (Docker Compose) and Vercel. Copy values into:
#   - Local dev:  the repo-root `.env` (auto-loaded by docker-compose.yml).
#                 Only the DB_* decomposed vars + PGADMIN_* / API_PATH apply.
#   - Vercel:     Project Settings → Environment Variables, scoped per
#                 environment (Production / Preview / Development).
#
# Every variable read by the API is listed below; nothing else is needed.

# =============================================================================
# Database connection — pick ONE of the three input shapes.
# Resolution lives in `app/core/config.py:Settings.database_url`.
# Precedence: DATABASE_URL → POSTGRES_URL → composed from DB_* decomposed vars.
# =============================================================================

# Option A (canonical, recommended for prod/Vercel): a full Postgres URL.
# Neon hands out `postgres://…` — the resolver normalizes the scheme to
# `postgresql://` automatically, so paste it verbatim.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Option B (Neon's default name when its integration has no prefix). Accepted
# as a transparent alias for DATABASE_URL — set ONE of A or B, not both.
# POSTGRES_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Option C (used by local Docker Compose dev). The five pieces below compose
# into a URL when neither DATABASE_URL nor POSTGRES_URL is set.
DB_HOST=db
DB_PORT=5432
DB_SCHEMA=synapxia          # the Postgres DATABASE name (legacy naming)
DB_USER=synapxia
DB_PASSWORD=synapxia

# =============================================================================
# Auth — required in prod, dev-default fallback in development
# =============================================================================
# Generate: `openssl rand -hex 32`
SECRET_KEY=change-me-in-production

# Access-token cookie / Bearer lifetime in seconds (default 3600 = 60 min)
JWT_LIFETIME_SECONDS=3600

# Refresh-token lifetime in seconds (default 1209600 = 14 days)
JWT_REFRESH_LIFETIME_SECONDS=1209600

# Set ONLY when the UI lives on a different subdomain than the API and you
# want the auth_token cookie to be visible to both. Example: ".synapxia.app".
# Leave unset for same-origin (Vite proxy in dev, Vercel rewrite in prod).
# COOKIE_DOMAIN=

# =============================================================================
# CORS — comma-separated origins allowed to call the API directly.
# Browser-side calls go same-origin via the UI's vercel.json rewrite, so this
# matters mostly for direct API calls (devtools, curl, scripts). Must be the
# explicit UI URL when allow_credentials=True (don't use "*").
# =============================================================================
CORS_ORIGINS=http://localhost:4321,https://dev-synapxia.vercel.app,https://synapxia.vercel.app

# =============================================================================
# Application
# =============================================================================
APP_ENV=development         # "production" disables SQL echo + enables Secure cookie
LOG_LEVEL=INFO

# =============================================================================
# SMTP (all optional — leave SMTP_HOSTNAME blank to disable email entirely;
# send operations will log instead of throw)
# =============================================================================
SMTP_HOSTNAME=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=noreply@synapxia.local
SMTP_FROM_NAME=SynapxIA
OPS_EMAIL=ops@synapxia.local
OPS_EMAIL_NAME=SynapxIA Operations
BOOKINGS_EMAIL=bookings@synapxia.local
BOOKINGS_EMAIL_NAME=SynapxIA Bookings
