---
import { t } from "@/i18n";
import { getLocale } from "@/utils/getLocale";
import ChevronDown from "@/images/icons/chevron-down.svg?raw";
import EditIcon from "@/images/icons/edit.svg?raw";
import SupportIcon from "@/images/icons/information-circle.svg?raw";
import SignOutIcon from "@/images/icons/arrow-left-sign-out.svg?raw";
import SunIcon from "@/images/icons/sun.svg?raw";
import MoonIcon from "@/images/icons/moon.svg?raw";
import ReviewRequestsIcon from "@/images/icons/clipboard-document-check.svg?raw";
import languagesData from "@/data/languages.json";

const locale = getLocale(Astro);

interface MenuItem {
  label: string;
  href?: string;
  icon?: string;
  /** Allow-list of profile codes (e.g. "REVIEWER") that may see this item.
   * Omitted/empty means visible to everyone. Superusers always see it.
   * Filtered client-side (see the mount script) — there's no SSR user fetch
   * in this component, unlike the DB/privilege-driven sidebar. */
  profiles?: string[];
}

interface Props {
  name?: string;
  email?: string;
  avatarUrl?: string;
  menuItems?: MenuItem[];
  /** Personal "my work" links (e.g. Review Requests) shown in their own
   * section above menuItems, each optionally profile-gated. */
  workItems?: MenuItem[];
  signOutLabel?: string;
}

// Pre-bundled SVG strings for the default menu items. Keyed by the
// account_menu.* i18n string so a custom `menuItems` prop can opt in by
// using the same labels (or pass its own glyphs).
const ICONS: Record<string, string> = {
  "account_menu.edit_profile": EditIcon,
  "account_menu.support": SupportIcon,
  "account_menu.review_requests": ReviewRequestsIcon,
};

const {
  name = "—",
  email = "—",
  avatarUrl,
  menuItems = [
    { label: "account_menu.edit_profile", href: "/profile" },
    { label: "account_menu.support", href: "/support" },
  ],
  workItems = [],
  signOutLabel = "account_menu.sign_out",
} = Astro.props as Props;

// Generate initials from name
const initials = name
  .split(" ")
  .map(word => word.charAt(0).toUpperCase())
  .join("")
  .slice(0, 2); // Limit to 2 characters
---

<details class="account-menu relative" aria-label="Account menu">
  <summary class="account-trigger group" role="button">
    <span class="h-11 w-11 shrink-0 aspect-square overflow-hidden rounded-full bg-indigo-100 text-indigo-700 font-semibold flex items-center justify-center text-sm sm:mr-3">
      {avatarUrl ? (
        <img src={avatarUrl} alt={name} class="h-full w-full object-cover rounded-full" />
      ) : (
        <span id="account-initials">{initials}</span>
      )}
    </span>
    <span id="account-firstname" class="mr-1 hidden max-w-[8rem] truncate text-sm font-medium text-gray-700 sm:block dark:text-gray-400">{name.split(" ")[0]}</span>
    <span class="h-5 w-5 text-gray-500 dark:text-gray-400 transition duration-200 group-open:rotate-180">
      <Fragment set:html={ChevronDown} />
    </span>
  </summary>

  <div class="account-dropdown">
    <div class="mb-4">
      <span id="account-fullname" class="block text-sm font-semibold text-gray-800 dark:text-white/90">{name}</span>
      <span id="account-email" class="mt-1 block text-xs text-gray-500 dark:text-gray-400">{email}</span>
    </div>

    {/* Mobile-only preferences — on desktop these live in the header. */}
    <div class="sm:hidden mb-2 space-y-1 border-b border-gray-200 pb-3 dark:border-gray-800">
      {/* Theme */}
      <div class="flex items-center justify-between gap-3 px-3 py-1.5">
        <span class="text-sm font-medium text-gray-700 dark:text-gray-300" data-i18n="account_menu.theme">
          {t(locale, "account_menu.theme")}
        </span>
        <div role="group" aria-label="Theme" data-i18n-aria-label="account_menu.theme"
          class="inline-flex items-center gap-1.5 rounded-full border border-gray-200 bg-gray-100 p-1.5 dark:border-gray-700 dark:bg-gray-800">
          <button type="button" data-theme-set="light" aria-label="Light"
            class="theme-seg flex h-7 w-7 items-center justify-center rounded-full text-gray-500 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400 dark:text-gray-400">
            <span class="h-4 w-4 inline-block"><Fragment set:html={SunIcon} /></span>
          </button>
          <button type="button" data-theme-set="dark" aria-label="Dark"
            class="theme-seg flex h-7 w-7 items-center justify-center rounded-full text-gray-500 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400 dark:text-gray-400">
            <span class="h-4 w-4 inline-block"><Fragment set:html={MoonIcon} /></span>
          </button>
        </div>
      </div>

      {/* Language */}
      <div class="flex items-center justify-between gap-3 px-3 py-1.5">
        <span class="text-sm font-medium text-gray-700 dark:text-gray-300" data-i18n="account_menu.language">
          {t(locale, "account_menu.language")}
        </span>
        <div role="radiogroup" aria-label="Language" data-i18n-aria-label="account_menu.language"
          class="inline-flex items-center gap-1.5 rounded-full border border-gray-200 bg-gray-100 p-1.5 dark:border-gray-700 dark:bg-gray-800">
          {languagesData.map((lang) => (
            <button
              type="button"
              role="radio"
              aria-checked="false"
              data-acct-lang={lang.code}
              title={lang.label}
              class="acct-lang-pill inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-semibold text-gray-500 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400 dark:text-gray-400"
            >
              <span aria-hidden="true" class="text-sm leading-none">{lang.flag}</span>
              <span>{lang.code.toUpperCase()}</span>
            </button>
          ))}
        </div>
      </div>
    </div>

    {workItems.length > 0 && (
      <div class="mb-2 border-b border-gray-200 pb-3 dark:border-gray-800" data-work-section>
        <span
          class="mb-1 block px-1 text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500"
          data-i18n="account_menu.my_work"
        >
          {t(locale, "account_menu.my_work")}
        </span>
        <ul class="flex flex-col gap-1">
          {workItems.map((item) => (
            <li data-profiles={item.profiles?.length ? item.profiles.join(",") : undefined}>
              <a href={item.href || "#"} class="account-link group">
                <span class="account-link-icon w-4 h-4 inline-block text-current shrink-0" aria-hidden="true">
                  <Fragment set:html={ICONS[item.label] ?? ""} />
                </span>
                <span data-i18n={item.label}>{t(locale, item.label)}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <ul class="flex flex-col gap-1 border-b border-gray-200 pb-3 dark:border-gray-800">
      {menuItems.map((item) => (
        <li>
          <a href={item.href || "#"} class="account-link group">
            <span class="account-link-icon w-4 h-4 inline-block text-current shrink-0" aria-hidden="true">
              <Fragment set:html={ICONS[item.label] ?? ""} />
            </span>
            <span data-i18n={item.label}>{t(locale, item.label)}</span>
          </a>
        </li>
      ))}
    </ul>

    <button id="account-signout-btn" class="account-link mt-3 w-full text-left" type="button">
      <span class="account-link-icon w-4 h-4 inline-block text-current shrink-0" aria-hidden="true">
        <Fragment set:html={SignOutIcon} />
      </span>
      <span data-i18n={signOutLabel}>{t(locale, signOutLabel)}</span>
    </button>
  </div>
</details>

<script>
  import { getUser, logout } from "@/lib/auth";
  import { getClientLocale, setClientLocale } from "@/utils/clientLocale";
  import { loadClientTranslations } from "@/utils/i18nClient";

  // Mobile-only language pills inside the account dropdown. The theme button
  // (data-theme-toggle) is wired globally by BaseLayout's theme script.
  const ACTIVE_CLASSES = ["bg-white", "text-gray-900", "shadow-sm", "dark:bg-gray-900", "dark:text-white"];
  const INACTIVE_CLASSES = ["text-gray-500", "dark:text-gray-400"];

  const paintAcctLang = (code: string) => {
    document.querySelectorAll<HTMLButtonElement>(".acct-lang-pill").forEach((pill) => {
      const active = pill.getAttribute("data-acct-lang") === code;
      pill.setAttribute("aria-checked", String(active));
      if (active) {
        pill.classList.add(...ACTIVE_CLASSES);
        pill.classList.remove(...INACTIVE_CLASSES);
      } else {
        pill.classList.remove(...ACTIVE_CLASSES);
        pill.classList.add(...INACTIVE_CLASSES);
      }
    });
  };

  paintAcctLang(getClientLocale());

  document.querySelectorAll<HTMLButtonElement>(".acct-lang-pill").forEach((pill) => {
    pill.addEventListener("click", () => {
      const lang = pill.getAttribute("data-acct-lang");
      if (!lang || lang === getClientLocale()) return;
      setClientLocale(lang);
      loadClientTranslations();
      paintAcctLang(lang);
      document.dispatchEvent(new CustomEvent("synapxia:locale-changed", { detail: lang }));
    });
  });

  // Stay in sync if the language is changed elsewhere (e.g. the header switcher).
  document.addEventListener("synapxia:locale-changed", (e) => {
    paintAcctLang((e as CustomEvent<string>).detail);
  });

  // Patch placeholder name/email/initials with real cached user on mount.
  const user = getUser();
  if (user) {
    const fullName =
      `${(user as any).first_name ?? ""} ${(user as any).last_name ?? ""}`.trim() ||
      (user as any).username ||
      "—";
    const firstName = (user as any).first_name || (user as any).username || "—";
    const email = (user as any).email ?? "—";
    const initials =
      (((user as any).first_name?.[0] ?? "") +
        ((user as any).last_name?.[0] ?? "")).toUpperCase() ||
      ((user as any).username?.[0]?.toUpperCase() ?? "?");

    const setText = (id: string, value: string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    };
    setText("account-firstname", firstName);
    setText("account-fullname", fullName);
    setText("account-email", email);
    setText("account-initials", initials);
  }

  // Hide "My Work" items that don't apply to the current user's profile (no
  // allow-list = visible to everyone; superusers always see everything).
  // Client-side only — this component has no SSR user fetch, unlike the
  // DB/privilege-driven sidebar. The dropdown starts closed, so this runs
  // before the user could ever see a gated item flash.
  const profile = (user as any)?.profile;
  const isSuperuser = Boolean((user as any)?.is_superuser);
  document.querySelectorAll<HTMLLIElement>("[data-profiles]").forEach((li) => {
    const allowed = (li.dataset.profiles || "").split(",").filter(Boolean);
    if (allowed.length > 0 && !isSuperuser && (!profile || !allowed.includes(profile))) {
      li.style.display = "none";
    }
  });
  document.querySelectorAll<HTMLElement>("[data-work-section]").forEach((section) => {
    const anyVisible = Array.from(section.querySelectorAll("li")).some(
      (li) => (li as HTMLElement).style.display !== "none"
    );
    if (!anyVisible) section.style.display = "none";
  });

  // Sign-out button — async so the refresh-token revocation completes
  // before we navigate away.
  document
    .getElementById("account-signout-btn")
    ?.addEventListener("click", async () => {
      await logout();
      window.location.href = "/login";
    });
</script>
