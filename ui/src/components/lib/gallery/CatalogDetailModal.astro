---
/**
 * CatalogDetailModal — reusable, read-only "big card" view for a LIB curated
 * catalog. Opened by a whole-card click (the card carries `data-detail-modal`),
 * it shows the asset's full description + its rich characterization content
 * (prompt template, MCP tools/config, agent instructions, …) at full size —
 * the parts that are clamped to one or two lines on the card.
 *
 * The shell here is presentational only: it exposes a header (icon slot + name +
 * status pill + favorite), a scrollable body (description block + a `-sections`
 * container the controller fills) and a footer (Close / Edit / Delete). The
 * per-catalog wrapper (e.g. PromptDetailModal) supplies the icon + accent and
 * calls `mountCatalogDetail` to hydrate it and wire Edit/Delete/Copy/favorite.
 */
export interface Props {
  /** Dialog id, e.g. "prompt-view-modal". */
  modalId: string;
  /** Tailwind text-color class for the favorite star + section accents. */
  accentClass?: string;
  /** Status options (value→label) so the controller can resolve the header pill. */
  statuses?: { value: string; label: string }[];
}

const {
  modalId,
  accentClass = "text-indigo-600 dark:text-indigo-300",
  statuses = [],
} = Astro.props as Props;
---

<dialog
  id={modalId}
  class="w-[min(920px,95vw)] max-w-none rounded-2xl bg-white p-0 text-gray-900 backdrop:bg-black/60 backdrop:backdrop-blur-sm dark:bg-gray-900 dark:text-gray-100"
>
  <div class="flex max-h-[90vh] flex-col">
    {/* Header */}
    <div class="flex items-start justify-between gap-4 border-b border-gray-200 px-6 py-4 dark:border-gray-800">
      <div class="flex min-w-0 items-center gap-3">
        <slot name="icon" />
        <div class="min-w-0">
          <h3 id={`${modalId}-name`} class="truncate text-lg font-bold text-gray-900 dark:text-white">—</h3>
          <span id={`${modalId}-status-pill`} class="mt-1 hidden w-fit items-center rounded-full px-2.5 py-0.5 text-xs font-medium"></span>
        </div>
      </div>
      <div class="flex shrink-0 items-center gap-1">
        <button
          type="button"
          id={`${modalId}-fav`}
          aria-pressed="false"
          title="Add to favorites"
          data-i18n-title="gallery.favorite_add"
          class={`rounded-md p-1.5 text-gray-400 transition-colors hover:bg-gray-100 dark:hover:bg-gray-800 ${accentClass}`}
        >
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.3 4.02a1 1 0 00.95.69h4.22c.97 0 1.37 1.24.59 1.81l-3.42 2.48a1 1 0 00-.36 1.12l1.3 4.02c.3.92-.75 1.69-1.54 1.12l-3.41-2.48a1 1 0 00-1.18 0l-3.41 2.48c-.78.57-1.84-.2-1.54-1.12l1.3-4.02a1 1 0 00-.36-1.12L2 9.45c-.78-.57-.38-1.81.6-1.81h4.21a1 1 0 00.95-.69l1.3-4.02z" />
          </svg>
        </button>
        <button
          type="button"
          data-modal-close={modalId}
          class="rounded-md p-1 text-gray-400 hover:bg-gray-100 hover:text-gray-600 dark:hover:bg-gray-800"
          aria-label="Close"
          data-i18n-aria-label="common.close"
        >
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>
    </div>

    {/* Body */}
    <div class="flex-1 space-y-6 overflow-y-auto px-6 py-5">
      {/* Vote bar (HU-LI05) — hydrated + unhidden by mountCatalogDetail. */}
      <div id={`${modalId}-vote`} class="hidden items-center gap-1">
        <button
          type="button"
          id={`${modalId}-vote-up`}
          aria-pressed="false"
          title="Helpful"
          data-i18n-title="gallery.vote_up"
          class="rounded-md p-1.5 text-gray-400 transition-colors hover:bg-gray-100 dark:hover:bg-gray-800"
        >
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M5 12l5-5 5 5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <span id={`${modalId}-vote-score`} class="min-w-[1.75rem] text-center text-sm font-semibold text-gray-700 dark:text-gray-200">0</span>
        <button
          type="button"
          id={`${modalId}-vote-down`}
          aria-pressed="false"
          title="Not helpful"
          data-i18n-title="gallery.vote_down"
          class="rounded-md p-1.5 text-gray-400 transition-colors hover:bg-gray-100 dark:hover:bg-gray-800"
        >
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M5 8l5 5 5-5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>
      <p id={`${modalId}-desc`} class="hidden whitespace-pre-wrap text-sm text-gray-600 dark:text-gray-300"></p>
      <div id={`${modalId}-sections`} class="space-y-6"></div>
    </div>

    {/* Footer */}
    <div class="flex items-center justify-end gap-3 border-t border-gray-200 px-6 py-4 dark:border-gray-800">
      <button type="button" data-modal-close={modalId} class="rounded-lg px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800" data-i18n="common.close">Close</button>
      <button
        type="button"
        id={`${modalId}-delete`}
        class="rounded-lg px-4 py-2 text-sm font-semibold text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-900/20"
        data-i18n="common.delete"
      >
        Delete
      </button>
      <button
        type="button"
        id={`${modalId}-edit`}
        class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700"
        data-i18n="common.edit"
      >
        Edit
      </button>
    </div>
  </div>
  {/* Status options consumed by the controller (mountCatalogDetail) to resolve
      the header pill label without a second round-trip. */}
  <script type="application/json" id={`${modalId}-statuses`} set:html={JSON.stringify(statuses)}></script>
</dialog>
