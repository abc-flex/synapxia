---
export interface NavModule {
  code: string;
  name: string;
  icon: string;
}
export interface NavOption {
  module: string;
  name: string;
  path: string;
}

interface Props {
  modules?: NavModule[];
  options?: NavOption[];
  brandTitle?: string;
}

const {
  modules = [],
  options = [],
  brandTitle = "SynapxIA",
} = Astro.props as Props;
---

<aside
  class="sidebar hidden lg:flex h-screen w-[290px] flex-col overflow-y-hidden border-r border-gray-200 bg-white px-5 py-8 shadow-sm duration-300 ease-linear dark:border-gray-800 dark:bg-black"
>

  <!-- SIDEBAR HEADER -->
  <div class="sidebar-header flex items-center justify-between gap-2 pb-7">
    <div class="flex items-center gap-3">
      <div
        class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-600 text-white font-semibold"
      >
        IA
      </div>
      <div class="leading-tight">
        <p class="text-2xl font-semibold text-gray-900 dark:text-white">
          {brandTitle}
        </p>
      </div>
    </div>
  </div>
  <!-- SIDEBAR HEADER -->

  <div class="flex flex-col overflow-y-auto no-scrollbar">
    <!-- SIDEBAR MENU -->
    <nav x-data="{selected: $persist('Dashboard')}">
      <!-- Menu Group -->
      <div>
        <h3 class="mb-1 text-xs uppercase leading-[30px] text-gray-400">
          <span
            class="menu-group-title"
            :class="sidebarToggle ? 'lg:hidden' : ''"
          >
            MENU
          </span>
        </h3>

        <ul class="flex flex-col gap-2 mb-3">
          <!-- Menu Item Module -->
          {
            modules.map((module) => (
            <li>
              <a
                href="#"
                class="menu-item group"
              >
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    fill-rule="evenodd"
                    clip-rule="evenodd"
                    d={module.icon}
                    fill=""
                  />
                </svg>

                <span
                  class="menu-item-text"
                >
                  {module.name}
                </span>
              </a>

              {/* Dropdown Options Start */}
              {
                options
                  .filter((option) => option.module === module.code)
                  .map((option) => (
                    <div class="overflow-hidden transform translate">
                      <ul class="flex flex-col gap-1 mt-2 menu-dropdown pl-9">
                        <li>
                          <a href={option.path} class="menu-dropdown-item group">
                            {option.name}
                          </a>
                        </li>
                      </ul>
                    </div>
                  ))
              }
              {/* Dropdown Options End */}
            </li>
            ))
            }

        </ul>
      </div>
      <!-- Menu Group -->
    </nav>
    <!-- SIDEBAR MENU -->
  </div>
</aside>
