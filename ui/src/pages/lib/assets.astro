---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getAssets } from "@/lib/assets";
import { getCategoriesSelect } from "@/lib/categories";
import { getListItemsbyList } from "@/lib/list_items";

// Fetch assets from API
let assets: any[] = [];
let errorMessage: string | null = null;

try {
  const apiLists = await getAssets();
  assets = apiLists;
} catch (error) {
  console.error('Failed to fetch assets:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch assets from API';
  // Fallback to empty array to still render the page
  assets = [];
}

// Fetch items_list from API for select field (list IN['ASSET_STATUS')
let status: any[] = [];
status = await getListItemsbyList('ASSET_STATUS');

// Fetch categories from API for select field
let categories: any[] = [];
try {
  const apiCategories = await getCategoriesSelect();
  categories = apiCategories;
} catch (error) {
  console.error('Failed to fetch categories:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch categories from API';
  // Fallback to empty array to still render the page
  categories = [];
}

const columns = [
  { key: "name", label: "asset_modal.name"},
  { key: "category", label: "asset_modal.category", visible: false },
  { key: "category_name", label: "asset_modal.category" },
  { key: "status", label: "asset_modal.status", visible: false },
  { key: "status_name", label: "asset_modal.status" },
];


const data = assets.map((item) => ({
  id: item.id,
  name: item.name,
  description: item.description,
  category: item.category,
  category_name: categories.find((c) => String(c.value) === String(item.category))?.label || item.category_name,
  reference: item.reference,
  status: item.status,
  status_name: status.find((s) => s.value === item.status)?.label || item.status,
  tags: item.tags,
  detail: item.detail,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));

const formFields = [
  { key: "name", label: "asset_modal.name", required: true },
  { key: "category", label: "asset_modal.category", type: "select" as const, options: categories, required: true },
  { key: "status", label: "asset_modal.status", type: "select" as const, options: status, required: true },
  {
    key: "description",
    label: "asset_modal.description",
    type: "textarea" as const,
    required: false,
  },
  { key: "reference", label: "asset_modal.reference", required: false },
  { key: "tags", label: "asset_modal.tags", required: false },
];
const fieldKeys = formFields.map((f) => f.key);
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <!-- Breadcrumb Start -->
    <Breadcrumb
      moduleName="AI Library"
      pageName="Assets"
      pageTitle="Assets"
      homeLink="/"
      moduleNameKey="modules.LIB"
      pageNameKey="menu_options.assets"
      pageTitleKey="menu_options.assets"
    />
    <!-- Breadcrumb End -->

    <CrudModal
      mode="create"
      modalId="asset-create-modal"
      entityName="Asset"
      fields={formFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="asset-edit-modal"
      entityName="Asset"
      fields={formFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="asset-delete-modal"
      entityName="Asset"
      fields={formFields}
      showTrigger={false}
    />

    <div
      id="assets-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage } from "/scripts/crudClient.js";
      import {
        createAsset,
        updateAsset,
        deleteAsset,
      } from "/src/lib/assets";

      initCrudPage({
        dataId: "assets-data",
        editModalId: "asset-edit-modal",
        deleteModalId: "asset-delete-modal",
      });

      // Helper function to show toast notifications
      function showToast(message, variant = "info") {
        const toast = document.createElement("div");
        toast.className = `fixed top-4 right-4 z-50 max-w-md p-4 rounded-lg border shadow-lg transition-all duration-300 ${
          variant === "error"
            ? "bg-red-50 text-red-800 border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800"
            : "bg-green-50 text-green-800 border-green-200 dark:bg-green-900/20 dark:text-green-400 dark:border-green-800"
        }`;
        toast.innerHTML = `
          <div class="flex items-start gap-3">
            <div class="flex-1 text-sm font-medium">${message}</div>
            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="this.parentElement.parentElement.remove()">✕</button>
          </div>
        `;
        document.body.appendChild(toast);

        // Auto-remove after 5 seconds
        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateX(100%)";
          setTimeout(() => toast.remove(), 300);
        }, 5000);
      }

      // Handle CRUD form submissions
      document.addEventListener("crud-submit", async (e) => {
        const { modalId, mode, data } = e.detail;

        try {
          // Parse composite ID: "role::module::option"
          const [role, module, option] = data.id.split("::");
          if (mode === "create") {
            // Create new asset
            await createAsset({
              name: data.name,
              description: data.description,
              category: data.category,
              reference: data.reference,
              status: data.status,
              tags: data.tags,
              detail: data.detail,
              is_active: data.is_active !== false,
            });
            showToast("Asset created successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "edit") {
            // Update existing asset (id is numeric)
            await updateAsset(Number(data.id), {
              name: data.name,
              description: data.description,
              category: data.category,
              reference: data.reference,
              status: data.status,
              tags: data.tags,
              detail: data.detail,
              is_active: data.is_active !== false,
            });
            showToast("Asset updated successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "delete") {
            await deleteAsset(Number(data.id));
            showToast("Asset deleted successfully!");
            setTimeout(() => window.location.reload(), 1000);
          }
        } catch (error) {
          console.error("CRUD operation failed:", error);
          showToast(error instanceof Error ? error.message : "An error occurred", "error");
        }
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="border-0 p-0">
        <DataTable
          columns={columns}
          data={data}
          tableId="assets"
          i18Item="asset"
          columnFilter="category"
          filterOptions={categories}
          detailPage="/lib/characterizations"
          mdItem="characterization"
        />
      </div>
    </div>
  </div>
</BaseLayout>
