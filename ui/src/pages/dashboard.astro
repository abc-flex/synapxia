---
import { getToken, getUser } from "@/lib/auth";
import Layout from "@/layouts/Layout.astro";

// Check if user is authenticated (client-side localStorage; null during SSR
// — that's fine, middleware also gates this route).
const token = getToken();
if (!token) {
  return Astro.redirect("/login");
}

// Get user info from localStorage (the client-side <script> below also
// refreshes this via getCurrentUser() so values stay current).
const user = getUser();
---

<Layout title="Dashboard">
  <div class="min-h-screen bg-gradient-to-br from-slate-900 to-slate-800">
    <!-- Navigation Bar -->
    <nav class="bg-slate-800 border-b border-slate-700 shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div class="flex items-center">
            <h1 class="text-2xl font-bold text-white">SynapxIA</h1>
            <span class="ml-4 text-sm text-slate-400">Dashboard</span>
          </div>
          <div class="flex items-center space-x-4">
            {
              user && (
                <>
                  <div class="text-right">
                    <p class="text-sm font-medium text-white">
                      {user.first_name} {user.last_name}
                    </p>
                    <p class="text-xs text-slate-400">{user.username}</p>
                  </div>
                  <button
                    id="logoutBtn"
                    class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-medium rounded-lg transition-colors"
                  >
                    Logout
                  </button>
                </>
              )
            }
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Welcome Section -->
      {
        user && (
          <div class="bg-gradient-to-r from-blue-600 to-indigo-600 rounded-lg shadow-lg p-8 text-white mb-8">
            <h2 class="text-3xl font-bold mb-2">
              Welcome, {user.first_name}! 👋
            </h2>
            <p class="text-blue-100">
              You are successfully logged in to the SynapxIA administration
              dashboard.
            </p>
          </div>
        )
      }

      <!-- User Profile Card -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <!-- Profile Information -->
        <div class="md:col-span-2">
          <div
            class="bg-slate-700 rounded-lg shadow-lg p-6 border border-slate-600"
          >
            <h3 class="text-xl font-bold text-white mb-4">
              Profile Information
            </h3>
            {
              user && (
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <label class="text-xs font-semibold text-slate-400 uppercase">
                      Username
                    </label>
                    <p class="text-white mt-1 text-lg">{user.username}</p>
                  </div>
                  <div>
                    <label class="text-xs font-semibold text-slate-400 uppercase">
                      Email
                    </label>
                    <p class="text-white mt-1 text-lg">{user.email}</p>
                  </div>
                  <div>
                    <label class="text-xs font-semibold text-slate-400 uppercase">
                      Full Name
                    </label>
                    <p class="text-white mt-1 text-lg">
                      {user.first_name} {user.last_name}
                    </p>
                  </div>
                  <div>
                    <label class="text-xs font-semibold text-slate-400 uppercase">
                      Account Status
                    </label>
                    <p class="mt-1">
                      {user.is_active ? (
                        <span class="inline-block bg-green-600 text-white px-3 py-1 rounded text-sm font-medium">
                          Active
                        </span>
                      ) : (
                        <span class="inline-block bg-red-600 text-white px-3 py-1 rounded text-sm font-medium">
                          Inactive
                        </span>
                      )}
                    </p>
                  </div>
                </div>
              )
            }
          </div>
        </div>

        <!-- Permissions Card -->
        <div>
          <div
            class="bg-slate-700 rounded-lg shadow-lg p-6 border border-slate-600"
          >
            <h3 class="text-xl font-bold text-white mb-4">Permissions</h3>
            {
              user && (
                <div class="space-y-3">
                  <div>
                    <label class="text-xs font-semibold text-slate-400 uppercase">
                      Role
                    </label>
                    <p class="text-white mt-1 font-medium">{user.profile}</p>
                  </div>
                  <div>
                    <label class="text-xs font-semibold text-slate-400 uppercase">
                      Business Unit
                    </label>
                    <p class="text-white mt-1 font-medium">
                      {user.unit}
                    </p>
                  </div>
                  <div class="pt-2 border-t border-slate-600">
                    <label class="text-xs font-semibold text-slate-400 uppercase">
                      Admin Access
                    </label>
                    <p class="mt-1">
                      {user.is_superuser ? (
                        <span class="inline-block bg-purple-600 text-white px-3 py-1 rounded text-sm font-medium flex items-center">
                          <svg
                            class="w-4 h-4 mr-2"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                          >
                            <path
                              fill-rule="evenodd"
                              d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                              clip-rule="evenodd"
                            />
                          </svg>
                          Yes
                        </span>
                      ) : (
                        <span class="inline-block bg-slate-600 text-slate-300 px-3 py-1 rounded text-sm font-medium">
                          No
                        </span>
                      )}
                    </p>
                  </div>
                </div>
              )
            }
          </div>
        </div>
      </div>

      <!-- Account Details -->
      <div
        class="bg-slate-700 rounded-lg shadow-lg p-6 border border-slate-600 mb-8"
      >
        <h3 class="text-xl font-bold text-white mb-4">Account Details</h3>
        {
          user && (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="text-xs font-semibold text-slate-400 uppercase">
                  Account Created
                </label>
                <p class="text-white mt-1">
                  {user.created_at
                    ? new Date(user.created_at).toLocaleDateString()
                    : "N/A"}
                </p>
              </div>
              <div>
                <label class="text-xs font-semibold text-slate-400 uppercase">
                  Last Login
                </label>
                <p class="text-white mt-1">
                  {user.last_login_at ? (
                    <>
                      {new Date(user.last_login_at).toLocaleDateString()} at{" "}
                      {` `}
                      {new Date(user.last_login_at).toLocaleTimeString()}
                    </>
                  ) : (
                    "Never"
                  )}
                </p>
              </div>
            </div>
          )
        }
      </div>

      <!-- Quick Actions -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div
          class="bg-slate-700 rounded-lg shadow-lg p-6 border border-slate-600 hover:border-blue-500 transition-colors cursor-pointer"
        >
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg
                class="h-8 w-8 text-blue-500"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <div class="ml-4">
              <h4 class="text-lg font-medium text-white">Account Settings</h4>
              <p class="text-sm text-slate-400 mt-1">
                Manage your profile and preferences
              </p>
            </div>
          </div>
        </div>

        <div
          class="bg-slate-700 rounded-lg shadow-lg p-6 border border-slate-600 hover:border-green-500 transition-colors cursor-pointer"
        >
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg
                class="h-8 w-8 text-green-500"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                ></path>
              </svg>
            </div>
            <div class="ml-4">
              <h4 class="text-lg font-medium text-white">Change Password</h4>
              <p class="text-sm text-slate-400 mt-1">
                Update your account password
              </p>
            </div>
          </div>
        </div>

        <div
          class="bg-slate-700 rounded-lg shadow-lg p-6 border border-slate-600 hover:border-purple-500 transition-colors cursor-pointer"
        >
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg
                class="h-8 w-8 text-purple-500"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="ml-4">
              <h4 class="text-lg font-medium text-white">API Documentation</h4>
              <p class="text-sm text-slate-400 mt-1">
                View API endpoints and usage
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Session Info -->
      <div
        class="bg-blue-900 border border-blue-700 rounded-lg p-4 text-blue-100"
      >
        <div class="flex items-start">
          <svg
            class="h-5 w-5 text-blue-400 mt-0.5 mr-3 flex-shrink-0"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path
              fill-rule="evenodd"
              d="M18 5v8a2 2 0 01-2 2h-5l-5 4v-4H4a2 2 0 01-2-2V5a2 2 0 012-2h12a2 2 0 012 2zm-7 4a1 1 0 00-2 0v2a1 1 0 102 0V9zm2-1a1 1 0 011 1v2a1 1 0 11-2 0V9a1 1 0 011-1zm2 1a1 1 0 00-2 0v2a1 1 0 102 0V9z"
              clip-rule="evenodd"></path>
          </svg>
          <div>
            <h4 class="font-medium">Session Active</h4>
            <p class="text-sm mt-1">
              Your authentication token is stored securely in your browser. It
              will expire after 60 minutes of inactivity.
            </p>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script>
    import { getCurrentUser, logout } from "@/lib/auth";

    // Background refresh: pull /me and update the cached user so any edits
    // made on /profile (or elsewhere) show up on next paint. Non-blocking.
    getCurrentUser().catch(() => {
      /* silent — middleware handles unauth, /me may simply not be reachable */
    });

    // Handle logout button — await so the refresh-token revocation hits the
    // server before we navigate away.
    const logoutBtn = document.getElementById("logoutBtn");
    if (logoutBtn) {
      logoutBtn.addEventListener("click", async () => {
        await logout();
        window.location.href = "/login";
      });
    }
  </script>
</Layout>
