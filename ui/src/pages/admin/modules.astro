---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getModules } from "@/lib/modules";

// Fetch modules from API
let modules: any[] = [];
let errorMessage: string | null = null;

try {
  const apiModules = await getModules();
  modules = apiModules;
} catch (error) {
  console.error('Failed to fetch modules:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch modules from API';
  // Fallback to empty array to still render the page
  modules = [];
}

const columns = [
  { key: "sort_order", label: "module_modal.sort_order" },
  { key: "code", label: "module_modal.code", visible: false },
  { key: "name", label: "module_modal.name", as: "title", subtitleKey: "code", subtitleFormat: "text" },
];
const data = modules.map((item) => ({
  id: item.code,
  code: item.code,
  name: item.name,
  description: item.description,
  sort_order: item.sort_order,
  icon: item.icon,
  is_active: item.is_active,
}));

const formFields = [
  { key: "code", label: "module_modal.code", pk: true, required: true, placeholder: "e.g. ADMIN" },
  { key: "name", label: "module_modal.name", required: true, placeholder: "Administration" },
  { key: "sort_order", label: "module_modal.sort_order", required: true, type: "number" as const, placeholder: "10" },
  { key: "icon", label: "module_modal.icon", placeholder: "Heroicon path" },
  {
    key: "description",
    label: "module_modal.description",
    type: "textarea" as const,
    placeholder: "Optional details",
  },
];
const fieldKeys = formFields.map((f) => f.key);
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto w-full max-w-full md:p-0">
    <Breadcrumb
      moduleName="Administration"
      pageName="Modules"
      pageTitle="Modules"
      homeLink="/"
      moduleNameKey="modules.ADMIN"
      pageNameKey="menu_options.modules"
      pageTitleKey="menu_options.modules"
    />

    <CrudModal
      mode="create"
      modalId="module-create-modal"
      entityName="Module"
      fields={formFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="module-edit-modal"
      entityName="Module"
      fields={formFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="module-delete-modal"
      entityName="Module"
      fields={formFields}
      showTrigger={false}
    />

    <div
      id="modules-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage } from "/scripts/crudClient.js";
      import {
        createModule,
        updateModule,
        deleteModule,
      } from "/src/lib/modules";

      initCrudPage({
        dataId: "modules-data",
        editModalId: "module-edit-modal",
        deleteModalId: "module-delete-modal",
      });

      // Helper function to show toast notifications
      function showToast(message, variant = "info") {
        const toast = document.createElement("div");
        toast.className = `fixed top-4 right-4 z-50 max-w-md p-4 rounded-lg border shadow-lg transition-all duration-300 ${
          variant === "error"
            ? "bg-red-50 text-red-800 border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800"
            : "bg-green-50 text-green-800 border-green-200 dark:bg-green-900/20 dark:text-green-400 dark:border-green-800"
        }`;
        toast.innerHTML = `
          <div class="flex items-start gap-3">
            <div class="flex-1 text-sm font-medium">${message}</div>
            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="this.parentElement.parentElement.remove()">✕</button>
          </div>
        `;
        document.body.appendChild(toast);

        // Auto-remove after 5 seconds
        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateX(100%)";
          setTimeout(() => toast.remove(), 300);
        }, 5000);
      }

      // Handle CRUD form submissions
      document.addEventListener("crud-submit", async (e) => {
        const { modalId, mode, data } = e.detail;

        try {
          if (mode === "create") {
            // Create new module
            await createModule({
              code: data.code,
              name: data.name,
              description: data.description,
              sort_order: data.sort_order ? Number(data.sort_order) : 0,
              icon: data.icon,
              is_active: data.is_active !== false,
            });

            showToast("Module created successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "edit") {
            // Update existing module
            await updateModule(data.id, {
              name: data.name,
              description: data.description,
              sort_order: data.sort_order ? Number(data.sort_order) : undefined,
              icon: data.icon,
              is_active: data.is_active !== false,
            });

            showToast("Module updated successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "delete") {
            // Delete module
            await deleteModule(data.id);

            showToast("Module deleted successfully!");
            setTimeout(() => window.location.reload(), 1000);
          }
        } catch (error) {
          console.error("CRUD operation failed:", error);
          showToast(error.message || "An error occurred", "error");
        }
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="space-y-5 sm:space-y-6">
        <DataTable
          columns={columns}
          data={data}
          tableId="modules"
          i18Item="module"
        />
      </div>
    </div>
  </div>
</BaseLayout>
