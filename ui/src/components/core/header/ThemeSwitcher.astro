---
import { t } from "@/i18n";
import { getLocale } from "@/utils/getLocale";
import SunIcon from "@/components/icons/sun.svg?raw";
import MoonIcon from "@/components/icons/moon.svg?raw";

const locale = getLocale(Astro);
---

<button
  class="relative flex h-11 w-11 items-center justify-center rounded-full border border-gray-200 bg-white text-gray-500 transition hover:bg-gray-100 hover:text-gray-700 dark:border-gray-800 dark:bg-gray-900 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white"
  type="button"
  aria-label={t(locale, "header.toggle_theme")}
  aria-pressed="false"
  data-theme-toggle
>
  <span class="hidden dark:block">
    <Fragment set:html={SunIcon} />
  </span>
  <span class="dark:hidden">
    <Fragment set:html={MoonIcon} />
  </span>
</button>
