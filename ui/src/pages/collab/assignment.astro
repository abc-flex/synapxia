---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";

// Dimension + as-of date are chosen client-side; the secured endpoint
// (GET /api/metrics/dimension/{code}?date=...) needs the JWT from localStorage,
// so the grid is fetched and rendered in the browser, not at build time.
const dimensionFilter = Astro.url.searchParams.get("dimension") || "";
---

<BaseLayout>
  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <!-- Breadcrumb Start -->
    <Breadcrumb
      moduleName="Collaboration"
      pageName="Assignments Dashboard"
      pageTitle="Assigments Dashboard"
      homeLink="/"
      moduleNameKey="modules.COLLAB"
      pageNameKey="menu_options.assignment"
      pageTitleKey="menu_options.assignment"
    />
    <!-- Breadcrumb End -->

    <div class="space-y-5 sm:space-y-6">
      <!-- Filters Section -->
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div class="flex flex-col gap-1">
          <label
            for="dimensionSelect"
            class="text-sm font-semibold text-slate-600"
            data-i18n="assignment_dashboard.dimension"
          >
            Dimension
          </label>
          <select
            id="dimensionSelect"
            data-initial-dimension={dimensionFilter}
            class="px-4 py-2 border border-slate-200 rounded-lg bg-white text-slate-900 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition shadow-sm"
          >
          </select>
        </div>
        <div class="flex flex-col gap-1">
          <label
            for="asOfDate"
            class="text-sm font-semibold text-slate-600"
            data-i18n="assignment_dashboard.date"
          >
            As-of date
          </label>
          <input
            id="asOfDate"
            type="date"
            class="px-4 py-2 border border-slate-200 rounded-lg bg-white text-slate-900 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition shadow-sm"
          />
        </div>
      </div>

      <!-- Dashboard Grid Section -->
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm min-w-[800px] datatable-dense">
          <thead
            id="assignmentThead"
            class="bg-gray-200 text-sm uppercase text-gray-700 border-b border-black"
          >
          </thead>
          <tbody id="assignmentTbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Modal for Assignment Details -->
  <div id="assignmentModal" class="hidden fixed inset-0 bg-black/50 z-[9999] flex items-center justify-center">
    <div class="bg-white rounded-2xl p-8 w-[800px] max-w-5xl shadow-2xl border border-slate-200">
      <div class="flex justify-between items-start mb-6">
        <h3 id="modalAssignmentName" class="text-2xl font-bold text-gray-900"></h3>
        <button id="closeModalBtn" class="text-gray-400 hover:text-gray-600 text-2xl transition">
          ✕
        </button>
      </div>

      <div class="space-y-4">
        <div>
          <label class="block text-sm font-semibold text-gray-600 mb-1">Email:</label>
          <span id="modalAssignmentEmail" class="text-slate-900"></span>
        </div>
        <div class="flex flex-col gap-4 md:flex-row md:gap-4">
          <div class="flex-1">
            <label class="block text-sm font-semibold text-gray-600 mb-1">Rol:</label>
            <span id="modalAssignmentRole" class="text-slate-900"></span>
          </div>
          <div class="flex-1">
            <label class="block text-sm font-semibold text-gray-600 mb-1">Equipo:</label>
            <span id="modalAssignmentTeam" class="text-slate-900"></span>
          </div>
          <div class="flex-1">
            <label class="block text-sm font-semibold text-gray-600 mb-1">Fecha:</label>
            <span id="modalAssignmentDate" class="text-slate-900"></span>
          </div>
        </div>
        <div>
          <label for="modalMetricSelect" class="block text-sm font-semibold text-gray-600 mb-2">
            Métrica actual:
          </label>
          <select
            id="modalMetricSelect"
            class="w-full px-3 py-2 border border-slate-200 rounded-lg bg-white text-slate-900 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition shadow-sm"
          >
            <option value="UNDEFINED">---</option>
            <option value="NO_USAGE">No Usage</option>
            <option value="LOW">Low</option>
            <option value="MODERATE">Moderate</option>
            <option value="HIGH">High</option>
            <option value="VERY_HIGH">Very High</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-600 mb-1">Observación:</label>
          <textarea
            id="modalAssignmentObservation"
            class="w-full px-3 py-2 border border-slate-200 rounded-lg bg-white text-slate-900 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition min-h-[120px] shadow-sm"
          ></textarea>
        </div>
      </div>

      <div class="flex gap-3 mt-8">
        <button
          id="saveMetricBtn"
          class="flex-1 px-5 py-3 bg-blue-50 text-indigo-600 font-semibold rounded-2xl border border-blue-200 shadow-sm hover:border-indigo-300 hover:text-indigo-700 transition transform hover:-translate-y-0.5"
        >
          Guardar Métrica
        </button>
      </div>
    </div>
  </div>

  <style>
    .avatar-tooltip {
      @apply hidden;
    }

    .avatar-wrapper:hover .avatar-tooltip {
      @apply block;
    }

    @keyframes slideIn {
      from {
        transform: translateX(100%);
        opacity: 0;
      }
      to {
        transform: translateX(0);
        opacity: 1;
      }
    }

    .animate-slideIn {
      animation: slideIn 0.3s ease;
    }
  </style>

  <script>
    import { getDimensions } from "@/lib/dimensions";
    import { getMetricsByDimension } from "@/lib/metrics";
    import type { MetricByDimension } from "@/types/api";

    // ----- Constants & helpers (ported from former server-side frontmatter) -----
    const METRIC_LEVELS = ["UNDEFINED", "NO_USAGE", "LOW", "MODERATE", "HIGH", "VERY_HIGH"];
    const LEGACY_METRIC_MAP: Record<string, string> = {
      ALTO: "HIGH",
      ALTA: "HIGH",
      MEDIO: "MODERATE",
      MEDIA: "MODERATE",
      BAJO: "LOW",
      BAJA: "LOW",
    };

    function normalizeMetricValue(metric: string): string {
      if (!metric) return "NO_USAGE";
      const candidate = metric.toString().trim().toUpperCase().replace(/\s+/g, "_");
      if (METRIC_LEVELS.includes(candidate)) return candidate;
      if (LEGACY_METRIC_MAP[candidate]) return LEGACY_METRIC_MAP[candidate];
      return "NO_USAGE";
    }

    function getInitials(name: string): string {
      return name
        .split(" ")
        .filter(Boolean)
        .map((part) => part[0])
        .join("")
        .slice(0, 3)
        .toUpperCase();
    }

    function getMetricColorClass(metric: string): string {
      const colorMap: Record<string, string> = {
        UNDEFINED: "bg-slate-100 text-slate-700 border border-slate-300",
        NO_USAGE: "bg-red-300 text-red-700 border border-red-500",
        LOW: "bg-orange-300 text-orange-700 border border-orange-500",
        MODERATE: "bg-yellow-200 text-yellow-700 border border-yellow-500",
        HIGH: "bg-lime-300 text-lime-700 border border-lime-500",
        VERY_HIGH: "bg-green-300 text-green-700 border border-green-500",
      };
      return colorMap[metric] || "bg-gray-400";
    }

    // Minimal i18n lookup against the dict injected by ClientTranslations.astro
    function t(key: string, fallback: string): string {
      const dict = (window as any).__I18N__;
      if (!dict) return fallback;
      const value = key.split(".").reduce((acc: any, part) => (acc ? acc[part] : undefined), dict);
      return typeof value === "string" ? value : fallback;
    }

    function showNotification(message: string, variant: "info" | "error" = "info") {
      const palette =
        variant === "error"
          ? "bg-red-50 text-red-600 border-red-200"
          : "bg-blue-50 text-blue-600 border-blue-200";
      const notification = document.createElement("div");
      notification.className = `fixed top-6 right-6 z-[1100] animate-slideIn px-5 py-3 rounded-lg shadow-lg border font-semibold ${palette}`;
      notification.textContent = message;
      document.body.appendChild(notification);
      setTimeout(() => notification.remove(), 3000);
    }

    function escapeHtml(value: string): string {
      return String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }

    // ----- Application state -----
    let assignments: MetricByDimension[] = [];
    let currentAssignment: MetricByDimension | null = null;

    document.addEventListener("DOMContentLoaded", async () => {
      setupStaticListeners();
      initDateInput();
      await loadDimensions();
      await reload();
    });

    // Default the as-of date to today (local).
    function initDateInput() {
      const input = document.getElementById("asOfDate") as HTMLInputElement | null;
      if (input && !input.value) {
        const now = new Date();
        const yyyy = now.getFullYear();
        const mm = String(now.getMonth() + 1).padStart(2, "0");
        const dd = String(now.getDate()).padStart(2, "0");
        input.value = `${yyyy}-${mm}-${dd}`;
      }
    }

    // Populate the dimension selector from the API.
    async function loadDimensions() {
      const select = document.getElementById("dimensionSelect") as HTMLSelectElement | null;
      if (!select) return;
      try {
        const dimensions = await getDimensions();
        const initial = select.getAttribute("data-initial-dimension") || "";
        select.innerHTML = dimensions
          .map(
            (dim) =>
              `<option value="${escapeHtml(dim.code)}"${
                dim.code === initial ? " selected" : ""
              }>${escapeHtml(dim.name)}</option>`,
          )
          .join("");
      } catch (err) {
        console.error("Failed to load dimensions", err);
        showNotification("Error loading dimensions", "error");
      }
    }

    // Fetch the assignments grid for the selected dimension + as-of date.
    async function reload() {
      const dimensionSelect = document.getElementById("dimensionSelect") as HTMLSelectElement | null;
      const dateInput = document.getElementById("asOfDate") as HTMLInputElement | null;
      const dimensionCode = dimensionSelect?.value || "";
      const dateValue = dateInput?.value || "";
      if (!dimensionCode || !dateValue) {
        assignments = [];
        renderGrid();
        return;
      }
      // Make the cut-off inclusive of the whole selected day.
      const cutoff = `${dateValue}T23:59:59`;
      try {
        const rows = await getMetricsByDimension(dimensionCode, cutoff);
        assignments = rows.map((row) => ({ ...row, metric: normalizeMetricValue(row.metric) }));
        (window as any).assignmentsData = assignments;
      } catch (err) {
        console.error("Failed to load metrics by dimension", err);
        showNotification("Error loading assignments", "error");
        assignments = [];
      }
      renderGrid();
    }

    // ----- Rendering -----
    function renderGrid() {
      const thead = document.getElementById("assignmentThead");
      const tbody = document.getElementById("assignmentTbody");
      if (!thead || !tbody) return;

      const withTeam = assignments.filter((a) => a.team && a.team.trim() !== "");
      const withoutTeam = assignments.filter((a) => !a.team || a.team.trim() === "");
      const roles = [...new Set(withTeam.map((a) => a.role))];
      const teams = [...new Set(withTeam.map((a) => a.team))].filter(Boolean);

      if (assignments.length === 0) {
        thead.innerHTML = "";
        tbody.innerHTML = `<tr><td class="px-4 py-10 text-center text-slate-500">${escapeHtml(
          t("assignment_dashboard.empty_message", "No assignments found"),
        )}</td></tr>`;
        return;
      }

      // Header
      thead.innerHTML = `
        <tr class="border-b border-slate-200">
          <th class="text-slate-900 text-center px-2 py-3 font-semibold sticky top-0 z-10 border border-slate-200">
            <span class="uppercase">Team</span> &#11208;<br>
            <span class="uppercase">Role</span> &#11206;
          </th>
          ${teams
            .map(
              (team) =>
                `<th class="text-slate-900 px-4 py-3 font-semibold text-center border border-slate-200 sticky top-0 z-10">${escapeHtml(
                  team.toUpperCase(),
                )}</th>`,
            )
            .join("")}
        </tr>`;

      // Body: role × team matrix
      const roleRows = roles
        .map((role) => {
          const cells = teams
            .map((team) => {
              const employees = withTeam.filter((a) => a.role === role && a.team === team);
              const avatars = employees.map((emp) => avatarMarkup(emp)).join("");
              return `<td class="px-4 py-3 border border-slate-200 text-center">${
                employees.length > 0
                  ? `<div class="flex flex-wrap gap-2 justify-center items-center min-h-[80px]">${avatars}</div>`
                  : ""
              }</td>`;
            })
            .join("");
          return `<tr class="border-b border-slate-200 hover:bg-slate-50">
            <td class="bg-gray-50 text-slate-900 text-center text-sm uppercase px-4 py-3 font-semibold border border-slate-200">${escapeHtml(
              role,
            )}</td>${cells}</tr>`;
        })
        .join("");

      // No-team row
      let noTeamRow = "";
      if (withoutTeam.length > 0) {
        const items = withoutTeam
          .map(
            (emp) =>
              `<div class="flex flex-col items-center gap-2">${avatarMarkup(
                emp,
              )}<span class="text-xs font-medium text-slate-600 max-w-[70px] text-center line-clamp-2">${escapeHtml(
                emp.role,
              )}</span></div>`,
          )
          .join("");
        noTeamRow = `<tr class="border-b border-slate-200">
          <td class="px-4 py-3 font-semibold border border-slate-200">--</td>
          <td colspan="${teams.length}" class="px-4 py-3 border border-slate-200">
            <div class="grid grid-cols-4 gap-4 md:grid-cols-6 lg:grid-cols-8 justify-items-center min-h-[120px]">${items}</div>
          </td></tr>`;
      }

      tbody.innerHTML = roleRows + noTeamRow;
      wireAvatars();
    }

    function avatarMarkup(emp: MetricByDimension): string {
      const initials = getInitials(emp.name);
      const metricClass = getMetricColorClass(emp.metric);
      return `<div class="avatar-wrapper relative inline-block group">
        <button class="avatar w-12 h-12 rounded-full flex items-center justify-center font-bold text-sm cursor-pointer transition-transform hover:scale-110 ${metricClass}" data-email="${escapeHtml(
          emp.email,
        )}" data-name="${escapeHtml(emp.name)}">${escapeHtml(initials)}</button>
        <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 bg-gray-900 text-white text-xs px-3 py-2 rounded whitespace-nowrap z-50 pointer-events-none shadow-lg opacity-0 group-hover:opacity-100 transition-opacity duration-200">${escapeHtml(
          emp.name,
        )}</div>
      </div>`;
    }

    // ----- Listeners -----
    function setupStaticListeners() {
      document.getElementById("closeModalBtn")?.addEventListener("click", closeModal);
      document.getElementById("assignmentModal")?.addEventListener("click", (e) => {
        if ((e.target as HTMLElement).id === "assignmentModal") closeModal();
      });
      document.getElementById("saveMetricBtn")?.addEventListener("click", saveMetric);
      document.getElementById("dimensionSelect")?.addEventListener("change", reload);
      document.getElementById("asOfDate")?.addEventListener("change", reload);
    }

    function wireAvatars() {
      document.querySelectorAll<HTMLButtonElement>(".avatar").forEach((btn) => {
        btn.addEventListener("click", () => {
          const email = btn.getAttribute("data-email") || "";
          openAssignmentModal(email);
        });
      });
    }

    // ----- Modal -----
    function openAssignmentModal(email: string) {
      const assignment = assignments.find((a) => a.email === email);
      if (!assignment) return;
      currentAssignment = assignment;

      (document.getElementById("modalAssignmentName") as HTMLElement).textContent = assignment.name;
      (document.getElementById("modalAssignmentEmail") as HTMLElement).textContent = assignment.email;
      (document.getElementById("modalAssignmentRole") as HTMLElement).textContent = assignment.role;
      (document.getElementById("modalAssignmentTeam") as HTMLElement).textContent = assignment.team || "-";
      (document.getElementById("modalAssignmentDate") as HTMLElement).textContent = assignment.date;
      (document.getElementById("modalAssignmentObservation") as HTMLTextAreaElement).value =
        assignment.observation || "";
      (document.getElementById("modalMetricSelect") as HTMLSelectElement).value = assignment.metric;

      document.getElementById("assignmentModal")?.classList.remove("hidden");
    }

    function closeModal() {
      document.getElementById("assignmentModal")?.classList.add("hidden");
      currentAssignment = null;
    }

    // Updates the in-memory grid only. Persisting the edit back to the API
    // (POST/PUT a metric) is a separate, not-yet-wired step.
    function saveMetric() {
      if (!currentAssignment) return;
      const newMetric = (document.getElementById("modalMetricSelect") as HTMLSelectElement).value;
      const newObservation = (document.getElementById("modalAssignmentObservation") as HTMLTextAreaElement)
        .value;

      const index = assignments.findIndex((a) => a.email === currentAssignment!.email);
      if (index !== -1) {
        assignments[index].metric = newMetric;
        assignments[index].observation = newObservation;
        showNotification("Métrica actualizada (solo en pantalla)", "info");
        closeModal();
        renderGrid();
      }
    }
  </script>
</BaseLayout>
