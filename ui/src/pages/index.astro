---
import Layout from "@/layouts/Layout.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import LandingBody from "@/components/landing/LandingBody.astro";
import LanguageSwitcher from "@/components/core/header/LanguageSwitcher.astro";
import { isAuthenticatedSSR } from "@/lib/auth";
import { t } from "@/i18n";
import { getLocale } from "@/utils/getLocale";

// Landing is shared by everyone. Logged-in users see it inside the app
// shell (BaseLayout — sidebar + header + AccountMenu). Anonymous users
// see it inside the minimal Layout with a small public top bar.
const isAuthed = isAuthenticatedSSR(Astro);
const locale = getLocale(Astro);
const title = t(locale, "home_page.title");
---

{isAuthed ? (
  <BaseLayout title={title}>
    <LandingBody isAuthed={true} />
  </BaseLayout>
) : (
  <Layout title={title}>
    {/* ============================== Public top bar ============================== */}
    <header class="mx-auto max-w-4xl flex flex-wrap items-center justify-between gap-3 px-3 pt-4 sm:px-4 sm:pt-5 md:px-6 md:pt-6">
      <a
        href="/"
        class="flex items-center gap-2 sm:gap-3 rounded-lg p-1 -m-1 transition hover:opacity-80 focus:outline-none focus:ring-2 focus:ring-indigo-400"
        aria-label="SynapxIA — Home"
      >
        <div class="flex h-9 w-9 sm:h-10 sm:w-10 items-center justify-center rounded-lg bg-indigo-600 text-white font-semibold text-sm sm:text-base">
          IA
        </div>
        <span class="text-xl sm:text-2xl font-semibold text-gray-900 dark:text-white">SynapxIA</span>
      </a>

      <div class="flex items-center gap-2 sm:gap-3">
        <LanguageSwitcher />
        <a
          href="/login"
          class="hidden sm:inline-flex items-center rounded-lg border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-100 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-800 transition"
          data-i18n="login_page.sign_in"
        >
          Sign In
        </a>
        <a
          href="/signup"
          class="inline-flex items-center rounded-lg bg-indigo-600 px-3 sm:px-4 py-2 text-xs sm:text-sm font-semibold text-white hover:bg-indigo-700 transition"
          data-i18n="login_page.sign_up"
        >
          Sign up
        </a>
      </div>
    </header>

    <LandingBody isAuthed={false} />
  </Layout>
)}
