---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components//core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getNavigationData } from "@/lib/navigation";
import { getOptions } from "@/lib/options";
import { getModules } from "@/lib/modules";

// Fetch options from API
let options: any[] = [];
let errorMessage: string | null = null;
try {
  const apiOptions = await getOptions();
  options = apiOptions;
} catch (error) {
  console.error('Failed to fetch options:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch options from API';
  // Fallback to empty array to still render the page
  options = [];
}

// Fetch modules from API for select field
let modules: any[] = [];
try {
  const apiModules = await getModules();
  modules = apiModules;
} catch (error) {
  console.error('Failed to fetch modules:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch modules from API';
  // Fallback to empty array to still render the page
  modules = [];
}

const title = "SynapxIA";
const { primaryNav, itemsNav } = getNavigationData();

const columns = [
  { key: "sort_order", label: "#" },
  { key: "module", label: "Module" },
  { key: "name", label: "Name" },
  { key: "path", label: "Path" },
];
const data = options.map((option) => ({
  id: `${option.module}:${option.path}`,
  module: option.module,
  name: option.name,
  path: option.path,
  sort_order: option.sort_order,
}));

const optionFields = [
  { key: "name", label: "Name", required: true, placeholder: "e.g. Users" },
  { key: "module", label: "Module", type: "select" as const, options: modules, required: true },
  { key: "path", label: "Path", required: true, placeholder: "/admin/users" },
  {
    key: "sort_order",
    label: "Sort Order",
    type: "number" as const,
    placeholder: "10",
  },
];
const fieldKeys = optionFields.map((f) => f.key);
---

<BaseLayout title={title} navModules={primaryNav} navOptions={itemsNav}>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <Breadcrumb
      moduleName="Administration"
      pageName="Options"
      pageTitle="Options"
      homeLink="/"
      moduleNameKey="modules.ADMIN"
      pageNameKey="menu_options.options"
    />

    <CrudModal
      mode="create"
      modalId="option-create-modal"
      entityName="Option"
      fields={optionFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="option-edit-modal"
      entityName="Option"
      fields={optionFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="option-delete-modal"
      entityName="Option"
      fields={optionFields}
      showTrigger={false}
    />

    <div
      id="options-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage } from "/scripts/crudClient.js";
      initCrudPage({
        dataId: "options-data",
        editModalId: "option-edit-modal",
        deleteModalId: "option-delete-modal",
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="border-0 p-0">
        <DataTable
          columns={columns}
          data={data}
          tableId="options"
          i18Item="option"
          columnFilter="module"
        />
      </div>
    </div>
  </div>
</BaseLayout>
