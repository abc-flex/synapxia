---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components//core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import modules from "../../data/modules.json";
import options from "../../data/options.json";
import users from "../../data/users.json";
import roles from "../../data/roles.json";

const title = "SynapxIA";
const primaryNav = modules.map((module) => ({
  code: module.code,
  name: module.name,
  icon: `${module.icon}`,
}));
const itemsNav = options.map((option) => ({
  module: option.module,
  name: option.name,
  path: option.path,
}));

const columns = [
  { key: "name", label: "Name" },
  { key: "email", label: "Email" },
  { key: "role", label: "Role" },
];
const data = users.map((user) => ({
  id: user.id,
  name: user.name,
  email: user.email,
  role: user.role,
  unit: user.unit,
  status: user.status,
}));

const roleOptions = roles.map((r) => ({ label: r.name, value: r.code }));
const statusOptions = [
  { label: "Active", value: "Active" },
  { label: "Invited", value: "Invited" },
  { label: "Suspended", value: "Suspended" },
];

const userFields = [
  { key: "name", label: "Name", required: true, placeholder: "Jane Doe" },
  { key: "email", label: "Email", type: "email" as const, required: true, placeholder: "jane@company.com" },
  { key: "role", label: "Role", type: "select" as const, required: true, options: roleOptions },
  { key: "unit", label: "Unit", placeholder: "Operations" },
  { key: "status", label: "Status", type: "select" as const, required: true, options: statusOptions },
];
const fieldKeys = userFields.map((f) => f.key);
---

<BaseLayout title={title} navModules={primaryNav} navOptions={itemsNav}>
  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <Breadcrumb moduleName="Administration" pageName="Users" pageTitle="Users" homeLink="/" />

    <CrudModal mode="create" modalId="user-create-modal" entityName="User" fields={userFields} />
    <CrudModal mode="edit" modalId="user-edit-modal" entityName="User" fields={userFields} showTrigger={false} />
    <CrudModal mode="delete" modalId="user-delete-modal" entityName="User" fields={userFields} showTrigger={false} />

    <div
      id="users-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    />

    <script type="module">
      import { initCrudPage } from "/src/scripts/crudClient.js";
      initCrudPage({
        dataId: "users-data",
        editModalId: "user-edit-modal",
        deleteModalId: "user-delete-modal",
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="space-y-5 sm:space-y-6">
        <div class="border-t border-gray-100 dark:border-gray-800 p-0">
          <DataTable columns={columns} data={data} tableItem="user" tableId="users" />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
