---
import BaseLayout from "../layouts/BaseLayout.astro";
import modules from "../data/modules.json";
import options from "../data/options.json";

const title = "SynapxIA";
const primaryNav = modules.map(module => ({
  code: module.code,
  name: module.name,
  icon: `${module.icon}`
}));
const itemsNav = options.map(option => ({
  module: option.module,
  name: option.name,
  path: option.path
}));

---
<BaseLayout title={title} navModules={primaryNav} navOptions={itemsNav}>
  <div class="rounded-2xl border border-dashed border-slate-200 bg-white/70 p-10 text-center shadow-sm">
    <p class="text-sm uppercase tracking-[0.2em] text-slate-400">TailAdmin</p>
    <h1 class="mt-3 text-3xl font-bold text-slate-900">Astro Integration Starter</h1>
  </div>
</BaseLayout>
