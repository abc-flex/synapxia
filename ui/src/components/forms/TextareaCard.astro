---
import FormCard from "./FormCard.astro";

const base =
  "w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 placeholder:text-gray-400 shadow-sm focus:border-indigo-300 focus:ring-2 focus:ring-indigo-100 focus:outline-none dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/40";
const disabledBase = `${base} disabled:border-gray-100 disabled:bg-gray-50 disabled:placeholder:text-gray-300 dark:disabled:border-gray-800 dark:disabled:bg-white/5 dark:disabled:placeholder:text-white/20`;
---
<FormCard title="Textarea input field">
  <div class="space-y-6">
    <div>
      <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-300">
        Description
      </label>
      <textarea rows={6} placeholder="Enter a description..." class={base}></textarea>
    </div>

    <div>
      <label class="mb-1.5 block text-sm font-medium text-gray-400 dark:text-white/40">
        Description
      </label>
      <textarea rows={6} placeholder="Enter a description..." class={disabledBase} disabled></textarea>
    </div>

    <div>
      <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-300">
        Description
      </label>
      <textarea
        rows={6}
        placeholder="Enter a description..."
        class={`${base} border-rose-300 focus:border-rose-300 focus:ring-rose-100 dark:border-rose-700 dark:focus:border-rose-600`}
      ></textarea>
      <p class="mt-1 text-xs text-rose-500">Please enter a message in the textarea.</p>
    </div>
  </div>
</FormCard>
