---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "TailAdmin x Astro";
const primaryNav = [
  { label: "Dashboard", href: "#" },
  { label: "Calendar", href: "#" },
  { label: "User Profile", href: "#" },
  { label: "Forms", href: "#" },
  { label: "Tables", href: "#" },
  { label: "Pages", href: "#" },
];

---
<BaseLayout title={title} navItems={primaryNav}>
  <div class="rounded-2xl border border-dashed border-slate-200 bg-white/70 p-10 text-center shadow-sm">
    <p class="text-sm uppercase tracking-[0.2em] text-slate-400">TailAdmin</p>
    <h1 class="mt-3 text-3xl font-bold text-slate-900">Astro Integration Starter</h1>
    <p class="mt-3 text-slate-600">
      Sidebar and header are now reusable components. Plug your content here.
    </p>
  </div>
</BaseLayout>
