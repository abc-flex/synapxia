---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import lists from "../../data/lists.json";
import modules from "../../data/modules.json";
import options from "../../data/options.json";

const title = "SynapxIA";
const primaryNav = modules.map((module) => ({
  code: module.code,
  name: module.name,
  icon: `${module.icon}`,
}));
const itemsNav = options.map((option) => ({
  module: option.module,
  name: option.name,
  path: option.path,
}));


const columns = [
  { key: "module", label: "Module", visible: true },
  { key: "code", label: "Code", visible: true },
  { key: "name", label: "Name", visible: true },
  { key: "type", label: "Type", visible: true },
];
const data = lists.map((item) => ({
  id: item.code,
  module: item.module,
  code: item.code,
  name: item.name,
  type: item.type,  //references List_items where list='LIST_TYPE'
  description: item.description,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));
const tableFields = [
  { key: "module", label: "Module", required: true, placeholder: "e.g. ADMIN" },
  { key: "code", label: "Code", required: true, placeholder: "e.g. STATUS" },
  { key: "name", label: "Name", required: true, placeholder: "e.g. List statuses for..." },
  { key: "type", label: "Type", required: true, placeholder: "e.g. List statuses for..." },
  {
    key: "description",
    label: "Description",
    type: "textarea" as const,
    placeholder: "Optional details of list",
  },
  { key: "is_active", label: "Active", type: "checkbox" as const },
];
const fieldKeys = tableFields.map((f) => f.key);
---

<BaseLayout title={title} navModules={primaryNav} navOptions={itemsNav}>
  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <Breadcrumb
      moduleName="Administration"
      pageName="Lists"
      pageTitle="Lists"
      homeLink="/"
      moduleNameKey="modules.ADMIN"
      pageNameKey="menu_options.lists"
    />

    <CrudModal
      mode="create"
      modalId="list-create-modal"
      entityName="List"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="list-edit-modal"
      entityName="List"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="list-delete-modal"
      entityName="List"
      fields={tableFields}
      showTrigger={false}
    />

    <div
      id="lists-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage, openEditModal, openDeleteModal } from "/scripts/crudClient.js";

      initCrudPage({
        dataId: "lists-data",
        editModalId: "list-edit-modal",
        deleteModalId: "list-delete-modal",
      });
    </script>

    <div class="space-y-5 sm:space-y-6 bg-white dark:bg-gray-900 rounded-lg shadow-sm p-6">
      <div class="space-y-5 sm:space-y-6">
        <div class="border-0 p-0">
          <DataTable
            columns={columns}
            data={data}
            tableId="lists"
            i18Item="list"
            columnFilter="module"
            detailPage="/admin/items_list"
            mdItem="itemlist"
          />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
