---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components//core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import modules from "../../data/modules.json";
import options from "../../data/options.json";

const title = "SynapxIA";
const primaryNav = modules.map((module) => ({
  code: module.code,
  name: module.name,
  icon: `${module.icon}`,
}));
const itemsNav = options.map((option) => ({
  module: option.module,
  name: option.name,
  path: option.path,
}));

const columns = [
  { key: "code", label: "Code" },
  { key: "name", label: "Name" },
];
const data = units.map((unit) => ({
  id: unit.code,
  code: unit.code,
  name: unit.name,
  description: unit.description,
}));

const unitFields = [
  {
    key: "code",
    label: "Code",
    required: true,
    placeholder: "e.g. UNIT-OPS",
  },
  {
    key: "name",
    label: "Name",
    required: true,
    placeholder: "e.g. Operations",
  },
  {
    key: "description",
    label: "Description",
    type: "textarea" as const,
    placeholder: "Optional details",
  },
];
const fieldKeys = unitFields.map((f) => f.key);
---

<BaseLayout title={title} navModules={primaryNav} navOptions={itemsNav}>
  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <Breadcrumb moduleName="Administration" pageName="Units" pageTitle="Units" homeLink="/" />

    <CrudModal mode="create" modalId="unit-create-modal" entityName="Unit" fields={unitFields} />
    <CrudModal mode="edit" modalId="unit-edit-modal" entityName="Unit" fields={unitFields} showTrigger={false} />
    <CrudModal mode="delete" modalId="unit-delete-modal" entityName="Unit" fields={unitFields} showTrigger={false} />

    <div
      id="units-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    />

    <script type="module">
      import { initCrudPage } from "/src/scripts/crudClient.js";
      initCrudPage({
        dataId: "units-data",
        editModalId: "unit-edit-modal",
        deleteModalId: "unit-delete-modal",
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="space-y-5 sm:space-y-6">
        <div class="border-t border-gray-100 dark:border-gray-800 p-0">
          <DataTable columns={columns} data={data} tableItem="unit" tableId="units" />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
