---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getNavigationData } from "@/lib/navigation";
import { getListItems } from "@/lib/list_items";

// Fetch list_items from API
let list_items: any[] = [];
let errorMessage: string | null = null;

try {
  const apiLists = await getListItems();
  list_items = apiLists;
} catch (error) {
  console.error('Failed to fetch list_items:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch list_items from API';
  // Fallback to empty array to still render the page
  list_items = [];
}

const title = "SynapxIA";
const { primaryNav, itemsNav } = getNavigationData();

const columns = [
  { key: "sort_order", label: "#", visible: true },
  { key: "list", label: "List", visible: false},
  { key: "value", label: "Value", visible: true },
  { key: "label", label: "Label", visible: true },
];
const data = list_items.map((item) => ({
  id: item.value,
  list: item.list,
  value: item.value,
  label: item.label,
  sort_order: item.sort_order,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));
const tableFields = [
  { key: "list", label: "List", required: true },
  { key: "value", label: "Value", required: true },
  { key: "label", label: "Label", required: true },
  { key: "sort_order", label: "sort_order", required: true },
  { key: "is_active", label: "Active", type: "checkbox" as const },
];
const fieldKeys = tableFields.map((f) => f.key);
---

<BaseLayout title={title} navModules={primaryNav} navOptions={itemsNav}>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <Breadcrumb
      moduleName="Administration"
      pageName="ItemsList"
      pageTitle="Items Lists"
      homeLink="/"
      moduleNameKey="modules.ADMIN"
      pageNameKey="menu_options.list_items"
    />

    <CrudModal
      mode="create"
      modalId="list_item-create-modal"
      entityName="ListItem"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="list_item-edit-modal"
      entityName="ListItem"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="list_item-delete-modal"
      entityName="ListItem"
      fields={tableFields}
      showTrigger={false}
    />

    <div
      id="itemslist-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage, openEditModal, openDeleteModal } from "/scripts/crudClient.js";

      initCrudPage({
        dataId: "itemslist-data",
        editModalId: "list_item-edit-modal",
        deleteModalId: "list_item-delete-modal",
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="border-0 p-0">
        <DataTable
          columns={columns}
          data={data}
          tableId="items_list"
          i18Item="list_item"
          columnFilter="list"
          masterPage="/admin/lists"
          mdItem="list"
        />
      </div>
    </div>
  </div>
</BaseLayout>
