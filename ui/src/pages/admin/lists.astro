---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getLists } from "@/lib/lists";
import { getModules } from "@/lib/modules";
import { getListItemsbyList } from "@/lib/list_items";

// Fetch lists from API
let lists: any[] = [];
let errorMessage: string | null = null;
try {
  const apiLists = await getLists();
  lists = apiLists;
} catch (error) {
  console.error('Failed to fetch lists:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch lists from API';
  // Fallback to empty array to still render the page
  lists = [];
}

// Fetch modules from API for select field
let modules: any[] = [];
try {
  const apiModules = await getModules();
  modules = apiModules;
} catch (error) {
  console.error('Failed to fetch modules:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch modules from API';
  // Fallback to empty array to still render the page
  modules = [];
}

// Fetch items_list from API for select field
let types: any[] = [];
types = await getListItemsbyList('LIST_TYPE');


const columns = [
  { key: "module", label: "Module", visible: true },
  { key: "code", label: "Code", visible: true },
  { key: "name", label: "Name", visible: true },
  { key: "type", label: "Type", visible: true },
];
const data = lists.map((item) => ({
  id: item.code,
  module: item.module,
  code: item.code,
  name: item.name,
  type: item.type,  //references List_items where list='LIST_TYPE'
  description: item.description,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));
const tableFields = [
  { key: "code", label: "Code", required: true, placeholder: "e.g. STATUS" },
  { key: "name", label: "Name", required: true, placeholder: "e.g. List statuses for..." },
  { key: "type", label: "Type", type: "select", options: types, required: true },
  { key: "module", label: "Module", type: "select" as const, options: modules, required: false },
  {
    key: "description",
    label: "Description",
    type: "textarea" as const,
    placeholder: "Optional details of list",
  },
];
const fieldKeys = tableFields.map((f) => f.key);
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}
  
  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <Breadcrumb
      moduleName="Administration"
      pageName="Lists"
      pageTitle="Lists"
      homeLink="/"
      moduleNameKey="modules.ADMIN"
      pageNameKey="menu_options.lists"
    />

    <CrudModal
      mode="create"
      modalId="list-create-modal"
      entityName="List"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="list-edit-modal"
      entityName="List"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="list-delete-modal"
      entityName="List"
      fields={tableFields}
      showTrigger={false}
    />

    <div
      id="lists-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage, openEditModal, openDeleteModal } from "/scripts/crudClient.js";

      initCrudPage({
        dataId: "lists-data",
        editModalId: "list-edit-modal",
        deleteModalId: "list-delete-modal",
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="border-0 p-0">
        <DataTable
          columns={columns}
          data={data}
          tableId="lists"
          i18Item="list"
          columnFilter="module"
          detailPage="/admin/list_items"
          mdItem="list_item"
        />
      </div>
    </div>
  </div>
</BaseLayout>
