---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getBusinessUnits } from "@/lib/business_units";
import { getListItemsbyList } from "@/lib/list_items";

// Fetch business_units from API
let business_units: any[] = [];
let errorMessage: string | null = null;
try {
  const apiBusinessUnits = await getBusinessUnits();
  business_units = apiBusinessUnits;
} catch (error) {
  console.error('Failed to fetch business_units:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch business_units from API';
  // Fallback to empty array to still render the page
  business_units = [];
}

// Fetch items_list from API for select field
let types: any[] = [];
types = await getListItemsbyList('BIZ_UNIT_TYPE');

const columns = [
  { key: "code", label: "Code" },
  { key: "name", label: "Name" },
  { key: "type", label: "Type" },
  { key: "parent", label: "Parent" },
];
const data = business_units.map((item) => ({
  id: item.code,
  code: item.code,
  name: item.name,
  description: item.description,
  type: item.type,
  parent: item.parent,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));
const tableFields = [
  { key: "code", label: "Code", required: true, placeholder: "e.g. ADMIN" },
  { key: "name", label: "Name", required: true, placeholder: "e.g. Administration" },
  { key: "type", label: "Type", type: "select", options: types, required: false },
  { key: "parent", label: "Parent", required: false },
  {
    key: "description",
    label: "Description",
    type: "textarea" as const,  
    placeholder: "Optional details of business unit",
  },
];
const fieldKeys = tableFields.map((f) => f.key);
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <!-- Breadcrumb Start -->
    <Breadcrumb
      moduleName="Administration"
      pageName="BusinessUnits"
      pageTitle="Business Units"
      homeLink="/"
      moduleNameKey="modules.ADMIN"
      pageNameKey="menu_options.business_units"
    />
    <!-- Breadcrumb End -->

    <CrudModal
      mode="create"
      modalId="businessunit-create-modal"
      entityName="BusinessUnit"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="businessunit-edit-modal"
      entityName="BusinessUnit"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="businessunit-delete-modal"
      entityName="BusinessUnit"
      fields={tableFields}
      showTrigger={false}
    />

    <div
      id="business_units-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage } from "/scripts/crudClient.js";
      initCrudPage({
        dataId: "business_units-data",
        editModalId: "businessunit-edit-modal",
        deleteModalId: "businessunit-delete-modal",
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="space-y-5 sm:space-y-6">
        <!-- ====== Table Start -->
        <DataTable
          columns={columns}
          data={data}
          tableId="business_units"
          i18Item="businessunit"
        />
        <!-- ====== Table End -->
      </div>
    </div>
  </div>
</BaseLayout>
