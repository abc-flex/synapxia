---
/**
 * PermissionsList — the read-only "Permissions" section embedded inside the
 * reusable CatalogDetailModal. Presentational shell only: a status line + a
 * list container that the `mountPermissions` controller (lib/assetPermissionsView.ts)
 * hydrates on open with the asset's permission grants (target type · target ·
 * access level).
 *
 * View-only — the editable permissions live in the /lib/assets repo modal.
 * Backed by the existing `GET /api/asset_permissions/asset/{id}` (module-read
 * gated) — no new endpoint.
 *
 * Ids are scoped by `modalId` so every catalog (prompts/agents/mcps) gets its
 * own section; the controller queries within `#${modalId}-permissions`.
 */
export interface Props {
  /** The detail dialog id, e.g. "mcp-view-modal". */
  modalId: string;
}
const { modalId } = Astro.props as Props;
---

{/* Lives alone in the modal's "Permissions" tab, which already labels it — so
    no in-section heading. The modal body owns the scroll. */}
<section id={`${modalId}-permissions`}>
  <p data-permissions-status class="hidden text-sm text-gray-400 dark:text-gray-500"></p>

  <div data-permissions-list class="space-y-2"></div>
</section>
