---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import TreeChart from "../../components/treeview/TreeChart.astro";
import { getCategoriesWithAssetsCount } from "../../lib/categories";

// Fetch categories from API
let categories: any[] = [];
try {
  categories = await getCategoriesWithAssetsCount(0, 1000);
} catch (error) {
  console.error("Error fetching categories:", error);
}
---

<BaseLayout>
  <div class="mx-auto w-full max-w-full md:p-0">
    <!-- Breadcrumb Start -->
    <Breadcrumb
      moduleName="Asset Taxonomy"
      pageName="View Taxonomy"
      pageTitle="View Taxonomy"
      homeLink="/"
      homeLink="/"
      moduleNameKey="modules.TAXO"
      pageNameKey="menu_options.taxonomy"
      pageTitleKey="menu_options.taxonomy"
    />
    <!-- Breadcrumb End -->

    <div class="space-y-5 sm:space-y-6">
      <!-- Categories Visualization -->
      {categories.length > 0 && (
        <TreeChart items={categories} />
      )}
    </div>
  </div>

  </BaseLayout>