{
  "framework": "astro",
  "buildCommand": "bun run build",
  "installCommand": "bun install",
  "outputDirectory": "dist",
  "devCommand": "bun run dev",
  "ignoreCommand": "git cat-file -e $VERCEL_GIT_PREVIOUS_SHA^{commit} 2>/dev/null && git diff --quiet $VERCEL_GIT_PREVIOUS_SHA $VERCEL_GIT_COMMIT_SHA -- ui/"
}
