---
/**
 * FavoritesPill — the shared "★ My favorites" filter pill, reused by the curated
 * card galleries (CardGallery) and the assets DataTable toolbar (DataTableFilters)
 * so favorites filtering looks identical everywhere.
 *
 * It's a presentational `aria-pressed` toggle button: the active (pressed) look
 * comes from Tailwind's `aria-pressed:` variant, so each host controller only
 * flips `aria-pressed` — no class juggling. The optional `columnKey`/`onValue`
 * let the DataTable controller (advancedTable.ts) treat it as a filter slot
 * (read its value + clear it on Reset); galleries omit them.
 */
export interface Props {
  /** DOM id — gallery uses `${galleryId}-fav-filter`, DataTable uses the slot id. */
  id: string;
  /** i18n key for the label (default the gallery's "My favorites"). */
  labelKey?: string;
  /** DataTable filter column key (omitted in galleries). */
  columnKey?: string | null;
  /** DataTable "on" value when pressed (omitted in galleries). */
  onValue?: string | null;
  /** Extra classes (e.g. width/justify) appended by the host. */
  class?: string;
}
const {
  id,
  labelKey = "gallery.favorites_only",
  columnKey = null,
  onValue = null,
  class: className = "",
} = Astro.props as Props;
---
<button
  id={id}
  type="button"
  aria-pressed="false"
  data-fav-pill
  data-column-key={columnKey}
  data-on-value={onValue}
  class:list={[
    "inline-flex items-center gap-1.5 rounded-lg border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 transition hover:bg-gray-50 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-800",
    "aria-pressed:border-indigo-600 aria-pressed:bg-indigo-600 aria-pressed:text-white aria-pressed:hover:bg-indigo-600 dark:aria-pressed:border-indigo-500 dark:aria-pressed:bg-indigo-500 dark:aria-pressed:hover:bg-indigo-500",
    className,
  ]}
>
  <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
    <path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.3 4.02a1 1 0 00.95.69h4.22c.97 0 1.37 1.24.59 1.81l-3.42 2.48a1 1 0 00-.36 1.12l1.3 4.02c.3.92-.75 1.69-1.54 1.12l-3.41-2.48a1 1 0 00-1.18 0l-3.41 2.48c-.78.57-1.84-.2-1.54-1.12l1.3-4.02a1 1 0 00-.36-1.12L2 9.45c-.78-.57-.38-1.81.6-1.81h4.21a1 1 0 00.95-.69l1.3-4.02z" />
  </svg>
  <span data-i18n={labelKey}>My favorites</span>
</button>
