---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import CrudModal from "../../components/forms/CrudModal.astro";

// Dimension + as-of date are chosen client-side; the secured endpoint
// (GET /api/metrics/dimension/{code}?date=...) needs the JWT from localStorage,
// so the grid is fetched and rendered in the browser, not at build time.
const dimensionFilter = Astro.url.searchParams.get("dimension") || "";

// The dashboard is a graphical view of metrics, so editing an avatar reuses the
// exact same Edit Metric modal as collab/metrics.astro (shared CrudModal). Since
// the metric's dimension + assignment can't change on edit, they're shown as
// disabled text inputs (no need to load the full option lists — just display the
// current values, filled client-side in openEditModal). Only `value` (from the
// dimension's SCALE list), `observation` and `measured_at` are editable.
const metricFields = [
  { key: "dimension", label: "metric_modal.dimension", type: "text" as const, disabled: true },
  { key: "assignment", label: "metric_modal.assignment", type: "text" as const, disabled: true },
  { key: "value", label: "metric_modal.value", type: "select" as const, options: [], required: true },
  { key: "observation", label: "metric_modal.observation", type: "textarea" as const, placeholder: "Optional observation" },
  { key: "measured_at", label: "metric_modal.measured_at", type: "calendar" as const, withTime: true },
];
---

<BaseLayout>
  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <!-- Breadcrumb Start -->
    <Breadcrumb
      moduleName="Collaboration"
      pageName="Assignments Dashboard"
      pageTitle="Assigments Dashboard"
      homeLink="/"
      moduleNameKey="modules.COLLAB"
      pageNameKey="menu_options.dashboard"
      pageTitleKey="menu_options.dashboard"
    />
    <!-- Breadcrumb End -->

    <div class="space-y-5 sm:space-y-6">
      <!-- Filters Section -->
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div class="flex flex-col gap-1">
          <label
            for="dimensionSelect"
            class="text-sm font-semibold text-slate-600"
            data-i18n="assignment_dashboard.dimension"
          >
            Dimension
          </label>
          <select
            id="dimensionSelect"
            data-initial-dimension={dimensionFilter}
            class="px-4 py-2 border border-slate-200 rounded-lg bg-white text-slate-900 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition shadow-sm"
          >
          </select>
        </div>
        <div class="flex flex-col gap-1">
          <label
            for="asOfDate"
            class="text-sm font-semibold text-slate-600"
            data-i18n="assignment_dashboard.date"
          >
            As-of date
          </label>
          <input
            id="asOfDate"
            type="date"
            class="px-4 py-2 border border-slate-200 rounded-lg bg-white text-slate-900 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition shadow-sm"
          />
        </div>
      </div>

      <!-- Dashboard Grid Section -->
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm min-w-[800px] datatable-dense">
          <thead
            id="assignmentThead"
            class="bg-gray-200 text-sm uppercase text-gray-700 border-b border-black"
          >
          </thead>
          <tbody id="assignmentTbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Edit modal: same shared CrudModal used by collab/metrics.astro. Options
       are injected client-side before opening (see openEditModal). -->
  <CrudModal
    mode="edit"
    modalId="metric-edit-modal"
    entityName="Metric"
    fields={metricFields}
    showTrigger={false}
  />

  <style>
    @keyframes slideIn {
      from {
        transform: translateX(100%);
        opacity: 0;
      }
      to {
        transform: translateX(0);
        opacity: 1;
      }
    }

    .animate-slideIn {
      animation: slideIn 0.3s ease;
    }
  </style>

  <script>
    import { getDimensions } from "@/lib/dimensions";
    import { getMetricsByDimension, updateMetric } from "@/lib/metrics";
    import { getListsbyType } from "@/lib/lists";
    import { getListItemsbyList } from "@/lib/list_items";
    import { getTeamsSelect } from "@/lib/teams";
    import { getRolesSelect } from "@/lib/roles";
    import type { MetricByDimension } from "@/types/api";

    // Grid row = the API projection + the raw (un-normalized) metric value, kept
    // for the edit modal's value <select> (the `metric` field is normalized to a
    // colour bucket for the avatar).
    type GridRow = MetricByDimension & { rawValue: string };

    // ----- Constants & helpers (ported from former server-side frontmatter) -----
    const METRIC_LEVELS = ["UNDEFINED", "NO_USAGE", "LOW", "MODERATE", "HIGH", "VERY_HIGH"];
    const LEGACY_METRIC_MAP: Record<string, string> = {
      ALTO: "HIGH",
      ALTA: "HIGH",
      MEDIO: "MODERATE",
      MEDIA: "MODERATE",
      BAJO: "LOW",
      BAJA: "LOW",
    };

    function normalizeMetricValue(metric: string): string {
      if (!metric) return "NO_USAGE";
      const candidate = metric.toString().trim().toUpperCase().replace(/\s+/g, "_");
      if (METRIC_LEVELS.includes(candidate)) return candidate;
      if (LEGACY_METRIC_MAP[candidate]) return LEGACY_METRIC_MAP[candidate];
      return "NO_USAGE";
    }

    function getInitials(name: string): string {
      return name
        .split(" ")
        .filter(Boolean)
        .map((part) => part[0])
        .join("")
        .slice(0, 3)
        .toUpperCase();
    }

    const METRIC_COLORS: Record<string, string> = {
      UNDEFINED: "bg-slate-100 text-slate-700 border border-slate-300",
      NO_USAGE: "bg-red-300 text-red-700 border border-red-500",
      LOW: "bg-orange-300 text-orange-700 border border-orange-500",
      MODERATE: "bg-yellow-200 text-yellow-700 border border-yellow-500",
      HIGH: "bg-lime-300 text-lime-700 border border-lime-500",
      VERY_HIGH: "bg-green-300 text-green-700 border border-green-500",
    };
    const getMetricColorClass = (metric: string): string =>
      METRIC_COLORS[metric] || "bg-gray-400";

    // Minimal i18n lookup against the dict injected by ClientTranslations.astro
    function t(key: string, fallback: string): string {
      const dict = (window as any).__I18N__;
      if (!dict) return fallback;
      const value = key.split(".").reduce((acc: any, part) => (acc ? acc[part] : undefined), dict);
      return typeof value === "string" ? value : fallback;
    }

    function showNotification(message: string, variant: "info" | "error" = "info") {
      const palette =
        variant === "error"
          ? "bg-red-50 text-red-600 border-red-200"
          : "bg-blue-50 text-blue-600 border-blue-200";
      const notification = document.createElement("div");
      notification.className = `fixed top-6 right-6 z-[1100] animate-slideIn px-5 py-3 rounded-lg shadow-lg border font-semibold ${palette}`;
      notification.textContent = message;
      document.body.appendChild(notification);
      setTimeout(() => notification.remove(), 3000);
    }

    function escapeHtml(value: string): string {
      return String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }

    // ----- Application state -----
    let assignments: GridRow[] = [];
    // Cached lookups feeding the edit modal's selects (populated client-side
    // because the metrics endpoints are JWT-secured — same reason the grid is).
    let dimensionList: any[] = [];
    let scalesByList: Record<string, any[]> = {};
    let dimensionScale: Record<string, string> = {};
    // Team/role code -> name, to show the assignment as "TeamName / RoleName / UserName".
    let teamsByCode: Record<string, string> = {};
    let rolesByCode: Record<string, string> = {};

    document.addEventListener("DOMContentLoaded", async () => {
      setupStaticListeners();
      initDateInput();
      await Promise.all([loadDimensions(), loadScales(), loadLookups()]);
      await reload();
    });

    // Team + role name lookups for the edit modal's assignment label.
    async function loadLookups() {
      try {
        const [teams, roles] = await Promise.all([getTeamsSelect(), getRolesSelect()]);
        teamsByCode = Object.fromEntries(teams.map((t: any) => [String(t.value), t.label]));
        rolesByCode = Object.fromEntries(roles.map((r: any) => [String(r.value), r.label]));
      } catch (err) {
        console.error("Failed to load team/role lookups", err);
      }
    }

    // Default the as-of date to today (local).
    function initDateInput() {
      const input = document.getElementById("asOfDate") as HTMLInputElement | null;
      if (input && !input.value) {
        const now = new Date();
        const yyyy = now.getFullYear();
        const mm = String(now.getMonth() + 1).padStart(2, "0");
        const dd = String(now.getDate()).padStart(2, "0");
        input.value = `${yyyy}-${mm}-${dd}`;
      }
    }

    // Populate the dimension selector from the API.
    async function loadDimensions() {
      const select = document.getElementById("dimensionSelect") as HTMLSelectElement | null;
      if (!select) return;
      try {
        const dimensions = await getDimensions();
        dimensionList = dimensions;
        // Each dimension measures against a SCALE list (its `scale` FK, falling
        // back to its own code) — this drives the value <select> options.
        dimensionScale = Object.fromEntries(
          dimensions.map((d: any) => [d.code, d.scale || d.code]),
        );
        const initial = select.getAttribute("data-initial-dimension") || "";
        select.innerHTML = dimensions
          .map(
            (dim) =>
              `<option value="${escapeHtml(dim.code)}"${
                dim.code === initial ? " selected" : ""
              }>${escapeHtml(dim.name)}</option>`,
          )
          .join("");
      } catch (err) {
        console.error("Failed to load dimensions", err);
        showNotification("Error loading dimensions", "error");
      }
    }

    // Load every SCALE list's items so the edit modal's value <select> can be
    // rebuilt for whichever dimension is on screen (mirrors metrics.astro).
    async function loadScales() {
      try {
        const scaleLists = await getListsbyType("SCALE");
        const entries = await Promise.all(
          scaleLists.map(
            async (l: any) => [l.code, await getListItemsbyList(l.code)] as const,
          ),
        );
        scalesByList = Object.fromEntries(entries);
      } catch (err) {
        console.error("Failed to load scale lists", err);
        scalesByList = {};
      }
    }

    // Value options for a dimension: its SCALE list's items, filtered to the
    // user's language (falls back to another language if the current has none).
    function valueOptionsFor(dimensionCode: string): any[] {
      const scaleCode = dimensionScale[dimensionCode];
      const items = (scaleCode && scalesByList[scaleCode]) || [];
      if (items.length === 0) return [];
      const lang = localStorage.getItem("lang") || "en";
      const langs = new Set(items.map((i: any) => i.lang));
      const target = langs.has(lang)
        ? lang
        : items.find((i: any) => i.lang)?.lang || lang;
      return items.filter((i: any) => !i.lang || i.lang === target);
    }

    // Fetch the assignments grid for the selected dimension + as-of date.
    async function reload() {
      const dimensionSelect = document.getElementById("dimensionSelect") as HTMLSelectElement | null;
      const dateInput = document.getElementById("asOfDate") as HTMLInputElement | null;
      const dimensionCode = dimensionSelect?.value || "";
      const dateValue = dateInput?.value || "";
      if (!dimensionCode || !dateValue) {
        assignments = [];
        renderGrid();
        return;
      }
      // Make the cut-off inclusive of the whole selected day.
      const cutoff = `${dateValue}T23:59:59`;
      try {
        const rows = await getMetricsByDimension(dimensionCode, cutoff);
        // Keep the raw value for editing; `metric` is normalized for the avatar colour.
        assignments = rows.map((row) => ({
          ...row,
          rawValue: row.metric,
          metric: normalizeMetricValue(row.metric),
        }));
      } catch (err) {
        console.error("Failed to load metrics by dimension", err);
        showNotification("Error loading assignments", "error");
        assignments = [];
      }
      renderGrid();
    }

    // ----- Rendering -----
    function renderGrid() {
      const thead = document.getElementById("assignmentThead");
      const tbody = document.getElementById("assignmentTbody");
      if (!thead || !tbody) return;

      if (assignments.length === 0) {
        thead.innerHTML = "";
        tbody.innerHTML = `<tr><td class="px-4 py-10 text-center text-slate-500">${escapeHtml(
          t("assignment_dashboard.empty_message", "No assignments found"),
        )}</td></tr>`;
        return;
      }

      const withTeam = assignments.filter((a) => a.team && a.team.trim() !== "");
      const withoutTeam = assignments.filter((a) => !a.team || a.team.trim() === "");
      const roles = [...new Set(withTeam.map((a) => a.role))];
      const teams = [...new Set(withTeam.map((a) => a.team))].filter(Boolean);

      // Header
      thead.innerHTML = `
        <tr class="border-b border-slate-200">
          <th class="text-slate-900 text-center px-2 py-3 font-semibold sticky top-0 z-10 border border-slate-200">
            <span class="uppercase" data-i18n="assignment_dashboard.team">Team</span> &#11208;<br>
            <span class="uppercase" data-i18n="assignment_dashboard.role">Role</span> &#11206;
          </th>
          ${teams
            .map(
              (team) =>
                `<th class="text-slate-900 px-4 py-3 font-semibold text-center border border-slate-200 sticky top-0 z-10">${escapeHtml(
                  team.toUpperCase(),
                )}</th>`,
            )
            .join("")}
        </tr>`;

      // Body: role × team matrix
      const roleRows = roles
        .map((role) => {
          const cells = teams
            .map((team) => {
              const employees = withTeam.filter((a) => a.role === role && a.team === team);
              const avatars = employees.map((emp) => avatarMarkup(emp)).join("");
              return `<td class="px-4 py-3 border border-slate-200 text-center">${
                employees.length > 0
                  ? `<div class="flex flex-wrap gap-2 justify-center items-center min-h-[80px]">${avatars}</div>`
                  : ""
              }</td>`;
            })
            .join("");
          return `<tr class="border-b border-slate-200 hover:bg-slate-50">
            <td class="bg-gray-50 text-slate-900 text-center text-sm uppercase px-4 py-3 font-semibold border border-slate-200">${escapeHtml(
              role,
            )}</td>${cells}</tr>`;
        })
        .join("");

      // No-team row
      let noTeamRow = "";
      if (withoutTeam.length > 0) {
        const items = withoutTeam
          .map(
            (emp) =>
              `<div class="flex flex-col items-center gap-2">${avatarMarkup(
                emp,
              )}<span class="text-xs font-medium text-slate-600 max-w-[70px] text-center line-clamp-2">${escapeHtml(
                emp.role,
              )}</span></div>`,
          )
          .join("");
        noTeamRow = `<tr class="border-b border-slate-200">
          <td class="px-4 py-3 font-semibold border border-slate-200">--</td>
          <td colspan="${teams.length}" class="px-4 py-3 border border-slate-200">
            <div class="grid grid-cols-4 gap-4 md:grid-cols-6 lg:grid-cols-8 justify-items-center min-h-[120px]">${items}</div>
          </td></tr>`;
      }

      tbody.innerHTML = roleRows + noTeamRow;
    }

    function avatarMarkup(emp: GridRow): string {
      const initials = getInitials(emp.name);
      const metricClass = getMetricColorClass(emp.metric);
      return `<div class="avatar-wrapper relative inline-block group">
        <button class="avatar w-12 h-12 rounded-full flex items-center justify-center font-bold text-sm cursor-pointer transition-transform hover:scale-110 ${metricClass}" data-metric-id="${emp.id}">${escapeHtml(
          initials,
        )}</button>
        <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 bg-gray-900 text-white text-xs px-3 py-2 rounded whitespace-nowrap z-50 pointer-events-none shadow-lg opacity-0 group-hover:opacity-100 transition-opacity duration-200">${escapeHtml(
          emp.name,
        )}</div>
      </div>`;
    }

    // ----- Listeners -----
    function setupStaticListeners() {
      document.getElementById("dimensionSelect")?.addEventListener("change", reload);
      document.getElementById("asOfDate")?.addEventListener("change", reload);

      // Delegated avatar click — bound once and survives grid re-renders (the
      // <tbody> element is reused; only its innerHTML changes).
      document.getElementById("assignmentTbody")?.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".avatar");
        if (!btn) return;
        const row = assignments.find((a) => a.id === Number(btn.dataset.metricId));
        if (row) openEditModal(row);
      });

      // The shared CrudModal dispatches `crud-submit` on save — persist the edit
      // (only value/observation/measured_at are editable; the PK selects are
      // disabled and therefore excluded from the form data) and refresh the grid.
      document.addEventListener("crud-submit", async (e) => {
        const detail = (e as CustomEvent).detail || {};
        if (detail.modalId !== "metric-edit-modal") return;
        const { data } = detail;
        try {
          await updateMetric(parseInt(data.id, 10), {
            value: data.value,
            observation: data.observation || undefined,
            measured_at: data.measured_at || undefined,
            is_active: true,
          });
          showNotification(t("assignment_dashboard.metric_saved", "Metric updated successfully"), "info");
          await reload();
        } catch (err) {
          console.error("Failed to update metric", err);
          showNotification(
            t("assignment_dashboard.metric_save_error", "Error updating metric"),
            "error",
          );
        }
      });
    }

    // ----- Modal -----
    // Prefill and open the shared Edit Metric modal for the clicked avatar.
    // dimension + assignment are read-only context (disabled → not submitted);
    // value/observation/measured_at are editable and persisted on save.
    function openEditModal(row: GridRow) {
      const modal = document.getElementById("metric-edit-modal") as HTMLDialogElement | null;
      if (!modal) return;

      // Set any named form control (input/textarea/select) by value.
      const setValue = (name: string, value: string) => {
        const el = modal.querySelector<
          HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement
        >(`[name="${name}"]`);
        if (el) el.value = value;
      };

      const dimensionCode =
        (document.getElementById("dimensionSelect") as HTMLSelectElement | null)?.value || "";
      const dimName = dimensionList.find((d) => d.code === dimensionCode)?.name || dimensionCode;
      const teamLbl = teamsByCode[row.team] || row.team;
      const roleLbl = rolesByCode[row.role] || row.role;

      // Read-only context (disabled → not submitted): dimension name, and the
      // assignment as "UserName — RoleName — TeamName" (team dropped when null).
      setValue("dimension", dimName);
      setValue("assignment", [row.name, roleLbl, teamLbl].filter(Boolean).join(" — "));

      // Value select — rebuild options from the dimension's SCALE list (falling
      // back to the current raw value when no scale is loaded), then select it.
      const valSelect = modal.querySelector('select[name="value"]') as HTMLSelectElement | null;
      if (valSelect) {
        const options = valueOptionsFor(dimensionCode);
        const fallback = row.rawValue ? [{ value: row.rawValue, label: row.rawValue }] : [];
        valSelect.innerHTML = (options.length ? options : fallback)
          .map(
            (i: any) =>
              `<option value="${escapeHtml(i.value)}">${escapeHtml(i.label || i.value)}</option>`,
          )
          .join("");
        valSelect.value = row.rawValue;
      }

      setValue("observation", row.observation || "");
      // datetime-local expects "YYYY-MM-DDTHH:mm"; the ISO string slices cleanly.
      setValue("measured_at", (row.measured_at || "").slice(0, 16));
      setValue("id", String(row.id));

      modal.showModal();
    }
  </script>
</BaseLayout>
