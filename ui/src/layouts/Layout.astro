---
import "../styles/globals.css";
import ClientTranslations from "../components/ClientTranslations.astro";

interface Props {
  title?: string;
}

const {
  title = "SynapxIA",
} = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    {/* Auth gate runs server-side in src/middleware.ts (cookie-based).
        Pages reach this layout already authenticated (or already redirected
        to /login). No flash-of-empty-content, no localStorage round-trip. */}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <ClientTranslations />
    <slot />
  </body>
</html>
