---
/**
 * Propose an asset (HU-Propose) — the review-workflow entry point. POSTs to
 * `/api/assets/propose`, which atomically creates the asset (PROPOSED), its
 * characterizations (from the category's specs), the PROPOSAL + REVIEW actions,
 * and MANAGE permissions — generating the reviewer's notification.
 *
 * UX: the form card carries a **type-branded hero** (gradient + icon matching
 * that type's gallery card) and is split into two **tabs** — Details and
 * Characterization — so it isn't one very tall column. Reached from a gallery's
 * "Propose" button with `?category=<CODE>`: the type is then **locked** and the
 * hero/heading/characterization brand to it. On a direct visit (no `?category=`)
 * the type is an editable select and the hero + Characterization tab appear once
 * a type is chosen.
 *
 * Category / reviewer / characterization are hydrated client-side (per-user data
 * + the Vercel build-time empty-fetch gotcha), via a bundled `@/` script. All
 * inputs stay DOM-mounted (tabs only show/hide) so the submit handler still
 * collects them via FormData + querySelectorAll("[data-characterization]").
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import Toast from "../../components/Toast.astro";

const inputClass =
  "w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100";
const labelClass = "mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300";
const tabBase =
  "propose-tab whitespace-nowrap border-b-2 px-1 py-3 text-sm font-medium focus:outline-none";
const tabOff =
  "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200";
---

<BaseLayout>
  <div class="mx-auto w-full max-w-3xl">
    <Breadcrumb
      moduleName="AI Library"
      pageName="Propose"
      pageTitle="Propose an asset"
      homeLink="/"
      moduleNameKey="modules.LIB"
      pageNameKey="menu_options.propose"
      pageTitleKey="propose.title"
    />

    <form
      id="propose-form"
      class="overflow-hidden rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900"
    >
      <!-- Type-branded hero (gradient + icon re-themed client-side by category). -->
      <div id="propose-hero" class="flex items-start gap-4 bg-gradient-to-br from-indigo-500 to-indigo-600 px-6 py-5 text-white">
        <span id="propose-hero-icon" class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white/20 text-white">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M12 5v14M5 12h14" stroke-linecap="round" />
          </svg>
        </span>
        <div class="min-w-0">
          <h1 id="propose-hero-title" class="text-lg font-semibold" data-i18n="propose.title">Propose an asset</h1>
          <p class="mt-0.5 text-sm text-white/85" data-i18n="propose.subtitle">
            Submit a new asset for review. A reviewer will be notified to approve, request changes, or reject it.
          </p>
        </div>
      </div>

      <!-- Tabs -->
      <div class="border-b border-gray-200 px-6 dark:border-gray-800">
        <div role="tablist" aria-label="Propose sections" class="-mb-px flex gap-6">
          <button
            type="button" role="tab" data-propose-tab="details" aria-selected="true"
            class={`${tabBase} border-indigo-600 text-indigo-600 dark:text-indigo-400`}
            data-i18n="propose.tab_details"
          >Details</button>
          <button
            type="button" role="tab" data-propose-tab="characterization" aria-selected="false" tabindex="-1"
            id="propose-tab-char"
            class={`${tabBase} ${tabOff} hidden`}
            data-i18n="propose.tab_characterization"
          >Characterization</button>
        </div>
      </div>

      <!-- Panels -->
      <div class="px-6 py-5">
        <!-- Details -->
        <div data-propose-panel="details" class="space-y-5">
          <div>
            <label class={labelClass} for="propose-name" data-i18n="propose.name">Name</label>
            <input id="propose-name" name="name" type="text" maxlength="100" class={inputClass}
              data-i18n-placeholder="propose.name_placeholder" placeholder="Asset name" />
            <p id="propose-name-error" class="mt-1 hidden text-xs text-red-600 dark:text-red-400" data-i18n="propose.name_required">Name is required</p>
          </div>

          <div>
            <label class={labelClass} for="propose-description" data-i18n="propose.description">Description</label>
            <textarea id="propose-description" name="description" rows="2" maxlength="500" class={inputClass}
              data-i18n-placeholder="propose.description_placeholder" placeholder="Short description"></textarea>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label class={labelClass} for="propose-category" data-i18n="propose.category">Category</label>
              <!-- Editable selector — used only on a direct visit (no ?category=). -->
              <select id="propose-category" name="category" class={inputClass}>
                <option value="" data-i18n="propose.category_placeholder">Select a category…</option>
              </select>
              <!-- Locked display — shown when the type comes from the originating
                   gallery (?category=); the type then can't be changed. -->
              <input id="propose-category-locked" type="text" readonly
                class={`${inputClass} hidden cursor-not-allowed bg-gray-100 dark:bg-gray-800`} />
              <p id="propose-category-error" class="mt-1 hidden text-xs text-red-600 dark:text-red-400" data-i18n="propose.category_required">Category is required</p>
            </div>
            <div>
              <label class={labelClass} for="propose-reviewer" data-i18n="propose.reviewer">Reviewer</label>
              <select id="propose-reviewer" name="reviewer_id" class={inputClass}>
                <option value="" data-i18n="propose.reviewer_auto">Auto-assign</option>
              </select>
            </div>
          </div>

          <div>
            <label class={labelClass} for="propose-tags" data-i18n="propose.tags">Tags</label>
            <input id="propose-tags" name="tags" type="text" class={inputClass}
              data-i18n-placeholder="propose.tags_placeholder" placeholder="comma, separated, tags" />
          </div>

          <div>
            <label class={labelClass} for="propose-detail" data-i18n="propose.detail">Detail</label>
            <textarea id="propose-detail" name="detail" rows="4" class={inputClass}
              data-i18n-placeholder="propose.detail_placeholder" placeholder="Additional detail (optional)"></textarea>
          </div>
        </div>

        <!-- Characterization (one field per the category's spec features). -->
        <div data-propose-panel="characterization" class="hidden">
          <p class="mb-4 text-xs text-gray-500 dark:text-gray-400" data-i18n="propose.characterization_hint">
            Describe the asset against this type's features. Defaults are prefilled; adjust as needed.
          </p>
          <div id="propose-characterization-fields" class="grid gap-5 sm:grid-cols-2"></div>
        </div>
      </div>

      <!-- Footer -->
      <div class="flex justify-end gap-3 border-t border-gray-200 px-6 py-4 dark:border-gray-800">
        <button
          id="propose-submit"
          type="submit"
          class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-indigo-700 disabled:opacity-60"
          data-i18n="propose.submit"
        >
          Propose for review
        </button>
      </div>
    </form>
  </div>

  <Toast message="" variant="info" open={false} />

  <script>
    // Bundled module (Astro resolves @/ + TS). We avoid inline type="module" +
    // /src imports (those 404 in the Vercel build — see memory/CHANGELOG.md).
    import { getCategories } from "@/lib/categories";
    import { getReviewers, proposeAsset } from "@/lib/propose";
    import { getSpecificationsbyCategory } from "@/lib/specifications";
    import { loadClientTranslations, translate } from "@/utils/i18nClient";
    import { installGlobalToast, showToast } from "@/lib/toast";

    loadClientTranslations();
    installGlobalToast();

    // Tailwind class strings (client island can't read the frontmatter consts).
    const inputClass =
      "w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100";
    const labelClass = "mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300";
    const SUBMIT_BASE =
      "rounded-lg px-4 py-2 text-sm font-semibold text-white transition disabled:opacity-60";
    const HERO_BASE = "flex items-start gap-4 bg-gradient-to-br px-6 py-5 text-white";
    const TAB_OFF = [
      "border-transparent", "text-gray-500", "hover:border-gray-300",
      "hover:text-gray-700", "dark:text-gray-400", "dark:hover:text-gray-200",
    ];
    // Every accent's active-tab classes, so switching accents can clear them all.
    const ALL_TAB_ON = [
      "border-indigo-600", "text-indigo-600", "dark:text-indigo-400",
      "border-emerald-600", "text-emerald-600", "dark:text-emerald-400",
      "border-violet-600", "text-violet-600", "dark:text-violet-400",
    ];

    // Per-type branding — icons + colors copied from the gallery cards so
    // "Propose a Prompt/MCP/Agent" matches PromptCard / McpCard / AgentCard.
    const ICON_PROMPT =
      `<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M8 10h8M8 14h5M21 12a8 8 0 0 1-8 8H7l-4 3v-5a8 8 0 1 1 18-6z" stroke-linecap="round" stroke-linejoin="round" /></svg>`;
    const ICON_MCP =
      `<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="6" rx="1.5" /><rect x="3" y="14" width="18" height="6" rx="1.5" /><path d="M7 7h.01M7 17h.01" stroke-linecap="round" /></svg>`;
    const ICON_AGENT =
      `<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="6" y="6" width="12" height="12" rx="2" /><path d="M9 1v3M15 1v3M9 20v3M15 20v3M1 9h3M1 15h3M20 9h3M20 15h3" stroke-linecap="round" /></svg>`;
    const ICON_DEFAULT =
      `<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 5v14M5 12h14" stroke-linecap="round" /></svg>`;

    type Theme = { grad: string; icon: string; tabOn: string[]; submit: string };
    const THEME_DEFAULT: Theme = {
      grad: "from-indigo-500 to-indigo-600", icon: ICON_DEFAULT,
      tabOn: ["border-indigo-600", "text-indigo-600", "dark:text-indigo-400"],
      submit: "bg-indigo-600 hover:bg-indigo-700",
    };
    const THEMES: Record<string, Theme> = {
      PROMPTS: {
        grad: "from-indigo-500 to-indigo-600", icon: ICON_PROMPT,
        tabOn: ["border-indigo-600", "text-indigo-600", "dark:text-indigo-400"],
        submit: "bg-indigo-600 hover:bg-indigo-700",
      },
      MCPS: {
        grad: "from-emerald-500 to-emerald-600", icon: ICON_MCP,
        tabOn: ["border-emerald-600", "text-emerald-600", "dark:text-emerald-400"],
        submit: "bg-emerald-600 hover:bg-emerald-700",
      },
      AGENTS: {
        grad: "from-violet-500 to-indigo-500", icon: ICON_AGENT,
        tabOn: ["border-violet-600", "text-violet-600", "dark:text-violet-400"],
        submit: "bg-violet-600 hover:bg-violet-700",
      },
    };

    // Per-type heading keys (fallback to the generic propose.title).
    const TITLE_KEYS: Record<string, string> = {
      PROMPTS: "propose.title_prompts",
      MCPS: "propose.title_mcps",
      AGENTS: "propose.title_agents",
    };
    // Features whose payload is long-form → render a <textarea>.
    const RICH_FEATURES = new Set([
      "PROMPT_TEMPLATE", "EXAMPLE_OUTPUT", "OVERVIEW",
      "CONTENT", "TOOLS", "SERVER_CONFIG", "INSTRUCTIONS",
    ]);

    const tr = (key: string, fallback: string): string => {
      try {
        const v = translate(key);
        if (v && v !== key) return v;
      } catch {
        /* non-fatal */
      }
      return fallback;
    };

    const form = document.getElementById("propose-form") as HTMLFormElement | null;
    const nameInput = document.getElementById("propose-name") as HTMLInputElement | null;
    const catSel = document.getElementById("propose-category") as HTMLSelectElement | null;
    const catLocked = document.getElementById("propose-category-locked") as HTMLInputElement | null;
    const revSel = document.getElementById("propose-reviewer") as HTMLSelectElement | null;
    const submitBtn = document.getElementById("propose-submit") as HTMLButtonElement | null;
    const hero = document.getElementById("propose-hero") as HTMLElement | null;
    const heroIcon = document.getElementById("propose-hero-icon") as HTMLElement | null;
    const heroTitle = document.getElementById("propose-hero-title") as HTMLElement | null;
    const charTab = document.getElementById("propose-tab-char") as HTMLButtonElement | null;
    const charFields = document.getElementById("propose-characterization-fields") as HTMLElement | null;
    const nameErr = document.getElementById("propose-name-error") as HTMLElement | null;
    const catErr = document.getElementById("propose-category-error") as HTMLElement | null;

    // Toggle a field's invalid state: red border + its inline error message.
    function setInvalid(el: HTMLElement | null, err: HTMLElement | null, invalid: boolean) {
      if (el) {
        el.classList.toggle("border-gray-300", !invalid);
        el.classList.toggle("dark:border-gray-700", !invalid);
        el.classList.toggle("border-red-500", invalid);
        el.classList.toggle("dark:border-red-500", invalid);
        el.setAttribute("aria-invalid", String(invalid));
      }
      err?.classList.toggle("hidden", !invalid);
    }

    const tabButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-propose-tab]"),
    );
    const tabPanels = Array.from(
      document.querySelectorAll<HTMLElement>("[data-propose-panel]"),
    );

    // When the type comes from a gallery, it can't be changed: the editable
    // select is replaced by a read-only field and we submit this value directly.
    let lockedCategory: string | null = null;
    let theme: Theme = THEME_DEFAULT;
    // First-time nudge: has the user opened the Characterization tab yet?
    let charVisited = false;

    /* ---- tabs ------------------------------------------------------------- */
    function styleTab(btn: HTMLButtonElement, on: boolean) {
      btn.setAttribute("aria-selected", String(on));
      if (on) btn.removeAttribute("tabindex");
      else btn.setAttribute("tabindex", "-1");
      btn.classList.remove(...ALL_TAB_ON, ...TAB_OFF);
      btn.classList.add(...(on ? theme.tabOn : TAB_OFF));
    }
    function activateTab(name: string) {
      for (const btn of tabButtons) styleTab(btn, btn.dataset.proposeTab === name);
      for (const p of tabPanels) p.classList.toggle("hidden", p.dataset.proposePanel !== name);
    }
    for (const btn of tabButtons) {
      btn.addEventListener("click", () => {
        const name = btn.dataset.proposeTab || "details";
        if (name === "characterization") charVisited = true;
        activateTab(name);
      });
    }

    function setCharTabVisible(visible: boolean) {
      if (!charTab) return;
      charTab.classList.toggle("hidden", !visible);
      if (!visible && charTab.getAttribute("aria-selected") === "true") activateTab("details");
    }

    /* ---- branding --------------------------------------------------------- */
    function applyTheme(category: string) {
      theme = THEMES[(category || "").toUpperCase()] || THEME_DEFAULT;
      if (hero) hero.className = `${HERO_BASE} ${theme.grad}`;
      if (heroIcon) heroIcon.innerHTML = theme.icon;
      if (submitBtn) submitBtn.className = `${SUBMIT_BASE} ${theme.submit}`;
      // Re-apply active-tab styling in the new accent.
      const active = tabButtons.find((b) => b.getAttribute("aria-selected") === "true");
      for (const btn of tabButtons) styleTab(btn, btn === active);
    }

    function applyTitle(category: string) {
      if (!heroTitle) return;
      const key = TITLE_KEYS[(category || "").toUpperCase()] || "propose.title";
      heroTitle.setAttribute("data-i18n", key); // keep correct across language switches
      heroTitle.textContent = tr(key, heroTitle.textContent || "Propose an asset");
    }

    function lockCategory(category: string, label: string) {
      lockedCategory = category;
      if (catSel) {
        catSel.value = category;
        catSel.disabled = true;
        catSel.classList.add("hidden");
      }
      if (catLocked) {
        catLocked.value = label;
        catLocked.classList.remove("hidden");
      }
    }

    // Everything that must react to the chosen type, in one place.
    function syncType(category: string) {
      charVisited = false; // a new type → its characterization hasn't been reviewed yet
      applyTitle(category);
      applyTheme(category);
      void fillCharacterization(category);
    }

    /* ---- characterization ------------------------------------------------- */
    async function fillCharacterization(category: string) {
      if (!charFields || !category) {
        setCharTabVisible(false);
        return;
      }
      try {
        const specs = await getSpecificationsbyCategory(category, 0, 1000);
        charFields.innerHTML = "";
        if (!specs.length) {
          setCharTabVisible(false);
          return;
        }
        for (const s of specs) {
          const code = s.feature;
          const rich = RICH_FEATURES.has(code);
          const cell = document.createElement("div");
          if (rich) cell.className = "sm:col-span-2";

          const label = document.createElement("label");
          label.className = labelClass;
          label.htmlFor = `char-${code}`;
          label.setAttribute("data-i18n", `feature.${code}`);
          label.textContent = tr(`feature.${code}`, code);
          cell.appendChild(label);

          const field = rich
            ? document.createElement("textarea")
            : document.createElement("input");
          if (field instanceof HTMLTextAreaElement) {
            field.rows = code === "EXAMPLE_OUTPUT" || code === "OVERVIEW" ? 3 : 5;
          } else {
            field.type = "text";
          }
          field.id = `char-${code}`;
          field.name = code;
          field.className = inputClass;
          field.setAttribute("data-characterization", "1");
          if (s.default_value != null) field.value = s.default_value;
          cell.appendChild(field);

          charFields.appendChild(cell);
        }
        setCharTabVisible(true);
        loadClientTranslations(); // patch the new [data-i18n] labels
      } catch {
        setCharTabVisible(false);
      }
    }

    /* ---- init ------------------------------------------------------------- */
    async function init() {
      const pre = new URLSearchParams(location.search).get("category");
      let cats: { code: string; name: string }[] = [];
      try {
        cats = await getCategories(0, 1000);
      } catch {
        /* leave the placeholder; submit will validate */
      }
      if (catSel) {
        for (const c of cats) {
          const o = document.createElement("option");
          o.value = c.code;
          o.textContent = c.name;
          catSel.appendChild(o);
        }
      }

      const match = pre
        ? cats.find((c) => c.code.toUpperCase() === pre.toUpperCase())
        : undefined;

      if (match) {
        // Locked flow — type fixed by the originating gallery.
        lockCategory(match.code, match.name);
        syncType(match.code);
      } else if (catSel) {
        // Fallback flow — editable; rebrand + rebuild on every change.
        catSel.addEventListener("change", () => syncType(catSel.value));
      }
    }

    // Localized role suffix for a reviewer option ("— Administrator", etc.).
    const REVIEWER_ROLES = ["ADMINISTRATOR", "ADMINISTRATIVE", "REVIEWER"];
    function reviewerRole(profile: string, isSuper: boolean): string {
      if (REVIEWER_ROLES.includes(profile)) return tr(`reviewer_role.${profile}`, profile);
      if (isSuper) return tr("reviewer_role.SUPERUSER", "Superuser");
      return tr(`reviewer_role.${profile}`, profile);
    }

    async function fillReviewers() {
      if (!revSel) return;
      try {
        const revs = await getReviewers();
        for (const r of revs) {
          const o = document.createElement("option");
          o.value = String(r.value);
          o.textContent = `${r.label} — ${reviewerRole(r.profile, r.is_superuser)}`;
          revSel.appendChild(o);
        }
      } catch {
        /* auto-assign stays the only option */
      }
    }

    // Clear a field's invalid state as soon as the user fixes it.
    nameInput?.addEventListener("input", () => setInvalid(nameInput, nameErr, false));
    catSel?.addEventListener("change", () => setInvalid(catSel, catErr, false));

    void init();
    void fillReviewers();

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const name = String(fd.get("name") || "").trim();
      const category = lockedCategory || String(fd.get("category") || "");
      const catControl = lockedCategory ? catLocked : catSel;
      const nameBad = !name;
      const catBad = !category;
      // Mark the offending inputs inline (red border + message).
      setInvalid(nameInput, nameErr, nameBad);
      setInvalid(catControl, catErr, catBad);
      if (nameBad || catBad) {
        // Required fields live on the Details tab — surface them there.
        activateTab("details");
        (nameBad ? nameInput : catControl)?.focus();
        showToast(tr("propose.required", "Name and category are required"), "error");
        return;
      }

      // First-time nudge: characterization is optional (defaults apply), but if
      // this type has a Characterization tab and the user hasn't opened it yet,
      // send them there once before actually proposing.
      const hasCharTab = charTab != null && !charTab.classList.contains("hidden");
      if (hasCharTab && !charVisited) {
        charVisited = true;
        activateTab("characterization");
        showToast(
          tr("propose.review_characterization", "Please review the Characterization tab before proposing."),
          "info",
        );
        return;
      }

      // Collect the per-feature characterization values (non-empty only).
      const values: Record<string, string> = {};
      charFields
        ?.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>("[data-characterization]")
        .forEach((el) => {
          const v = (el.value || "").trim();
          if (v) values[el.name] = v;
        });

      const tagsRaw = String(fd.get("tags") || "").trim();
      const reviewerRaw = String(fd.get("reviewer_id") || "");
      const payload = {
        name,
        category,
        description: String(fd.get("description") || "").trim() || undefined,
        detail: String(fd.get("detail") || "").trim() || undefined,
        tags: tagsRaw ? tagsRaw.split(",").map((t) => t.trim()).filter(Boolean) : undefined,
        reviewer_id: reviewerRaw ? Number(reviewerRaw) : undefined,
        values: Object.keys(values).length ? values : undefined,
      };

      if (submitBtn) submitBtn.disabled = true;
      try {
        await proposeAsset(payload);
        showToast(tr("propose.success", "Asset proposed for review"), "success");
        form.reset();
        activateTab("details");
        charVisited = false; // fresh proposal → nudge again next time
        // Re-prefill the characterization defaults after the native reset.
        const current = lockedCategory || "";
        if (current) void fillCharacterization(current);
        else setCharTabVisible(false);
      } catch (err) {
        showToast(
          err instanceof Error ? err.message : tr("propose.error", "Could not propose the asset"),
          "error",
        );
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  </script>
</BaseLayout>
