# Vercel environment variables — copy relevant vars into each Vercel project.
# This file is the source of truth for what to set in the Vercel dashboard.
# Do NOT commit real values; use the Vercel dashboard or `vercel env` CLI.

# ============================================================
# UI project  (Root Directory: ui/)
# ============================================================

# URL of the deployed API project (no trailing slash)
PUBLIC_API_BASE_URL=https://<api-project>.vercel.app

# URL of this UI project (used by Astro for canonical links / sitemaps)
SITE_URL=https://<ui-project>.vercel.app


# ============================================================
# API project  (Root Directory: api/)
# ============================================================

# --- Neon / Vercel Postgres (auto-injected when integration is linked) ---
# DO NOT set these manually if you linked the Neon database in the Vercel dashboard;
# Vercel injects them automatically for every environment (production/preview/dev).
#
# POSTGRES_URL=postgresql://<user>:<pass>@<neon-host>/<db>?sslmode=require
# POSTGRES_URL_NON_POOLING=postgresql://<user>:<pass>@<neon-host>/<db>?sslmode=require
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_HOST=
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=

# --- Manual vars (always required) ---

# Random secret for JWT signing — generate with: openssl rand -hex 32
SECRET_KEY=<random-32-char-string>

# Comma-separated allowed CORS origins (UI URL without trailing slash)
CORS_ORIGINS=https://<ui-project>.vercel.app

# Application environment
APP_ENV=production
