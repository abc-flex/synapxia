---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getFeatures } from "@/lib/features";
import { getListItemsbyList } from "@/lib/list_items";

// Fetch features from API
let features: any[] = [];
let errorMessage: string | null = null;
try {
  const apiFeatures = await getFeatures();
  features = apiFeatures;
} catch (error) {
  console.error('Failed to fetch features:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch features from API';
  // Fallback to empty array to still render the page
  features = [];
}

// Fetch items_list from API for select field
let types: any[] = [];
types = await getListItemsbyList('CHARS_TYPE');

const columns = [
  { key: "code", label: "feature_modal.code" },
  { key: "name", label: "feature_modal.name" },
  { key: "type", label: "feature_modal.type" },
];

const data = features.map((item) => ({
  id: item.code,
  code: item.code,
  name: item.name,
  description: item.description,
  type: item.type,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));
const tableFields = [
  { key: "code", label: "feature_modal.code", pk: true, required: true },
  { key: "name", label: "feature_modal.name", required: true },
  { key: "type", label: "feature_modal.type", type: "select" as const, options: types, required: false },
  {
    key: "description",
    label: "feature_modal.description",
    type: "textarea" as const,
    required: false,
  },
];
const fieldKeys = tableFields.map((f) => f.key);
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <!-- Breadcrumb Start -->
    <Breadcrumb
      moduleName="Digital Assets"
      pageName="Features"
      pageTitle="Features"
      homeLink="/"
      moduleNameKey="modules.CATALOG"
      pageNameKey="menu_options.features"
      pageTitleKey="menu_options.features"
    />
    <!-- Breadcrumb End -->

    <CrudModal
      mode="create"
      modalId="feature-create-modal"
      entityName="Feature"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="feature-edit-modal"
      entityName="Feature"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="feature-delete-modal"
      entityName="Feature"
      fields={tableFields}
      showTrigger={false}
    />

    <div
      id="features-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage } from "/scripts/crudClient.js";
      import {
        createFeature,
        updateFeature,
        deleteFeature,
      } from "/src/lib/features";

      initCrudPage({
        dataId: "features-data",
        editModalId: "feature-edit-modal",
        deleteModalId: "feature-delete-modal",
      });

      // Helper function to show toast notifications
      function showToast(message, variant = "info") {
        const toast = document.createElement("div");
        toast.className = `fixed top-4 right-4 z-50 max-w-md p-4 rounded-lg border shadow-lg transition-all duration-300 ${
          variant === "error"
            ? "bg-red-50 text-red-800 border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800"
            : "bg-green-50 text-green-800 border-green-200 dark:bg-green-900/20 dark:text-green-400 dark:border-green-800"
        }`;
        toast.innerHTML = `
          <div class="flex items-start gap-3">
            <div class="flex-1 text-sm font-medium">${message}</div>
            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="this.parentElement.parentElement.remove()">✕</button>
          </div>
        `;
        document.body.appendChild(toast);

        // Auto-remove after 5 seconds
        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateX(100%)";
          setTimeout(() => toast.remove(), 300);
        }, 5000);
      }

      // Handle CRUD form submissions
      document.addEventListener("crud-submit", async (e) => {
        const { modalId, mode, data } = e.detail;

        try {
          if (mode === "create") {
            // Create new feature
            await createFeature({
              code: data.code,
              name: data.name,
              description: data.description,
              type: data.type,
              parent: data.parent,
              is_active: data.is_active !== false,
            });

            showToast("Feature created successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "edit") {
            // Update existing feature
            await updateFeature(data.id, {
              name: data.name,
              description: data.description,
              type: data.type,
              parent: data.parent,
              is_active: data.is_active !== false,
            });

            showToast("Feature updated successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "delete") {
            // Delete feature
            await deleteFeature(data.id);

            showToast("Feature deleted successfully!");
            setTimeout(() => window.location.reload(), 1000);
          }
        } catch (error) {
          console.error("CRUD operation failed:", error);
          showToast(error.message || "An error occurred", "error");
        }
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="space-y-5 sm:space-y-6">
        <!-- ====== Table Start -->
        <DataTable
          columns={columns}
          data={data}
          tableId="features"
          i18Item="feature"
        />
        <!-- ====== Table End -->
      </div>
    </div>
  </div>
</BaseLayout>
