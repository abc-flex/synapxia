---
import { t } from "@/i18n";
import { getLocale } from "@/utils/getLocale";

const locale = getLocale(Astro);

interface Role {
  code?: string;
  name?: string;
  description?: string;
}

interface Props {
  modalId?: string;
  mode?: "create" | "edit" | "delete";
  role?: Role;
  showTrigger?: boolean;
}

const {
  modalId = "role-modal",
  mode = "create",
  role = {},
  showTrigger = true,
} = Astro.props as Props;

const titleMap = {
  create: t(locale, "role_modal.add_new_role"),
  edit: t(locale, "role_modal.edit_role"),
  delete: t(locale, "role_modal.delete_role"),
} as const;

const actionMap = {
  create: t(locale, "role_modal.save_role"),
  edit: t(locale, "role_modal.save_changes"),
  delete: t(locale, "role_modal.delete_role"),
} as const;

const triggerLabelMap = {
  create: t(locale, "role_modal.add_role"),
  edit: t(locale, "crud_modal.edit"),
  delete: t(locale, "crud_modal.delete"),
} as const;

const isDelete = mode === "delete";
const isEdit = mode === "edit";
const isCreate = mode === "create";
---

{
  showTrigger ? (
    <div class="flex justify-end mb-4">
      <button
        type="button"
        class={`inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold text-white shadow-sm transition focus:outline-none focus:ring-2 ${isDelete ? "bg-red-600 hover:bg-red-700 focus:ring-red-200 dark:bg-red-500 dark:hover:bg-red-400 dark:focus:ring-red-800" : "bg-indigo-600 hover:bg-indigo-700 focus:ring-indigo-200 dark:bg-indigo-500 dark:hover:bg-indigo-400 dark:focus:ring-indigo-800"}`}
        data-modal-open={modalId}
      >
        <span class="text-lg leading-none">
          {isDelete ? "✕" : isEdit ? "✎" : "+"}
        </span>
        <span>{triggerLabelMap[mode]}</span>
      </button>
    </div>
  ) : null
}

<dialog
  id={modalId}
  class="modal rounded-2xl border border-gray-200 bg-white p-0 shadow-2xl backdrop:bg-black/40 dark:border-gray-800 dark:bg-gray-900"
>
  <form method="dialog" class="w-[460px] max-w-full">
    <div
      class="flex items-center justify-between border-b border-gray-100 px-5 py-4 dark:border-gray-800"
    >
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
        {titleMap[mode]}
      </h2>
      <button
        type="button"
        class="p-1 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300"
        data-modal-close={modalId}
        aria-label="Close"
      >
        ✕
      </button>
    </div>

    <div class="space-y-4 px-5 py-4">
      {
        isDelete ? (
          <p class="text-sm text-gray-700 dark:text-gray-300">
            {t(locale, "role_modal.delete_confirmation")}{" "}
            <span class="font-semibold">
              {role.name || role.code || "this role"}
            </span>
            ? {t(locale, "role_modal.delete_warning")}
          </p>
        ) : null
      }

      <div class="space-y-1">
        <label
          for={`${modalId}-code`}
          class="text-sm font-medium text-gray-700 dark:text-gray-300"
          >{t(locale, "role_modal.code")}</label
        >
        <input
          id={`${modalId}-code`}
          name="code"
          type="text"
          required={!isDelete}
          disabled={isDelete}
          value={role.code}
          class={`h-11 w-full rounded-lg border border-gray-200 bg-white px-3 text-sm text-gray-900 shadow-inner focus:border-indigo-300 focus:ring-2 focus:ring-indigo-100 focus:outline-none dark:border-gray-800 dark:bg-gray-950 dark:text-white/90 dark:placeholder:text-white/30 ${isDelete ? "opacity-60" : ""}`}
          placeholder="e.g. ROLE_ADMIN"
        />
      </div>

      <div class="space-y-1">
        <label
          for={`${modalId}-name`}
          class="text-sm font-medium text-gray-700 dark:text-gray-300"
          >{t(locale, "role_modal.name")}</label
        >
        <input
          id={`${modalId}-name`}
          name="name"
          type="text"
          required={!isDelete}
          disabled={isDelete}
          value={role.name}
          class={`h-11 w-full rounded-lg border border-gray-200 bg-white px-3 text-sm text-gray-900 shadow-inner focus:border-indigo-300 focus:ring-2 focus:ring-indigo-100 focus:outline-none dark:border-gray-800 dark:bg-gray-950 dark:text-white/90 dark:placeholder:text-white/30 ${isDelete ? "opacity-60" : ""}`}
          placeholder="e.g. Administrator"
        />
      </div>

      <div class="space-y-1">
        <label
          for={`${modalId}-description`}
          class="text-sm font-medium text-gray-700 dark:text-gray-300"
          >{t(locale, "role_modal.description")}</label
        >
        <textarea
          id={`${modalId}-description`}
          name="description"
          rows={3}
          disabled={isDelete}
          class={`w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm text-gray-900 shadow-inner focus:border-indigo-300 focus:ring-2 focus:ring-indigo-100 focus:outline-none dark:border-gray-800 dark:bg-gray-950 dark:text-white/90 dark:placeholder:text-white/30 ${isDelete ? "opacity-60" : ""}`}
          placeholder={isDelete ? "" : "Optional details"}
          >{role.description}</textarea
        >
      </div>
    </div>

    <div
      class="flex items-center justify-end gap-3 border-t border-gray-100 px-5 py-3 dark:border-gray-800"
    >
      <button
        type="button"
        class="rounded-lg px-4 py-2 text-sm font-semibold text-gray-600 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-white/5"
        data-modal-close={modalId}
      >
        {t(locale, "crud_modal.cancel")}
      </button>
      <button
        type="submit"
        class={`rounded-lg px-4 py-2 text-sm font-semibold text-white shadow-sm transition focus:outline-none focus:ring-2 ${isDelete ? "bg-red-600 hover:bg-red-700 focus:ring-red-200 dark:bg-red-500 dark:hover:bg-red-400 dark:focus:ring-red-800" : "bg-indigo-600 hover:bg-indigo-700 focus:ring-indigo-200 dark:bg-indigo-500 dark:hover:bg-indigo-400 dark:focus:ring-indigo-800"}`}
      >
        {actionMap[mode]}
      </button>
    </div>
  </form>
</dialog>

<script define:vars={{ modalId }}>
  (() => {
    if (typeof window === "undefined") return;
    const modal = document.getElementById(modalId);

    if (!modal) return;

    const openBtn = document.querySelector(`[data-modal-open="${modalId}"]`);
    const closeButtons = Array.from(
      document.querySelectorAll(`[data-modal-close="${modalId}"]`)
    );

    const open = () => {
      if (modal.hasAttribute("open")) return;
      modal.showModal();
    };

    const close = () => {
      if (!modal.hasAttribute("open")) return;
      modal.close();
    };

    openBtn?.addEventListener("click", open);
    closeButtons.forEach((btn) => btn.addEventListener("click", close));
    modal.addEventListener("click", (event) => {
      const rect = modal.getBoundingClientRect();
      const isInDialog =
        rect.top <= event.clientY &&
        event.clientY <= rect.top + rect.height &&
        rect.left <= event.clientX &&
        event.clientX <= rect.left + rect.width;
      if (!isInDialog) close();
    });
    modal.addEventListener("cancel", (e) => {
      e.preventDefault();
      close();
    });
  })();
</script>
