---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getItemTranslations } from "@/lib/item_translations";
import { getListsSelect } from "@/lib/lists";

// Fetch item_translations from API
let item_translations: any[] = [];
let errorMessage: string | null = null;

try {
  const apiLists = await getItemTranslations();
  item_translations = apiLists;
} catch (error) {
  console.error('Failed to fetch item_translations:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch item_translations from API';
  // Fallback to empty array to still render the page
  item_translations = [];
}

// Fetch lists for filter dropdown and form select
let lists: any[] = [];
try {
  const apiLists = await getListsSelect();
  lists = apiLists;
} catch (error) {
  console.error('Failed to fetch lists:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch lists from API';
  // Fallback to empty array to still render the page
  lists = [];
}

const columns = [
  { key: "sort_order", label: "#" },
  { key: "value", label: "list_item_modal.value", as: "title", subtitleKey: "label", subtitleFormat: "text" },
  { key: "label", label: "list_item_modal.label", visible: false },
  { key: "list", label: "list_item_modal.list", visible: false },
  { key: "list_name", label: "list_item_modal.list" },
];
const data = item_translations.map((item) => ({
  id: `${item.list}::${item.value}`,
  value: item.value,
  label: item.label,
  sort_order: item.sort_order,
  list: item.list,
  list_name: lists.find((l) => l.value === item.list)?.label || item.list,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));
const formFields = [
  { key: "list", label: "list_item_modal.list", type: "select" as const, options: lists, pk: true, required: true },
  { key: "value", label: "list_item_modal.value", pk: true, required: true },
  { key: "label", label: "list_item_modal.label", required: true },
  { key: "sort_order", label: "option_modal.sort_order", type: "number" as const, required: true },
];
const fieldKeys = formFields.map((f) => f.key);
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto w-full max-w-full md:p-0">
    <Breadcrumb
      moduleName="Administration"
      pageName="ItemsList"
      pageTitle="Items Lists"
      homeLink="/"
      moduleNameKey="modules.ADMIN"
      pageNameKey="menu_options.item_translations"
    />

    <CrudModal
      mode="create"
      modalId="list_item-create-modal"
      entityName="ListItem"
      fields={formFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="list_item-edit-modal"
      entityName="ListItem"
      fields={formFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="list_item-delete-modal"
      entityName="ListItem"
      fields={formFields}
      showTrigger={false}
    />

    <div
      id="item_translations-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage } from "/scripts/crudClient.js";
      import {
        createItemTranslation,
        updateItemTranslation,
        deleteItemTranslation,
      } from "/src/lib/item_translations";

      initCrudPage({
        dataId: "item_translations-data",
        editModalId: "list_item-edit-modal",
        deleteModalId: "list_item-delete-modal",
      });
      // Helper function to show toast notifications
      function showToast(message, variant = "info") {
        const toast = document.createElement("div");
        toast.className = `fixed top-4 right-4 z-50 max-w-md p-4 rounded-lg border shadow-lg transition-all duration-300 ${
          variant === "error"
            ? "bg-red-50 text-red-800 border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800"
            : "bg-green-50 text-green-800 border-green-200 dark:bg-green-900/20 dark:text-green-400 dark:border-green-800"
        }`;
        toast.innerHTML = `
          <div class="flex items-start gap-3">
            <div class="flex-1 text-sm font-medium">${message}</div>
            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="this.parentElement.parentElement.remove()">✕</button>
          </div>
        `;
        document.body.appendChild(toast);

        // Auto-remove after 5 seconds
        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateX(100%)";
          setTimeout(() => toast.remove(), 300);
        }, 5000);
      }

      // Handle CRUD form submissions
      document.addEventListener("crud-submit", async (e) => {
        const { modalId, mode, data } = e.detail;

        try {
          // Parse composite ID: "list:::value"
          const [list, value] = data.id.split("::");
          if (mode === "create") {
            // Create new item translation
            await createItemTranslation({
              list: data.list,
              value: data.value,
              label: data.label,
              sort_order: data.sort_order,
              is_active: data.is_active !== false,
            });
            showToast("Item Translation created successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "edit") {
            // Update existing item translation
            await updateItemTranslation(list, value, {
              label: data.label,
              sort_order: data.sort_order,
              is_active: data.is_active !== false,
            });
            showToast("Item Translation updated successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "delete") {
            // Delete item translation
            await deleteItemTranslation(list, value);
            showToast("Item Translation deleted successfully!");
            setTimeout(() => window.location.reload(), 1000);
          }
        } catch (error) {
          console.error("CRUD operation failed:", error);
          showToast(error.message || "An error occurred", "error");
        }
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="border-0 p-0">
        <DataTable
          columns={columns}
          data={data}
          tableId="items_list"
          i18Item="list_item"
          columnFilter="list"
          filterOptions={lists}
          masterPage="/admin/lists"
          mdItem="list"
        />
      </div>
    </div>
  </div>
</BaseLayout>
