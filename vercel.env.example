# =============================================================================
# SynapxIA — Vercel environment variables
# =============================================================================
# This is the source-of-truth list of env vars to set in the Vercel dashboard
# for each of the three projects. Copy values into:
#   Vercel → <project> → Settings → Environment Variables
#
# Do NOT commit real secrets. This file documents NAMES only.
# =============================================================================


# -----------------------------------------------------------------------------
# 1) DATABASE — Neon (Vercel Postgres)
# -----------------------------------------------------------------------------
# Create via: Vercel → Storage → Create Database → Postgres (Neon).
# Connect it to BOTH the API and UI projects. Vercel then auto-injects the
# following into the connected projects (DO NOT set these manually):
#
#   POSTGRES_URL                 # pooled connection string (use at runtime)
#   POSTGRES_URL_NON_POOLING     # direct connection (use for migrations)
#   POSTGRES_USER
#   POSTGRES_PASSWORD
#   POSTGRES_HOST
#   POSTGRES_PORT
#   POSTGRES_DATABASE
#
# One-time migration after the DB is created:
#   export DATABASE_URL="<POSTGRES_URL_NON_POOLING from Vercel dashboard>"
#   bash db/neon-migrate.sh


# -----------------------------------------------------------------------------
# 2) API project  (Root Directory: api/  | Framework: Other)
# -----------------------------------------------------------------------------
# POSTGRES_URL is auto-injected by the Neon integration — do not set it here.
SECRET_KEY=change-me-to-a-random-32-char-string
CORS_ORIGINS=https://synapxia-ui.vercel.app
APP_ENV=production


# -----------------------------------------------------------------------------
# 3) UI project  (Root Directory: ui/  | Framework: Astro)
# -----------------------------------------------------------------------------
PUBLIC_API_BASE_URL=https://synapxia-api.vercel.app
SITE_URL=https://synapxia-ui.vercel.app
