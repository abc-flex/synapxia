---
import FormCard from "./FormCard.astro";
---
<FormCard title="Radio Buttons" titleKey="forms_demo.radios">
  <div class="flex flex-wrap items-center gap-8">
    <label class="flex cursor-pointer items-center text-sm font-medium text-gray-700 select-none dark:text-gray-300">
      <input type="radio" name="radio-example" class="peer sr-only" />
      <span
        class="mr-3 flex h-5 w-5 items-center justify-center rounded-full border border-gray-300 bg-white transition peer-checked:border-indigo-600 peer-checked:bg-indigo-50 dark:border-gray-700 dark:bg-gray-900"
      >
        <span class="h-2 w-2 rounded-full bg-white peer-checked:bg-indigo-600"></span>
      </span>
      Default
    </label>

    <label class="flex cursor-pointer items-center text-sm font-medium text-gray-700 select-none dark:text-gray-300">
      <input type="radio" name="radio-example" class="peer sr-only" defaultChecked />
      <span
        class="mr-3 flex h-5 w-5 items-center justify-center rounded-full border border-indigo-600 bg-indigo-50 text-indigo-600 transition peer-checked:bg-indigo-50 dark:border-indigo-500 dark:bg-indigo-500/20"
      >
        <span class="h-2 w-2 rounded-full bg-indigo-600"></span>
      </span>
      Secondary
    </label>

    <label class="flex cursor-not-allowed items-center text-sm font-medium text-gray-400 select-none dark:text-gray-700">
      <input type="radio" class="sr-only" name="radio-example" disabled />
      <span class="mr-3 flex h-5 w-5 items-center justify-center rounded-full border border-gray-200 bg-gray-50 dark:border-gray-800 dark:bg-gray-900">
        <span class="h-2 w-2 rounded-full bg-gray-200 dark:bg-gray-800"></span>
      </span>
      Disabled Secondary
    </label>
  </div>
</FormCard>
