---
// Orchestrator shell — composes the toolbar, table (head + body), pagination,
// and empty state, then bootstraps the client logic (advancedTable.ts). The
// emitted DOM (ids, classes, structure) is the contract advancedTable.ts and
// the card-view CSS depend on — keep it stable. Pure helpers live in
// `@/lib/datatable`, types in `@/types/datatable`, sub-parts in `./parts/`.
import { getLocale } from "@/utils/getLocale";
import DataTableToolbar from "./partials/DataTableToolbar.astro";
import DataTableHead from "./partials/DataTableHead.astro";
import DataTableBody from "./partials/DataTableBody.astro";
import DataTablePagination from "./partials/DataTablePagination.astro";
import DataTableEmpty from "./partials/DataTableEmpty.astro";
import type { ColumnConfig, FilterOption } from "@/types/datatable";

const locale = getLocale(Astro);

const {
  columns = [],
  data = [],
  tableId = "datatable",
  i18Item = "i18item",
  showAddButton = true,
  columnFilter = null,
  filterOptions = [],
  // Default selected value for the first filter (applied on page load).
  filterDefaultValue = "",
  // Optional second filter — backward-compat: when null, behaves like before.
  columnFilter2 = null,
  filterOptions2 = [],
  // Default selected value for the second filter (applied on page load).
  filterDefaultValue2 = "",
  // Optional third filter (e.g. a favorites/permissions toggle). Each option
  // may carry an `i18n` key so the label localizes at runtime.
  columnFilter3 = null,
  filterOptions3 = [],
  filterDefaultValue3 = "",
  // i18n key for the third filter's "all" (empty) option.
  filter3AllLabel = null,
  // Optional fourth filter. Matches by membership (the row value may be a
  // comma-separated multi-value field, e.g. asset access "VIEW,MANAGE,PUBLIC").
  columnFilter4 = null,
  filterOptions4 = [],
  filterDefaultValue4 = "",
  filter4AllLabel = null,
  masterPage = null,
  detailPage = null,
  mdItem = null,
  // Per-row favorite star toggle (emits data-action="favorite").
  favoriteAction = false,
  // Key on each row holding "yes"/"no" for the initial star state.
  favoriteKey = "favorite",
  // Per-row master-detail expand button (emits data-action="detail").
  detailExpand = false,
} = Astro.props as {
  columns?: ColumnConfig[];
  data?: Record<string, any>[];
  tableId?: string;
  i18Item?: string;
  showAddButton?: boolean;
  columnFilter?: string | null;
  filterOptions?: FilterOption[];
  filterDefaultValue?: string;
  columnFilter2?: string | null;
  filterOptions2?: FilterOption[];
  filterDefaultValue2?: string;
  columnFilter3?: string | null;
  filterOptions3?: FilterOption[];
  filterDefaultValue3?: string;
  filter3AllLabel?: string | null;
  columnFilter4?: string | null;
  filterOptions4?: FilterOption[];
  filterDefaultValue4?: string;
  filter4AllLabel?: string | null;
  masterPage?: string | null;
  detailPage?: string | null;
  mdItem?: string | null;
  favoriteAction?: boolean;
  favoriteKey?: string;
  detailExpand?: boolean;
};

// Filtrar columnas visibles (ocultar si visible: false)
const visibleColumns = columns.filter((col) => col.visible !== false);
const hasData = data.length > 0;
---

<div class="space-y-2">
  <!-- 🔹 TOP BAR -->
  <DataTableToolbar
    tableId={tableId}
    i18Item={i18Item}
    mdItem={mdItem}
    showAddButton={showAddButton}
    hasData={hasData}
    masterPage={masterPage}
    columnFilter={columnFilter}
    filterOptions={filterOptions}
    filterDefaultValue={filterDefaultValue}
    columnFilter2={columnFilter2}
    filterOptions2={filterOptions2}
    filterDefaultValue2={filterDefaultValue2}
    columnFilter3={columnFilter3}
    filterOptions3={filterOptions3}
    filterDefaultValue3={filterDefaultValue3}
    filter3AllLabel={filter3AllLabel}
    columnFilter4={columnFilter4}
    filterOptions4={filterOptions4}
    filterDefaultValue4={filterDefaultValue4}
    filter4AllLabel={filter4AllLabel}
  />

  {hasData && (
  <!-- 🔹 TABLE -->
  <div class="overflow-x-auto">
    <table
      id={tableId}
      class="w-full text-sm text-left text-gray-700 dark:text-gray-300 datatable-dense"
    >
      <DataTableHead visibleColumns={visibleColumns} />
      <DataTableBody
        data={data}
        visibleColumns={visibleColumns}
        locale={locale}
        i18Item={i18Item}
        mdItem={mdItem}
        detailPage={detailPage}
        detailExpand={detailExpand}
        favoriteAction={favoriteAction}
        favoriteKey={favoriteKey}
      />
    </table>
  </div>
  )}

  {hasData && (
  <!-- 🔹 PAGINATION -->
  <DataTablePagination tableId={tableId} />
  )}

  {!hasData && (
  <DataTableEmpty i18Item={i18Item} />
  )}

</div>

<script>
  // Mobile "Filtros" toggle — reveals/hides the column-filter panel (<sm only;
  // the panel is always visible at sm+ via the sm:flex utility). Delegated so
  // it works for every DataTable instance on the page.
  document.addEventListener("click", (event) => {
    const btn = (event.target as HTMLElement).closest("[data-filters-toggle]");
    if (!btn) return;
    const id = btn.getAttribute("data-filters-toggle");
    const panel = id ? document.getElementById(id) : null;
    panel?.classList.toggle("hidden");
  });
</script>

<!-- Per-table config carrier. A `define:vars` <script> would be emitted inline and
     could not bundle its `initAdvancedTable` import — the literal `/src/...` URL 404s
     in the production (Vercel) build. Instead we serialize the config into an inert
     JSON tag and let a single bundled module script (below) read every table's config.
     `<` is escaped so a `</script>` inside any string (e.g. an asset name) can't break out. -->
<script
  type="application/json"
  data-dt-config
  set:html={JSON.stringify({
    tableId,
    data,
    columns,
    visibleColumns,
    columnFilter,
    columnFilter2,
    filterDefaultValue,
    filterDefaultValue2,
    columnFilter3,
    filterDefaultValue3,
    columnFilter4,
    filterDefaultValue4,
  }).replace(/</g, "\\u003c")}
/>

<script>
  // Processed (bundled) by Astro → the import resolves to a hashed asset that exists in
  // the production build, and Astro dedupes this to once per page. It initializes every
  // DataTable on the page from its JSON config tag (works for multiple tables too).
  import { initAdvancedTable } from "@/components/table/advancedTable";
  document
    .querySelectorAll('script[type="application/json"][data-dt-config]')
    .forEach((el) => {
      const c = JSON.parse(el.textContent || "{}");
      initAdvancedTable(
        c.tableId,
        c.data,
        c.columns,
        c.visibleColumns,
        c.columnFilter,
        c.columnFilter2,
        c.filterDefaultValue,
        c.filterDefaultValue2,
        c.columnFilter3,
        c.filterDefaultValue3,
        c.columnFilter4,
        c.filterDefaultValue4,
      );
    });
</script>
