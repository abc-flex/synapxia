#!/usr/bin/env bash
# post-merge hook: updates memory/changelog.md after a merge into a principal branch.
# Tracked in .githooks/ — activate once per clone with:
#   git config core.hooksPath .githooks
#
# Also fires when GitHub/Vercel webhooks trigger a local pull (rare), but the
# principal-branch guard inside the script prevents spurious entries.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
BRANCH="$(git rev-parse --abbrev-ref HEAD)"

# Only run on principal branches
case "$BRANCH" in
  develop|main|production) ;;
  *) exit 0 ;;
esac

HOOK_SCRIPT="$REPO_ROOT/.claude/hooks/update-changelog.sh"
[[ -x "$HOOK_SCRIPT" ]] || exit 0

# ORIG_HEAD is set by git to the pre-merge tip — use it as the from-ref
FROM_REF="${ORIG_HEAD:-}"
bash "$HOOK_SCRIPT" "$BRANCH" "$FROM_REF" HEAD
