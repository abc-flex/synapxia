---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getMetrics } from "@/lib/metrics";
import { getDimensions } from "@/lib/dimensions";
import { getAssignments } from "@/lib/assignments";
import { getTeamsSelect } from "@/lib/teams";
import { getUsersSelect } from "@/lib/users";
import { getRolesSelect } from "@/lib/roles";
import { getListItemsbyList } from "@/lib/list_items";
import { getListsbyType } from "@/lib/lists";

// Read dimension query param for master-detail pre-filter
const dimensionFilter = Astro.url.searchParams.get("dimension") || "";

// Fetch metrics from API
let metrics: any[] = [];
let errorMessage: string | null = null;

try {
  const apiMetrics = await getMetrics();
  metrics = apiMetrics;
} catch (error) {
  console.error('Failed to fetch metrics:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch metrics from API';
  metrics = [];
}

// Fetch dimensions for filter dropdown and create form select
let dimensions: any[] = [];
try {
  const apiDimensions = await getDimensions();
  dimensions = apiDimensions;
} catch (error) {
  console.error('Failed to fetch dimensions:', error);
  dimensions = [];
}

// Fetch assignments for create form select
let assignments: any[] = [];
try {
  const apiAssignments = await getAssignments();
  assignments = apiAssignments;
} catch (error) {
  console.error('Failed to fetch assignments:', error);
  assignments = [];
}

// Fetch teams + users to resolve readable names for each assignment
let teams: any[] = [];
try {
  teams = await getTeamsSelect();
} catch (error) {
  console.error('Failed to fetch teams:', error);
  teams = [];
}

let users: any[] = [];
try {
  users = await getUsersSelect();
} catch (error) {
  console.error('Failed to fetch users:', error);
  users = [];
}

let roles: any[] = [];
try {
  roles = await getRolesSelect();
} catch (error) {
  console.error('Failed to fetch roles:', error);
  roles = [];
}

// Load the items of every SCALE-type list so the value select can be refreshed
// client-side depending on the selected dimension. `scalesByList` maps each
// SCALE list code -> its items; `dimensionScale` maps each dimension code -> the
// SCALE list it measures against (its `scale` FK, falling back to the code).
let scalesByList: Record<string, any[]> = {};
try {
  const scaleLists = await getListsbyType("SCALE");
  const entries = await Promise.all(
    scaleLists.map(
      async (l: any) => [l.code, await getListItemsbyList(l.code)] as const
    )
  );
  scalesByList = Object.fromEntries(entries);
} catch (error) {
  console.error('Failed to fetch SCALE list items:', error);
  scalesByList = {};
}

const dimensionScale: Record<string, string> = Object.fromEntries(
  dimensions.map((d: any) => [d.code, d.scale || d.code])
);

// Resolve an assignment id -> { team name, user name } once for reuse
const teamName = (id: any) =>
  teams.find((t: any) => String(t.value) === String(id))?.label || id;
const userName = (id: any) =>
  users.find((u: any) => String(u.value) === String(id))?.label || id;
const roleName = (code: any) =>
  roles.find((r: any) => String(r.value) === String(code))?.label || code;

const assignmentById = new Map(
  assignments.map((a: any) => [
    String(a.id),
    { team: teamName(a.team), role: roleName(a.role), user: userName(a.user_id) },
  ])
);

// Row title = the assigned user (bold); its secondary segment = "RoleName — TeamName"
// (team may be null → dropped). The leading "— " comes from the .dt-title-secondary CSS.
const assignmentUser = (id: any) => assignmentById.get(String(id))?.user || "";
const assignmentRoleTeam = (id: any) => {
  const a = assignmentById.get(String(id));
  if (!a) return "";
  return [a.role, a.team].filter(Boolean).join(" — ");
};

// Map assignments to select options with readable label, sorted by
// userName → teamName → roleName so the dropdown reads alphabetically by person.
const assignmentOptions = assignments
  .map((a: any) => ({
    code: a.id,
    user: String(userName(a.user_id)),
    team: a.team ? String(teamName(a.team)) : "",
    role: String(roleName(a.role)),
  }))
  .sort(
    (x: any, y: any) =>
      x.user.localeCompare(y.user) ||
      x.team.localeCompare(y.team) ||
      x.role.localeCompare(y.role),
  )
  .map((a: any) => ({
    code: a.code,
    // Team may be null (unassigned) — drop it from the label in that case.
    name: [a.user, a.role, a.team].filter(Boolean).join(" — "),
  }));

const columns = [
  { key: "user_name", label: "metric_modal.assignment", as: "title", titleSecondaryKey: "role_team", subtitleKey: "dimension", subtitleFormat: "text" },
  { key: "assignment", label: "metric_modal.assignment", visible: false },
  { key: "role_team", label: "metric_modal.assignment", visible: false },
  { key: "dimension", label: "metric_modal.dimension", visible: false },
  { key: "value", label: "metric_modal.value", visible: true },
  { key: "measured_at", label: "metric_modal.measured_at", as: "date" },
];
const data = metrics
  .map((item) => {
    const a = assignmentById.get(String(item.assignment));
    return {
      id: item.id,
      dimension: item.dimension,
      assignment: item.assignment,
      user_name: assignmentUser(item.assignment),
      role_team: assignmentRoleTeam(item.assignment),
      // Split sort keys (not displayed) so rows order by user → role → team.
      _sort_user: String(a?.user || ""),
      _sort_role: String(a?.role || ""),
      _sort_team: String(a?.team || ""),
      value: item.value,
      observation: item.observation,
      measured_at: item.measured_at,
      is_active: item.is_active,
      created_at: item.created_at,
      updated_at: item.updated_at,
    };
  })
  .sort(
    (x, y) =>
      x._sort_user.localeCompare(y._sort_user) ||
      x._sort_role.localeCompare(y._sort_role) ||
      x._sort_team.localeCompare(y._sort_team),
  );
const tableFields = [
  { key: "dimension", label: "metric_modal.dimension", type: "select" as const, options: dimensions, pk: true, required: true },
  { key: "assignment", label: "metric_modal.assignment", type: "select" as const, options: assignmentOptions, pk: true, required: true },
  { key: "value", label: "metric_modal.value", type: "select" as const, options: [], required: true },
  { key: "observation", label: "metric_modal.observation", type: "textarea" as const, placeholder: "Optional observation" },
  { key: "measured_at", label: "metric_modal.measured_at", type: "calendar" as const, withTime: true },
];
const fieldKeys = ["id", ...tableFields.map((f) => f.key)];
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto w-full max-w-full md:p-0">
    <!-- Breadcrumb Start -->
    <Breadcrumb
      moduleName="Collaboration"
      pageName="Metrics"
      pageTitle="Metrics"
      homeLink="/"
      moduleNameKey="modules.COLLAB"
      masterKey="menu_options.dimensions"
      pageNameKey="menu_options.metrics"
      pageTitleKey="menu_options.metrics"
    />
    <!-- Breadcrumb End -->

    <CrudModal
      mode="create"
      modalId="metric-create-modal"
      entityName="Metric"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="metric-edit-modal"
      entityName="Metric"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="metric-delete-modal"
      entityName="Metric"
      fields={tableFields}
      showTrigger={false}
    />

    <div
      id="metrics-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      data-dimension-filter={dimensionFilter}
      data-scales-by-list={encodeURIComponent(JSON.stringify(scalesByList))}
      data-dimension-scale={encodeURIComponent(JSON.stringify(dimensionScale))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script>
      import { initCrudPage } from "@/lib/crudClient";
      import {
        createMetric,
        updateMetric,
        deleteMetric,
      } from "@/lib/metrics";

      initCrudPage({
        dataId: "metrics-data",
        editModalId: "metric-edit-modal",
        deleteModalId: "metric-delete-modal",
      });

      // Pre-select dimension filter from URL query param
      const metricsData = document.getElementById("metrics-data");
      const dimensionFilter = metricsData?.dataset.dimensionFilter;
      if (dimensionFilter) {
        const filterSelect = document.getElementById("metrics-filter");
        if (filterSelect) {
          filterSelect.value = dimensionFilter;
          filterSelect.dispatchEvent(new Event("change"));
        }
      }

      // --- Dynamic Value options driven by the selected Dimension ---
      // Each dimension measures against a SCALE list; when the dimension changes
      // we rebuild the value <select> with that scale's items (filtered to the
      // user's language). Maps are seeded server-side from every SCALE list.
      let scalesByList = {};
      let dimensionScale = {};
      try {
        scalesByList = JSON.parse(
          decodeURIComponent(metricsData?.dataset.scalesByList || "%7B%7D")
        );
        dimensionScale = JSON.parse(
          decodeURIComponent(metricsData?.dataset.dimensionScale || "%7B%7D")
        );
      } catch (err) {
        console.error("Failed to decode scale maps", err);
      }

      function valueOptionsFor(dimensionCode) {
        const scaleCode = dimensionScale[dimensionCode];
        const items = (scaleCode && scalesByList[scaleCode]) || [];
        if (items.length === 0) return [];
        const lang = localStorage.getItem("lang") || "en";
        const langs = new Set(items.map((i) => i.lang));
        const target = langs.has(lang)
          ? lang
          : items.find((i) => i.lang)?.lang || lang;
        return items.filter((i) => !i.lang || i.lang === target);
      }

      function refreshValueOptions(modal) {
        if (!modal) return;
        const dimSelect = modal.querySelector('select[name="dimension"]');
        const valSelect = modal.querySelector('select[name="value"]');
        if (!dimSelect || !valSelect) return;

        const previous = valSelect.value;
        // Preserve the translated empty placeholder, drop the rest.
        const placeholder =
          valSelect.querySelector('option[value=""]')?.cloneNode(true);
        valSelect.innerHTML = "";
        if (placeholder) valSelect.appendChild(placeholder);

        for (const item of valueOptionsFor(dimSelect.value)) {
          const opt = document.createElement("option");
          opt.value = item.value;
          opt.textContent = item.label || item.value;
          if (item.value === previous) opt.selected = true;
          valSelect.appendChild(opt);
        }
      }

      ["metric-create-modal", "metric-edit-modal"].forEach((id) => {
        const modal = document.getElementById(id);
        const dimSelect = modal?.querySelector('select[name="dimension"]');
        // Fires on user change (create) and on programmatic change dispatched
        // by crudClient's edit prefill, where dimension is set before value.
        dimSelect?.addEventListener("change", () => refreshValueOptions(modal));
      });

      // Helper function to show toast notifications
      function showToast(message, variant = "info") {
        const toast = document.createElement("div");
        toast.className = `fixed top-4 right-4 z-50 max-w-md p-4 rounded-lg border shadow-lg transition-all duration-300 ${
          variant === "error"
            ? "bg-red-50 text-red-800 border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800"
            : "bg-green-50 text-green-800 border-green-200 dark:bg-green-900/20 dark:text-green-400 dark:border-green-800"
        }`;
        toast.innerHTML = `
          <div class="flex items-start gap-3">
            <div class="flex-1 text-sm font-medium">${message}</div>
            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="this.parentElement.parentElement.remove()">✕</button>
          </div>
        `;
        document.body.appendChild(toast);

        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateX(100%)";
          setTimeout(() => toast.remove(), 300);
        }, 5000);
      }

      // Handle CRUD form submissions
      document.addEventListener("crud-submit", async (e) => {
        const { modalId, mode, data } = e.detail;

        try {
          if (mode === "create") {
            await createMetric({
              dimension: data.dimension,
              assignment: parseInt(data.assignment, 10),
              value: data.value,
              observation: data.observation || undefined,
              measured_at: data.measured_at || undefined,
              is_active: true,
            });
            showToast("Metric created successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "edit") {
            await updateMetric(parseInt(data.id, 10), {
              value: data.value,
              observation: data.observation || undefined,
              measured_at: data.measured_at || undefined,
              is_active: data.is_active !== false,
            });
            showToast("Metric updated successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "delete") {
            await deleteMetric(parseInt(data.id, 10));
            showToast("Metric deleted successfully!");
            setTimeout(() => window.location.reload(), 1000);
          }
        } catch (error) {
          console.error("CRUD operation failed:", error);
          showToast(error instanceof Error ? error.message : "An error occurred", "error");
        }
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="border-0 p-0">
        <!-- ====== Table Start -->
        <DataTable
          columns={columns}
          data={data}
          tableId="metrics"
          i18Item="metric"
          columnFilter="dimension"
          filterOptions={dimensions}
          masterPage="/collab/dimensions"
          mdItem="dimension"
        />
        <!-- ====== Table End -->
      </div>
    </div>
  </div>
</BaseLayout>
