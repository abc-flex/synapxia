---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getSpecifications } from "@/lib/specifications";
import { getCategoriesSelect } from "@/lib/categories";
import { getFeaturesSelect } from "@/lib/features";

// Fetch specifications from API
let specifications: any[] = [];
let errorMessage: string | null = null;

try {
  const apiLists = await getSpecifications();
  specifications = apiLists;
} catch (error) {
  console.error('Failed to fetch specifications:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch specifications from API';
  // Fallback to empty array to still render the page
  specifications = [];
}

// Fetch categories from API for select field
let categories: any[] = [];
try {
  const apiCategories = await getCategoriesSelect();
  categories = apiCategories;
} catch (error) {
  console.error('Failed to fetch categories:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch categories from API';
  // Fallback to empty array to still render the page
  categories = [];
}

// Fetch features from API for select field
let features: any[] = [];
try {
  const apiFeatures = await getFeaturesSelect();
  features = apiFeatures;
} catch (error) {
  console.error('Failed to fetch features:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch features from API';
  // Fallback to empty array to still render the page
  features = [];
}

const columns = [
  { key: "category", label: "specification_modal.category", visible: false },
  { key: "category_name", label: "specification_modal.category" },
  { key: "feature", label: "specification_modal.feature", visible: false },
  { key: "feature_name", label: "specification_modal.feature" },
  { key: "default_value", label: "specification_modal.default_value" },
];
const data = specifications.map((item) => ({
  id: `${item.category}::${item.feature}`,
  category: item.category,
  category_name: categories.find((c) => String(c.value) === String(item.category))?.label || item.category,
  feature: item.feature,
  feature_name: features.find((f) => String(f.value) === String(item.feature))?.label || item.feature,
  default_value: item.default_value,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));
const formFields = [
  { key: "category", label: "specification_modal.category", type: "select" as const, options: categories, pk: true, required: true },
  { key: "feature", label: "specification_modal.feature", type: "select" as const, options: features, pk: true, required: true },
  { key: "default_value", label: "specification_modal.default_value", type: "text" as const },
];
const fieldKeys = ["id", ...formFields.map((f) => f.key)];
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <!-- Breadcrumb Start -->
    <Breadcrumb
      moduleName="Asset Taxonomy"
      pageName="Specifications"
      pageTitle="Specifications"
      homeLink="/"
      moduleNameKey="modules.TAXO"
      pageNameKey="menu_options.specifications"
      pageTitleKey="menu_options.specifications"
    />
    <!-- Breadcrumb End -->

    <CrudModal
      mode="create"
      modalId="specification-create-modal"
      entityName="Specification"
      fields={formFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="specification-edit-modal"
      entityName="Specification"
      fields={formFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="specification-delete-modal"
      entityName="Specification"
      fields={formFields}
      showTrigger={false}
    />

    <div
      id="specifications-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage } from "/scripts/crudClient.js";
      import {
        createSpecification,
        updateSpecification,
        deleteSpecification,
      } from "/src/lib/specifications";

      initCrudPage({
        dataId: "specifications-data",
        editModalId: "specification-edit-modal",
        deleteModalId: "specification-delete-modal",
      });

      // Helper function to show toast notifications
      function showToast(message, variant = "info") {
        const toast = document.createElement("div");
        toast.className = `fixed top-4 right-4 z-50 max-w-md p-4 rounded-lg border shadow-lg transition-all duration-300 ${
          variant === "error"
            ? "bg-red-50 text-red-800 border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800"
            : "bg-green-50 text-green-800 border-green-200 dark:bg-green-900/20 dark:text-green-400 dark:border-green-800"
        }`;
        toast.innerHTML = `
          <div class="flex items-start gap-3">
            <div class="flex-1 text-sm font-medium">${message}</div>
            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="this.parentElement.parentElement.remove()">✕</button>
          </div>
        `;
        document.body.appendChild(toast);

        // Auto-remove after 5 seconds
        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateX(100%)";
          setTimeout(() => toast.remove(), 300);
        }, 5000);
      }

      // Handle CRUD form submissions
      document.addEventListener("crud-submit", async (e) => {
        const { modalId, mode, data } = e.detail;

        try {
          // Parse composite ID: "category::feature"
          const [category, feature] = data.id.split("::");
          if (mode === "create") {
            // Create new specification
            await createSpecification({
              category: data.category,
              feature: data.feature,
              default_value: data.default_value || false,
            });
            showToast("Specification created successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "edit") {
            // Update existing specification
            await updateSpecification(category, feature, {
              default_value: data.default_value || false,
              is_active: data.is_active !== false,
            });
            showToast("Specification updated successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "delete") {
            await deleteSpecification(category, feature);
            showToast("Specification deleted successfully!");
            setTimeout(() => window.location.reload(), 1000);
          }
        } catch (error) {
          console.error("CRUD operation failed:", error);
          showToast(error instanceof Error ? error.message : "An error occurred", "error");
        }
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="border-0 p-0">
        <DataTable
          columns={columns}
          data={data}
          tableId="specifications"
          i18Item="specification"
          columnFilter="category"
          filterOptions={categories}
          masterPage="/taxo/categories"
          mdItem="category"
        />
      </div>
    </div>
  </div>
</BaseLayout>
