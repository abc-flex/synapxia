---
/**
 * AgentCard — Agent Index card. The richest catalog card: it uses GalleryCard's
 * opt-in "hero" mode (a violet gradient header carrying the cpu-chip icon + name
 * + favorite) and fills the body with the description, a short preview of the
 * agent INSTRUCTIONS, and meta chips (model + tool chips + tags). The whole card
 * opens the read-only detail view; Edit/Delete live there, so there are no
 * per-card action buttons.
 */
import GalleryCard from "@/components/lib/gallery/GalleryCard.astro";

export interface Props {
  id: number | string;
  name: string;
  subtitle?: string;
  description?: string;
  statusLabel?: string;
  statusValue?: string;
  favorite?: string;
  searchText?: string;
  editModalId?: string;
  detailModalId?: string;
  model?: string;
  tools?: string[];
  instructionsPreview?: string;
  tags?: string[];
  votable?: boolean;
  voteScore?: number;
  myVote?: string;
}

const {
  id,
  name,
  subtitle,
  description,
  statusLabel,
  statusValue,
  favorite,
  searchText,
  editModalId = "agent-detail-modal",
  detailModalId = "agent-view-modal",
  model,
  tools = [],
  instructionsPreview,
  tags = [],
  votable = false,
  voteScore = 0,
  myVote = "",
} = Astro.props as Props;

const MAX_TOOLS = 4;
const shownTools = tools.slice(0, MAX_TOOLS);
const extraTools = tools.length - shownTools.length;
---

<GalleryCard
  id={id}
  name={name}
  subtitle={subtitle}
  statusLabel={statusLabel}
  statusValue={statusValue}
  favorite={favorite}
  searchText={searchText}
  editModalId={editModalId}
  detailModalId={detailModalId}
  hero={true}
  heroClass="from-violet-500 to-indigo-500"
  votable={votable}
  voteScore={voteScore}
  myVote={myVote}
>
  <span slot="icon" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-white/20 text-white">
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <rect x="6" y="6" width="12" height="12" rx="2" />
      <path d="M9 1v3M15 1v3M9 20v3M15 20v3M1 9h3M1 15h3M20 9h3M20 15h3" stroke-linecap="round" />
    </svg>
  </span>

  <Fragment slot="body">
    {description && (
      <p class="line-clamp-2 text-sm text-gray-500 dark:text-gray-400">{description}</p>
    )}
    {instructionsPreview && (
      <div class="mt-3 rounded-lg bg-violet-50/60 p-2.5 dark:bg-violet-500/10">
        <span class="block text-[10px] font-semibold uppercase tracking-wide text-violet-600 dark:text-violet-300" data-i18n="agent_card.instructions">Instructions</span>
        <p class="mt-0.5 line-clamp-2 text-xs text-gray-500 dark:text-gray-400">{instructionsPreview}</p>
      </div>
    )}
  </Fragment>

  <Fragment slot="chips">
    {model && (
      <span class="inline-flex items-center gap-1 rounded-md bg-gray-100 px-2 py-0.5 text-xs text-gray-600 dark:bg-gray-800 dark:text-gray-300">
        <span class="opacity-60" data-i18n="agent_card.model">Model</span>
        <span class="font-medium">{model}</span>
      </span>
    )}
    {shownTools.map((tool) => (
      <span class="inline-flex items-center rounded-md bg-gray-100 px-2 py-0.5 text-xs text-gray-600 dark:bg-gray-800 dark:text-gray-300">{tool}</span>
    ))}
    {extraTools > 0 && (
      <span class="inline-flex items-center rounded-md bg-gray-100 px-2 py-0.5 text-xs text-gray-500 dark:bg-gray-800 dark:text-gray-400">
        +{extraTools} <span class="ml-1" data-i18n="agent_card.tools_more">more</span>
      </span>
    )}
    {tags.map((tag) => (
      <span class="inline-flex items-center rounded-md bg-violet-50 px-2 py-0.5 text-xs font-medium text-violet-700 dark:bg-violet-500/15 dark:text-violet-300">#{tag}</span>
    ))}
  </Fragment>
</GalleryCard>
