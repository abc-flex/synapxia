---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getRoles } from "@/lib/roles";

// Fetch roles from API
let roles: any[] = [];
let errorMessage: string | null = null;

try {
  const apiRoles = await getRoles();
  roles = apiRoles;
} catch (error) {
  console.error('Failed to fetch roles:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch roles from API';
  // Fallback to empty array to still render the page
  roles = [];
}

const columns = [
  { key: "code", label: "role_modal.code", as: "title", subtitleKey: "name", subtitleFormat: "text" },
  { key: "name", label: "role_modal.name", visible: false },
  { key: "icon", label: "role_modal.icon" },
];
const data = roles.map((item) => ({
  id: item.code,
  code: item.code,
  name: item.name,
  description: item.description,
  icon: item.icon,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));
const tableFields = [
  { key: "code", label: "role_modal.code", pk: true, required: true, placeholder: "e.g. ADMIN" },
  { key: "name", label: "role_modal.name", required: true, placeholder: "e.g. Administration" },
  { key: "icon", label: "role_modal.icon", placeholder: "Heroicon path" },
  {
    key: "description",
    label: "role_modal.description",
    type: "textarea" as const,  
    placeholder: "Optional details of role",
  },
];
const fieldKeys = tableFields.map((f) => f.key);
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto w-full max-w-full md:p-0">
    <!-- Breadcrumb Start -->
    <Breadcrumb
      moduleName="Collaboration"
      pageName="Roles"
      pageTitle="Roles"
      homeLink="/"
      moduleNameKey="modules.COLLAB"
      pageNameKey="menu_options.roles"
      pageTitleKey="menu_options.roles"
    />
    <!-- Breadcrumb End -->

    <CrudModal
      mode="create"
      modalId="role-create-modal"
      entityName="Role"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="role-edit-modal"
      entityName="Role"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="role-delete-modal"
      entityName="Role"
      fields={tableFields}
      showTrigger={false}
    />

    <div
      id="roles-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage } from "/scripts/crudClient.js";
      import {
        createRole,
        updateRole,
        deleteRole,
      } from "/src/lib/roles";

      initCrudPage({
        dataId: "roles-data",
        editModalId: "role-edit-modal",
        deleteModalId: "role-delete-modal",
      });

      // Helper function to show toast notifications
      function showToast(message, variant = "info") {
        const toast = document.createElement("div");
        toast.className = `fixed top-4 right-4 z-50 max-w-md p-4 rounded-lg border shadow-lg transition-all duration-300 ${
          variant === "error"
            ? "bg-red-50 text-red-800 border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800"
            : "bg-green-50 text-green-800 border-green-200 dark:bg-green-900/20 dark:text-green-400 dark:border-green-800"
        }`;
        toast.innerHTML = `
          <div class="flex items-start gap-3">
            <div class="flex-1 text-sm font-medium">${message}</div>
            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="this.parentElement.parentElement.remove()">✕</button>
          </div>
        `;
        document.body.appendChild(toast);

        // Auto-remove after 5 seconds
        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateX(100%)";
          setTimeout(() => toast.remove(), 300);
        }, 5000);
      }

      // Handle CRUD form submissions
      document.addEventListener("crud-submit", async (e) => {
        const { modalId, mode, data } = e.detail;

        try {
          if (mode === "create") {
            // Create new role
            await createRole({
              code: data.code,
              name: data.name,
              description: data.description,
              icon: data.icon,
              is_active: data.is_active !== false,
            });

            showToast("Role created successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "edit") {
            // Update existing role
            await updateRole(data.id, {
              name: data.name,
              description: data.description,
              icon: data.icon,
              is_active: data.is_active !== false,
            });

            showToast("Role updated successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "delete") {
            // Delete role
            await deleteRole(data.id);

            showToast("Role deleted successfully!");
            setTimeout(() => window.location.reload(), 1000);
          }
        } catch (error) {
          console.error("CRUD operation failed:", error);
          showToast(error.message || "An error occurred", "error");
        }
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="space-y-5 sm:space-y-6">
        <!-- ====== Table Start -->
        <DataTable
          columns={columns}
          data={data}
          tableId="roles"
          i18Item="role"
        />
        <!-- ====== Table End -->
      </div>
    </div>
  </div>
</BaseLayout>
