---
import ClientTranslations from "@/components/ClientTranslations.astro";
import LanguageSwitcher from "@/components/core/header/LanguageSwitcher.astro";
import "../styles/globals.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title data-i18n="login_page.sign_up">Sign Up - Synapxia</title>
  </head>
  <body
    class="bg-gradient-to-br from-indigo-600 to-purple-700 dark:from-gray-900 dark:to-gray-950 min-h-screen flex items-center justify-center p-4"
  >
    <ClientTranslations />

    {/* Language Switcher - Top Right */}
    <div class="fixed top-6 right-6 z-50">
      <LanguageSwitcher />
    </div>

    <div
      class="w-full max-w-md bg-white dark:bg-gray-900 rounded-2xl shadow-2xl overflow-hidden"
    >
      {/* Header */}
      <div
        class="bg-gradient-to-br from-indigo-600 to-purple-700 px-8 py-10 sm:px-10 sm:py-12 text-center text-white"
      >
        <div
          class="w-16 h-16 mx-auto mb-5 bg-white/10 rounded-2xl flex items-center justify-center text-3xl font-bold"
        >
          IA
        </div>
        <h1 class="text-2xl sm:text-3xl font-bold mb-2">Synapxia</h1>
        <p class="text-sm text-white/80">Create your account</p>
      </div>

      {/* Body */}
      <div class="px-6 sm:px-8 py-8 sm:py-10">
        {/* Error Message */}
        <div
          id="error-message"
          class="hidden mb-4 p-3 bg-red-100 dark:bg-red-900 border border-red-400 dark:border-red-600 text-red-700 dark:text-red-200 rounded-lg text-sm"
        ></div>

        {/* Success Message */}
        <div
          id="success-message"
          class="hidden mb-4 p-3 bg-green-100 dark:bg-green-900 border border-green-400 dark:border-green-600 text-green-700 dark:text-green-200 rounded-lg text-sm"
        ></div>

        {/* Loading State */}
        <div
          id="loading-spinner"
          class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50"
        >
          <div
            class="w-12 h-12 border-4 border-indigo-200 border-t-indigo-600 rounded-full animate-spin"
          ></div>
        </div>

        <form id="signup-form" class="space-y-4">
          {/* Username */}
          <div>
            <label
              for="username"
              class="block text-sm font-semibold text-gray-800 dark:text-gray-200 mb-1"
              >Username</label
            >
            <input
              id="username"
              type="text"
              name="username"
              placeholder="Choose a username"
              required
              minlength="3"
              class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white dark:bg-gray-800 bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 dark:focus:ring-indigo-900 transition"
            />
          </div>

          {/* Email */}
          <div>
            <label
              for="email"
              class="block text-sm font-semibold text-gray-800 dark:text-gray-200 mb-1"
              >Email</label
            >
            <input
              id="email"
              type="email"
              name="email"
              placeholder="Enter your email"
              required
              class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white dark:bg-gray-800 bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 dark:focus:ring-indigo-900 transition"
            />
          </div>

          {/* First Name */}
          <div>
            <label
              for="first_name"
              class="block text-sm font-semibold text-gray-800 dark:text-gray-200 mb-1"
              >First Name</label
            >
            <input
              id="first_name"
              type="text"
              name="first_name"
              placeholder="First name"
              required
              class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white dark:bg-gray-800 bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 dark:focus:ring-indigo-900 transition"
            />
          </div>

          {/* Last Name */}
          <div>
            <label
              for="last_name"
              class="block text-sm font-semibold text-gray-800 dark:text-gray-200 mb-1"
              >Last Name</label
            >
            <input
              id="last_name"
              type="text"
              name="last_name"
              placeholder="Last name"
              required
              class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white dark:bg-gray-800 bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 dark:focus:ring-indigo-900 transition"
            />
          </div>

          {/* Role */}
          <div>
            <label
              for="profile"
              class="block text-sm font-semibold text-gray-800 dark:text-gray-200 mb-1"
              >Role</label
            >
            <select
              id="profile"
              name="profile"
              required
              class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white dark:bg-gray-800 bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 dark:focus:ring-indigo-900 transition"
            >
              <option value="">Select a role</option>
              <option value="ADMINISTRATOR">Administrator</option>
              <option value="ADMINISTRATIVE">Operational Administrator</option>
              <option value="COLLABORATOR">Standard Collaborator</option>
            </select>
          </div>

          {/* Business Unit */}
          <div>
            <label
              for="unit"
              class="block text-sm font-semibold text-gray-800 dark:text-gray-200 mb-1"
              >Business Unit</label
            >
            <select
              id="unit"
              name="unit"
              required
              class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white dark:bg-gray-800 bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 dark:focus:ring-indigo-900 transition"
            >
              <option value="">Select a business unit</option>
              <option value="CORP">Corporate</option>
              <option value="ENG">Engineering</option>
              <option value="GEN_AI">Generative AI</option>
            </select>
          </div>

          {/* Password */}
          <div>
            <label
              for="password"
              class="block text-sm font-semibold text-gray-800 dark:text-gray-200 mb-1"
              >Password</label
            >
            <input
              id="password"
              type="password"
              name="password"
              placeholder="Min 8 characters"
              required
              minlength="8"
              class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white dark:bg-gray-800 bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 dark:focus:ring-indigo-900 transition"
            />
          </div>

          {/* Confirm Password */}
          <div>
            <label
              for="confirm_password"
              class="block text-sm font-semibold text-gray-800 dark:text-gray-200 mb-1"
              >Confirm Password</label
            >
            <input
              id="confirm_password"
              type="password"
              name="confirm_password"
              placeholder="Confirm password"
              required
              minlength="8"
              class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white dark:bg-gray-800 bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 dark:focus:ring-indigo-900 transition"
            />
          </div>

          {/* Terms & Conditions */}
          <label class="flex items-center cursor-pointer">
            <input
              type="checkbox"
              id="agree"
              name="agree"
              required
              class="w-4 h-4 rounded border-gray-300 dark:border-gray-600 text-indigo-600 focus:ring-indigo-500"
            />
            <span class="ml-2 text-sm text-gray-700 dark:text-gray-300"
              >I agree to the Terms and Conditions</span
            >
          </label>

          {/* Sign Up Button */}
          <button
            type="submit"
            class="w-full py-3 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-semibold rounded-lg transition active:scale-95 hover:shadow-lg transform hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed mt-6"
          >
            Create Account
          </button>
        </form>

        {/* Login Link */}
        <div class="mt-6 text-center text-sm text-gray-600 dark:text-gray-400">
          <span>Already have an account?</span>
          <a
            href="/login"
            class="ml-1 text-indigo-600 dark:text-indigo-400 font-semibold hover:underline"
            >Login</a
          >
        </div>
      </div>
    </div>

    <script>
      import { register } from '@/lib/auth';
      import type { UserCreate } from '@/types/api';

      const signupForm = document.getElementById('signup-form') as HTMLFormElement;
      const errorMessage = document.getElementById('error-message');
      const successMessage = document.getElementById('success-message');
      const loadingSpinner = document.getElementById('loading-spinner');
      const passwordInput = document.getElementById('password') as HTMLInputElement;
      const submitButton = signupForm?.querySelector('button[type="submit"]') as HTMLButtonElement;
      let isSubmitting = false;

      // Password strength validation
      passwordInput?.addEventListener('input', (e) => {
        const password = (e.target as HTMLInputElement).value;
        
        // Password must be at least 8 characters
        if (password.length >= 8) {
          (e.target as HTMLInputElement).classList.remove('border-red-500');
          (e.target as HTMLInputElement).classList.add('border-green-500');
        } else if (password.length > 0) {
          (e.target as HTMLInputElement).classList.add('border-red-500');
          (e.target as HTMLInputElement).classList.remove('border-green-500');
        }
      });

      signupForm?.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Prevent double submissions
        if (isSubmitting) return;
        isSubmitting = true;

        const username = (document.getElementById('username') as HTMLInputElement)?.value;
        const email = (document.getElementById('email') as HTMLInputElement)?.value;
        const first_name = (document.getElementById('first_name') as HTMLInputElement)?.value;
        const last_name = (document.getElementById('last_name') as HTMLInputElement)?.value;
        const profile = (document.getElementById('profile') as HTMLSelectElement)?.value;
        const unit = (document.getElementById('unit') as HTMLSelectElement)?.value;
        const password = (document.getElementById('password') as HTMLInputElement)?.value;
        const confirm_password = (document.getElementById('confirm_password') as HTMLInputElement)?.value;

        // Validate inputs
        if (!username || !email || !first_name || !last_name || !profile || !unit || !password) {
          showError('All fields are required');
          isSubmitting = false;
          return;
        }

        // Email validation
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(email)) {
          showError('Please enter a valid email address');
          isSubmitting = false;
          return;
        }

        // Password length validation
        if (password.length < 8) {
          showError('Password must be at least 8 characters long');
          isSubmitting = false;
          return;
        }

        if (password !== confirm_password) {
          showError('Passwords do not match');
          isSubmitting = false;
          return;
        }

        try {
          // Show loading spinner and disable button
          if (loadingSpinner) {
            loadingSpinner.classList.remove('hidden');
          }
          if (submitButton) {
            submitButton.disabled = true;
          }

          // Clear previous messages
          if (errorMessage) {
            errorMessage.classList.add('hidden');
            errorMessage.textContent = '';
          }
          if (successMessage) {
            successMessage.classList.add('hidden');
            successMessage.textContent = '';
          }

          // Call register API
          const userData: UserCreate = {
            username,
            email,
            password,
            first_name,
            last_name,
            profile,
            unit,
          };

          await register(userData);

          // Registration successful
          if (successMessage) {
            successMessage.textContent = 'Account created successfully! Redirecting to login...';
            successMessage.classList.remove('hidden');
          }

          // Redirect to login after 2 seconds
          setTimeout(() => {
            window.location.href = '/login';
          }, 2000);
        } catch (error) {
          isSubmitting = false;
          
          if (loadingSpinner) {
            loadingSpinner.classList.add('hidden');
          }
          if (submitButton) {
            submitButton.disabled = false;
          }

          if (error instanceof Error) {
            showError(error.message);
          } else {
            showError('Registration failed: unknown error');
          }
        }
      });

      function showError(message: string) {
        if (errorMessage) {
          errorMessage.textContent = message;
          errorMessage.classList.remove('hidden');
        }
      }
    </script>
  </body>
</html>
