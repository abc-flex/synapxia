---
/**
 * GalleryCard — base card scaffold shared by every LIB curated catalog
 * (Prompts, MCPs, Agents, …). Provides the common chrome (container, favorite
 * star, title + subtitle, status pill) and four named slots for per-catalog
 * custom rendering: `icon`, `chips`, `body`, `actions`.
 *
 * It is catalog-agnostic: the consumer page passes the flattened row fields and
 * fills the slots. The client controller (`lib/catalogGallery.ts`) drives the
 * favorite star, whole-card edit-open, and delete via the `data-*` attributes
 * emitted here.
 */
import { statusTone } from "@/lib/datatable";

export interface Props {
  id: number | string;
  name: string;
  /** Pre-formatted muted subtitle (e.g. "updated 2 d ago"). */
  subtitle?: string;
  /** Raw ISO timestamp behind `subtitle` — lets the client re-localize the
   * relative time on language switch (emitted as data-relative-ts). */
  subtitleTs?: string;
  /** Display label for the status pill. */
  statusLabel?: string;
  /** Raw status value — used for tone + the gallery's status filter. */
  statusValue?: string;
  /** "yes" | "no" — initial favorite state. */
  favorite?: string;
  /** Lowercased haystack for client-side search. */
  searchText?: string;
  /** Dialog id opened when the card (or its edit button) is activated. */
  editModalId?: string;
  /**
   * Dialog id opened on a whole-card click. When set it takes precedence over
   * `editModalId` (the controller opens this read-only "big card" view instead
   * of the edit form).
   */
  detailModalId?: string;
  /** Opt-in gradient "hero" header (icon + name + favorite on a colored band). */
  hero?: boolean;
  /** Tailwind gradient classes for the hero band (e.g. "from-violet-500 to-indigo-500"). */
  heroClass?: string;
  /** Opt-in up/down vote bar (HU-LI05). */
  votable?: boolean;
  /** Initial like count (active POSITIVE votes). */
  votePositive?: number;
  /** Initial dislike count (active NEGATIVE votes). */
  voteNegative?: number;
  /** The current user's vote: "POSITIVE" | "NEGATIVE" | "" (none). */
  myVote?: string;
  /** Show a "discuss" button (opens the detail view focused on the foro). Auto-on
   * when the card has a `detailModalId`. */
  discussCount?: number;
  /** Asset's current semver label (HU-LI09), e.g. "1.2.0". Rendered as a small
   * mono chip beside the status pill; omitted entirely when unset. */
  version?: string;
}

const {
  id,
  name,
  subtitle,
  subtitleTs,
  statusLabel,
  statusValue = "",
  favorite = "no",
  searchText = "",
  editModalId,
  detailModalId,
  hero = false,
  heroClass = "from-indigo-500 to-indigo-600",
  votable = false,
  votePositive = 0,
  voteNegative = 0,
  myVote = "",
  discussCount = 0,
  version,
} = Astro.props as Props;

const favOn = favorite === "yes";

// Status pill label is data-i18n'd so it re-localizes on language switch (the
// SSR `statusLabel` stays as the fallback). Key off the raw code (strip any
// `N-` ordinal prefix); omit when there's no code so the fallback text shows.
const statusCode = (statusValue || "").replace(/^\d+-/, "").toUpperCase();
const statusKey = statusCode ? `asset_status.${statusCode}` : undefined;

const upOn = myVote === "POSITIVE";
const downOn = myVote === "NEGATIVE";
const voteBtnBase = "rounded-md p-1 transition-colors hover:bg-gray-100 dark:hover:bg-gray-800 ";
const upBtnClass = voteBtnBase + (upOn ? "text-emerald-500" : "text-gray-400");
const downBtnClass = voteBtnBase + (downOn ? "text-rose-500" : "text-gray-400");
// Active vote = filled icon; inactive = outline. Title/aria-label flip to
// "Remove vote" when active so the un-vote toggle is discoverable.
const upKey = upOn ? "gallery.vote_remove" : "gallery.vote_up";
const downKey = downOn ? "gallery.vote_remove" : "gallery.vote_down";
const upTitle = upOn ? "Remove vote" : "Helpful";
const downTitle = downOn ? "Remove vote" : "Not helpful";

const base = "shrink-0 rounded-md p-1.5 transition-colors ";
const favBtnLight =
  base + "hover:bg-gray-100 dark:hover:bg-gray-800 " + (favOn ? "text-yellow-400" : "text-gray-400");
const favBtnHero = base + "hover:bg-white/20 " + (favOn ? "text-yellow-300" : "text-white/80");
---

<article
  data-card
  data-id={String(id)}
  data-search={searchText}
  data-status={statusValue}
  data-favorite={favOn ? "yes" : "no"}
  data-edit-modal={editModalId}
  data-detail-modal={detailModalId}
  class={`group relative flex cursor-pointer flex-col rounded-2xl border border-gray-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md dark:border-gray-800 dark:bg-gray-900 ${hero ? "overflow-hidden" : "p-4"}`}
>
  {hero ? (
    <div class={`flex items-start justify-between gap-3 bg-gradient-to-br ${heroClass} px-4 py-4 text-white`}>
      <div class="flex min-w-0 items-center gap-3">
        <slot name="icon" />
        <div class="min-w-0">
          <h3 class="truncate font-semibold text-white">{name}</h3>
          {subtitle && <p class="mt-0.5 truncate text-xs text-white/70" data-relative-ts={subtitleTs}>{subtitle}</p>}
        </div>
      </div>
      <button
        type="button"
        data-action="favorite"
        data-id={String(id)}
        aria-pressed={favOn ? "true" : "false"}
        title="Add to favorites"
        data-i18n-title="gallery.favorite_add"
        class={favBtnHero}
      >
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill={favOn ? "currentColor" : "none"} stroke="currentColor" stroke-width="1.5">
          <path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.3 4.02a1 1 0 00.95.69h4.22c.97 0 1.37 1.24.59 1.81l-3.42 2.48a1 1 0 00-.36 1.12l1.3 4.02c.3.92-.75 1.69-1.54 1.12l-3.41-2.48a1 1 0 00-1.18 0l-3.41 2.48c-.78.57-1.84-.2-1.54-1.12l1.3-4.02a1 1 0 00-.36-1.12L2 9.45c-.78-.57-.38-1.81.6-1.81h4.21a1 1 0 00.95-.69l1.3-4.02z" />
        </svg>
      </button>
    </div>
  ) : (
    <div class="flex items-start justify-between gap-3">
      <div class="flex min-w-0 items-center gap-3">
        <slot name="icon" />
        <div class="min-w-0">
          <h3 class="truncate font-semibold text-gray-900 dark:text-white">{name}</h3>
          {subtitle && <p class="mt-0.5 truncate text-xs text-gray-400" data-relative-ts={subtitleTs}>{subtitle}</p>}
        </div>
      </div>

      <button
        type="button"
        data-action="favorite"
        data-id={String(id)}
        aria-pressed={favOn ? "true" : "false"}
        title="Add to favorites"
        data-i18n-title="gallery.favorite_add"
        class={favBtnLight}
      >
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill={favOn ? "currentColor" : "none"} stroke="currentColor" stroke-width="1.5">
          <path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.3 4.02a1 1 0 00.95.69h4.22c.97 0 1.37 1.24.59 1.81l-3.42 2.48a1 1 0 00-.36 1.12l1.3 4.02c.3.92-.75 1.69-1.54 1.12l-3.41-2.48a1 1 0 00-1.18 0l-3.41 2.48c-.78.57-1.84-.2-1.54-1.12l1.3-4.02a1 1 0 00-.36-1.12L2 9.45c-.78-.57-.38-1.81.6-1.81h4.21a1 1 0 00.95-.69l1.3-4.02z" />
        </svg>
      </button>
    </div>
  )}

  <div class={hero ? "flex flex-1 flex-col px-4 pb-4 pt-3" : "contents"}>
  {(statusLabel || version) && (
    <div class="mt-3 flex flex-wrap items-center gap-1.5">
      {statusLabel && (
        <span class={`inline-flex w-fit items-center rounded-full px-2.5 py-0.5 text-xs font-medium ${statusTone(statusValue || statusLabel)}`} data-i18n={statusKey}>
          {statusLabel}
        </span>
      )}
      {version && (
        <span class="inline-flex w-fit items-center rounded-full bg-gray-100 px-2.5 py-0.5 font-mono text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-300">
          v{version}
        </span>
      )}
    </div>
  )}

  <div class="mt-3 flex-1">
    <slot name="body" />
  </div>

  <div class="mt-3 flex flex-wrap gap-1.5">
    <slot name="chips" />
  </div>

  {(votable || detailModalId) && (
    <div class="mt-3 flex items-center gap-1" data-vote-bar>
      {votable && (
        <Fragment>
          <button
            type="button"
            data-action="vote-up"
            data-id={String(id)}
            aria-pressed={upOn ? "true" : "false"}
            title={upTitle}
            aria-label={upTitle}
            data-i18n-title={upKey}
            data-i18n-aria-label={upKey}
            class={upBtnClass}
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M7.493 18.5c-.425 0-.82-.236-.974-.632A7.48 7.48 0 016 15.125c0-1.75.599-3.358 1.602-4.634.151-.192.373-.309.6-.397.473-.183.89-.514 1.212-.924a9.042 9.042 0 012.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 00.322-1.672V2.75a.75.75 0 01.75-.75 2.25 2.25 0 012.25 2.25c0 1.152-.26 2.243-.722 3.218-.266.558.107 1.282.725 1.282h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 01-2.649 7.521c-.388.482-.987.729-1.605.729H14.23c-.483 0-.964-.078-1.423-.23l-3.114-1.04a4.501 4.501 0 00-1.423-.23h-.777ZM2.331 10.727a11.969 11.969 0 00-.831 4.398 12 12 0 00.52 3.507c.26.85 1.084 1.368 1.973 1.368H4.9c.445 0 .72-.498.523-.898a8.963 8.963 0 01-.924-3.977c0-1.708.476-3.305 1.302-4.666.245-.403-.028-.959-.5-.959H4.25c-.832 0-1.612.453-1.918 1.227Z" />
            </svg>
          </button>
          <span data-vote-up-count class="min-w-[1rem] text-center text-sm font-semibold text-gray-700 dark:text-gray-200">{votePositive}</span>
          <button
            type="button"
            data-action="vote-down"
            data-id={String(id)}
            aria-pressed={downOn ? "true" : "false"}
            title={downTitle}
            aria-label={downTitle}
            data-i18n-title={downKey}
            data-i18n-aria-label={downKey}
            class={downBtnClass}
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
              <g transform="rotate(180 12 12)">
                <path d="M7.493 18.5c-.425 0-.82-.236-.974-.632A7.48 7.48 0 016 15.125c0-1.75.599-3.358 1.602-4.634.151-.192.373-.309.6-.397.473-.183.89-.514 1.212-.924a9.042 9.042 0 012.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 00.322-1.672V2.75a.75.75 0 01.75-.75 2.25 2.25 0 012.25 2.25c0 1.152-.26 2.243-.722 3.218-.266.558.107 1.282.725 1.282h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 01-2.649 7.521c-.388.482-.987.729-1.605.729H14.23c-.483 0-.964-.078-1.423-.23l-3.114-1.04a4.501 4.501 0 00-1.423-.23h-.777ZM2.331 10.727a11.969 11.969 0 00-.831 4.398 12 12 0 00.52 3.507c.26.85 1.084 1.368 1.973 1.368H4.9c.445 0 .72-.498.523-.898a8.963 8.963 0 01-.924-3.977c0-1.708.476-3.305 1.302-4.666.245-.403-.028-.959-.5-.959H4.25c-.832 0-1.612.453-1.918 1.227Z" />
              </g>
            </svg>
          </button>
          <span data-vote-down-count class="min-w-[1rem] text-center text-sm font-semibold text-gray-700 dark:text-gray-200">{voteNegative}</span>
        </Fragment>
      )}
      {detailModalId && (
        <button
          type="button"
          data-action="discuss"
          data-id={String(id)}
          title="Comment or ask a question"
          aria-label="Comment or ask a question"
          data-i18n-title="gallery.discuss"
          data-i18n-aria-label="gallery.discuss"
          class={`${votable ? "ml-1 " : ""}flex items-center gap-1 rounded-md p-1 text-gray-400 transition-colors hover:bg-gray-100 hover:text-indigo-500 dark:hover:bg-gray-800`}
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3.75h6m-9.75 5.25 3.6-2.7a1.5 1.5 0 0 1 .9-.3H18a2.25 2.25 0 0 0 2.25-2.25v-6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v11.25Z" />
          </svg>
          <span data-discuss-count class={`text-sm font-semibold ${discussCount > 0 ? "" : "hidden"}`}>{discussCount > 0 ? discussCount : ""}</span>
        </button>
      )}
    </div>
  )}

  {Astro.slots.has("actions") && (
    <div class="mt-4 flex items-center justify-end gap-2 border-t border-gray-100 pt-3 dark:border-gray-800">
      <slot name="actions" />
    </div>
  )}
  </div>
</article>
