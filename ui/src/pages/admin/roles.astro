---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getRoles } from "@/lib/roles";

// Fetch roles from API
let roles: any[] = [];
let errorMessage: string | null = null;

try {
  const apiRoles = await getRoles();
  roles = apiRoles;
} catch (error) {
  console.error('Failed to fetch roles:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch roles from API';
  // Fallback to empty array to still render the page
  roles = [];
}

const columns = [
  { key: "code", label: "Code" },
  { key: "name", label: "Name" },
];
const data = roles.map((item) => ({
  id: item.code,
  code: item.code,
  name: item.name,
  description: item.description,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));
const tableFields = [
  { key: "code", label: "Code", required: true, placeholder: "e.g. ADMIN" },
  { key: "name", label: "Name", required: true, placeholder: "e.g. Administration" },
  {
    key: "description",
    label: "Description",
    type: "textarea" as const,  
    placeholder: "Optional details of role",
  },
];
const fieldKeys = tableFields.map((f) => f.key);
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <!-- Breadcrumb Start -->
    <Breadcrumb
      moduleName="Administration"
      pageName="Roles"
      pageTitle="Roles"
      homeLink="/"
      moduleNameKey="modules.ADMIN"
      pageNameKey="menu_options.roles"
    />
    <!-- Breadcrumb End -->

    <CrudModal
      mode="create"
      modalId="role-create-modal"
      entityName="Role"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="role-edit-modal"
      entityName="Role"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="role-delete-modal"
      entityName="Role"
      fields={tableFields}
      showTrigger={false}
    />

    <div
      id="roles-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage } from "/scripts/crudClient.js";
      initCrudPage({
        dataId: "roles-data",
        editModalId: "role-edit-modal",
        deleteModalId: "role-delete-modal",
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="space-y-5 sm:space-y-6">
        <!-- ====== Table Start -->
        <DataTable
          columns={columns}
          data={data}
          tableId="roles"
          i18Item="role"
          detailPage="/admin/privileges"
          mdItem="privilege"
        />
        <!-- ====== Table End -->
      </div>
    </div>
  </div>
</BaseLayout>
