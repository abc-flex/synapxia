DB_HOST=
DB_SCHEMA=
DB_USER=
DB_PASSWORD=
# DB_PORT is the port INSIDE the docker network (the container's Postgres port,
# reached by the API + PgAdmin as db:${DB_PORT}). Keep it 5432.
DB_PORT=5432
# DB_HOST_PORT is the port PUBLISHED ON THE HOST (localhost:${DB_HOST_PORT}) for
# psql / DBeaver / a locally-run API. Defaults to 5433 to avoid clashing with a
# local Postgres or another project's container already holding 5432. Change it
# per machine if 5433 is also taken.
DB_HOST_PORT=5433

PGADMIN_EMAIL=
PGADMIN_PASSWORD=
# PGADMIN_HOST_PORT is the port PgAdmin is PUBLISHED ON THE HOST
# (http://localhost:${PGADMIN_HOST_PORT}). Defaults to 8081 to avoid clashing
# with another project already holding 8080. The container still listens on 80.
PGADMIN_HOST_PORT=8081

# API_HOST_PORT is the port the API is PUBLISHED ON THE HOST
# (http://localhost:${API_HOST_PORT}; Swagger at /docs). Defaults to 8001 to avoid
# clashing with another project already holding 8000. The container still listens
# on 80, and the UI reaches it in-network via the Vite proxy (not this host port).
API_HOST_PORT=8001

API_PATH=