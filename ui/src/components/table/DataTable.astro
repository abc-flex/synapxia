---
import { t } from "@/i18n";
import { getLocale } from "@/utils/getLocale";

const locale = getLocale(Astro);

const {
  columns = [],
  data = [],
  tableId = "datatable",
  i18Item = "i18item",
  showAddButton = true,
  columnFilter = null,
  masterPage = null,
  detailPage = null,
  mdItem = null,
} = Astro.props;
---

<div class="space-y-2">
  <!-- 🔹 TOP BAR -->
  <div
    class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between"
  >
    <!-- Left -->
    <div class="flex items-center gap-3">
      {
        showAddButton && (
          <button
            type="button"
            class="inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-1 text-sm font-semibold text-white hover:bg-indigo-700"
            data-modal-open={`${i18Item}-create-modal`}
          >
            <span class="text-lg">+</span>
            {t(locale, `${i18Item}_modal.one_title`)}
          </button>
        )
      }
      {
        columnFilter && (
          <div class="relative">
            <select
              id={`${tableId}-filter`}
              data-column-key={columnFilter}
              class="w-44 rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm
                  focus:border-indigo-500 focus:ring-indigo-500"
            >
              <option value="">All {columnFilter}s</option>
            </select>
          </div>
        )
      }
    </div>

    <!-- Right -->
    <div class="flex items-center gap-3 relative">
      <!-- Search -->
      <input
        id={`${tableId}-search`}
        type="search"
        placeholder={t(locale, "data_table.search")}
        class="w-56 rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm
               focus:border-indigo-500 focus:ring-indigo-500"
      />

      <!-- Export -->
      <button
        id={`${tableId}-export-btn`}
        type="button"
        class="inline-flex items-center gap-2 rounded-lg border px-3 py-2 text-sm hover:bg-gray-100"
      >
        <img src="/src/images/icons/arrow-down-tray.svg" class="w-5 h-5" />
      </button>

      <div
        id={`${tableId}-export-menu`}
        class="absolute right-0 top-full z-20 mt-2 hidden w-44 rounded-lg bg-white shadow-lg ring-1 ring-gray-200"
      >
        <ul class="py-1 text-sm">
          <li>
            <button
              data-export="csv"
              class="block w-full px-4 py-2 hover:bg-gray-100"
              >Export CSV</button
            >
          </li>
          <li>
            <button
              data-export="json"
              class="block w-full px-4 py-2 hover:bg-gray-100"
              >Export JSON</button
            >
          </li>
          <li>
            <button
              data-export="txt"
              class="block w-full px-4 py-2 hover:bg-gray-100"
              >Export TXT</button
            >
          </li>
          <li>
            <button
              data-export="sql"
              class="block w-full px-4 py-2 hover:bg-gray-100"
              >Export SQL</button
            >
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- 🔹 TABLE -->
  <div class="overflow-x-auto">
    <table
      id={tableId}
      class="w-full text-sm text-left text-gray-600 datatable-dense"
    >
      <thead
        class="bg-gray-200 text-xs uppercase text-gray-700 border-b border-black"
      >
        <tr>
          {
            columns.map((col) => (
              <th class="px-2 py-1 font-semibold tracking-wide">{col.label}</th>
            ))
          }
          <th class="px-4 py-4 text-right">
            {t(locale, "data_table.actions")}
          </th>
        </tr>
      </thead>
      <tbody
        class="[&>tr:nth-child(even)]:bg-gray-100 [&>tr:hover]:bg-gray-200"
      >
        {
          data.map((row) => (
            <tr class="border-b">
              {columns.map((col) => (
                <td class="px-2 py-1">{row[col.key]}</td>
              ))}
              <td class="actions-cell px-2 py-1 text-right space-x-0">
                <div class="actions-wrapper">
                  {detailPage && (
                    <a
                      href={detailPage + "?list=" + row.id}
                      class="detail-btn action-btn"
                      title={t(locale, `${mdItem}_modal.many_title`)}
                    >
                      <img
                        src="/src/images/icons/list-bullet.svg"
                        alt=""
                        class="w-5 h-5"
                      />
                    </a>
                    <span class="dot">•</span>
                  )}
                  <button
                    class="p-1 text-blue-600 hover:bg-blue-100 rounded edit-btn"
                    data-id={row.id}
                    data-action="edit"
                    data-i18n-title={`${i18Item}_modal.edit`}
                    title={t(locale, `${i18Item}_modal.edit`)}                    
                  >
                    <img
                      src="/src/images/icons/edit.svg"
                      alt=""
                      class="w-5 h-5"
                    />
                  </button>
                  <button
                    class="p-1 text-red-600 hover:bg-red-100 rounded delete-btn"
                    data-id={row.id}
                    data-action="delete"
                    data-i18n-title={`${i18Item}_modal.delete`}
                    title={t(locale, `${i18Item}_modal.delete`)}                    
                  >
                    <img
                      src="/src/images/icons/delete.svg"
                      alt=""
                      class="w-5 h-5"
                    />
                  </button>
                </div>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <!-- 🔹 PAGINATION -->
  <div
    id={`${tableId}-pagination`}
    class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4"
  >
    <!-- Info -->
    <div id={`${tableId}-pagination-info`} class="text-sm text-gray-600"></div>
    <select
      id={`${tableId}-per-page`}
      class="ml-3 rounded-lg border px-2 py-2 text-sm"
    >
      <option value="5">5</option>
      <option value="10" selected>10</option>
      <option value="25">25</option>
      <option value="50">50</option>
    </select>

    <!-- Controls -->
    <div class="flex items-center gap-2">
      <button
        id={`${tableId}-prev`}
        class="px-1 py-1 text-sm border rounded hover:bg-gray-100"
      >
        <img src="/src/images/icons/chevron-left.svg" alt="" class="w-5 h-5" />
      </button>
      <div id={`${tableId}-pages`} class="flex items-center gap-1"></div>
      <button
        id={`${tableId}-next`}
        class="px-1 py-1 text-sm border rounded hover:bg-gray-100"
      >
        <img src="/src/images/icons/chevron-right.svg" alt="" class="w-5 h-5" />
      </button>
    </div>
  </div>
</div>

<script type="module" define:vars={{ tableId, data, columns }}>
  import { initAdvancedTable } from "/src/components/table/advancedTable";
  initAdvancedTable(tableId, data, columns);
</script>
