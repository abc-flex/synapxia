---
import FormCard from "./FormCard.astro";
---
<FormCard title="File Input" titleKey="forms_demo.file_input">
  <div>
    <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-300">
      Upload file
    </label>
    <input
      type="file"
      class="h-11 w-full overflow-hidden rounded-lg border border-gray-300 bg-transparent text-sm text-gray-600 transition file:mr-5 file:cursor-pointer file:rounded-l-lg file:border-0 file:border-r file:border-solid file:border-gray-200 file:bg-gray-50 file:py-3 file:pr-3 file:pl-3.5 file:text-sm file:text-gray-700 hover:file:bg-gray-100 focus:border-indigo-300 focus:ring-2 focus:ring-indigo-100 focus:outline-none dark:border-gray-700 dark:bg-gray-900 dark:text-gray-300 dark:file:border-gray-800 dark:file:bg-white/10 dark:file:text-gray-200"
    />
  </div>
</FormCard>
