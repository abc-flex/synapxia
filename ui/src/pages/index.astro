---
import "../styles/globals.css";
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SinapxIA - Assignments Dashboard</title>
  </head>
  <body class="bg-slate-50 min-h-screen text-slate-900">
    <div class="flex flex-col min-h-screen">
      <header class="bg-gradient-to-r from-indigo-600 to-purple-600 text-white shadow-lg">
        <div class="max-w-7xl mx-auto px-6 py-6 flex flex-col gap-4">
          <div class="flex flex-col gap-1">
            <h1 class="text-3xl font-bold">SinapxIA</h1>
            <p class="text-sm opacity-90" data-i18n="header.subtitle"></p>
          </div>
          <div class="flex justify-end">
            <label class="sr-only" for="languageSelector" data-i18n="labels.language"></label>
            <select
              id="languageSelector"
              class="px-3 py-2 bg-white/10 border border-white/30 rounded-md text-white text-sm cursor-pointer hover:bg-white/20 transition"
              aria-label="language"
            ></select>
          </div>
        </div>
      </header>

      <div class="flex flex-1 max-w-7xl w-full mx-auto">
        <aside class="w-64 bg-white border-r border-gray-200 p-6 hidden lg:block">
          <nav class="space-y-1" aria-label="Primary">
            <ul>
              <li class="mb-1">
                <button
                  type="button"
                  class="block w-full text-left px-4 py-3 rounded-lg font-semibold transition bg-indigo-600 text-white"
                  data-i18n="sidebar.dashboard"
                ></button>
              </li>
              <li class="mb-1">
                <button
                  type="button"
                  class="block w-full text-left px-4 py-3 rounded-lg font-semibold transition text-gray-700 hover:bg-gray-100 hover:text-indigo-600"
                  data-i18n="sidebar.assignments"
                ></button>
              </li>
              <li class="mb-1">
                <button
                  type="button"
                  class="block w-full text-left px-4 py-3 rounded-lg font-semibold transition text-gray-700 hover:bg-gray-100 hover:text-indigo-600"
                  data-i18n="sidebar.reports"
                ></button>
              </li>
              <li>
                <button
                  type="button"
                  class="block w-full text-left px-4 py-3 rounded-lg font-semibold transition text-gray-700 hover:bg-gray-100 hover:text-indigo-600"
                  data-i18n="sidebar.settings"
                ></button>
              </li>
            </ul>
          </nav>
        </aside>

        <main class="flex-1 p-8 overflow-x-auto">
          <div class="flex flex-col gap-8 md:flex-row md:justify-between md:items-center mb-8">
            <h2 class="text-3xl font-bold text-gray-900" data-i18n="dashboard.title"></h2>
            <div class="flex flex-col gap-2 md:flex-row md:items-center">
              <label for="dimensionSelect" class="font-semibold text-gray-700" data-i18n="dashboard.selectDimension"></label>
              <select
                id="dimensionSelect"
                class="px-4 py-2 border border-gray-300 rounded-lg bg-white text-gray-900 text-base cursor-pointer focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-200 transition min-w-[200px]"
              ></select>
            </div>
          </div>

          <div id="dashboardGrid" class="bg-white rounded-2xl p-6 shadow-md overflow-x-auto"></div>
        </main>
      </div>

      <footer class="bg-white border-t border-gray-200 py-6 px-6 text-center text-gray-600 text-sm">
        <p data-i18n="footer.copyright"></p>
      </footer>
    </div>

    <div
      id="employeeModal"
      class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center animate-fadeIn"
      role="dialog"
      aria-modal="true"
    >
      <div class="bg-white rounded-2xl p-8 w-11/12 max-w-4xl shadow-2xl animate-slideDown">
        <div class="flex justify-between items-start mb-6">
          <h3 id="modalEmployeeName" class="text-2xl font-bold text-gray-900"></h3>
          <button id="closeModalBtn" type="button" class="text-gray-400 hover:text-gray-600 text-2xl transition">&times;</button>
        </div>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-gray-600" data-i18n="modal.email"></label>
            <span id="modalEmployeeEmail" class="text-gray-900"></span>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600" data-i18n="modal.role"></label>
            <span id="modalEmployeeRole" class="text-gray-900"></span>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600" data-i18n="modal.team"></label>
            <span id="modalEmployeeTeam" class="text-gray-900"></span>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600" data-i18n="modal.date"></label>
            <span id="modalEmployeeDate" class="text-gray-900"></span>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600" data-i18n="modal.observation"></label>
            <p id="modalEmployeeObservation" class="text-gray-900 leading-relaxed"></p>
          </div>
          <div>
            <label for="modalMetricSelect" class="block text-sm font-semibold text-gray-600 mb-2" data-i18n="modal.currentMetric"></label>
            <select
              id="modalMetricSelect"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg bg-white text-gray-900 focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-200 transition"
            >
              <option value="Alto" selected></option>
              <option value="Medio"></option>
              <option value="Bajo"></option>
            </select>
          </div>
        </div>
        <div class="flex flex-col gap-3 mt-8 sm:flex-row">
          <button
            id="saveMetricBtn"
            type="button"
            class="flex-1 px-4 py-2 bg-indigo-600 text-white font-semibold rounded-lg hover:bg-indigo-700 transition transform hover:-translate-y-0.5 shadow-md"
            data-i18n="modal.saveMetric"
          ></button>
          <button
            id="addEntryBtn"
            type="button"
            class="flex-1 px-4 py-2 bg-gray-100 text-gray-900 font-semibold rounded-lg border border-gray-300 hover:bg-gray-200 transition transform hover:-translate-y-0.5"
            data-i18n="modal.addEntry"
          ></button>
        </div>
      </div>
    </div>

    <script type="module" src="../scripts/dashboard.js" defer></script>
  </body>
</html>
