---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import { getMetrics } from "@/lib/metrics";
import { getDimensions } from "@/lib/dimensions";
import { getAssignments } from "@/lib/assignments";

// Read dimension query param for master-detail pre-filter
const dimensionFilter = Astro.url.searchParams.get("dimension") || "";

// Fetch metrics from API
let metrics: any[] = [];
let errorMessage: string | null = null;

try {
  const apiMetrics = await getMetrics();
  metrics = apiMetrics;
} catch (error) {
  console.error('Failed to fetch metrics:', error);
  errorMessage = error instanceof Error ? error.message : 'Failed to fetch metrics from API';
  metrics = [];
}

// Fetch dimensions for filter dropdown and create form select
let dimensions: any[] = [];
try {
  const apiDimensions = await getDimensions();
  dimensions = apiDimensions;
} catch (error) {
  console.error('Failed to fetch dimensions:', error);
  dimensions = [];
}

// Fetch assignments for create form select
let assignments: any[] = [];
try {
  const apiAssignments = await getAssignments();
  assignments = apiAssignments;
} catch (error) {
  console.error('Failed to fetch assignments:', error);
  assignments = [];
}

// Map assignments to select options with readable label
const assignmentOptions = assignments.map((a: any) => ({
  code: a.id,
  name: `${a.team} / ${a.user_id}`,
}));

const columns = [
  { key: "dimension", label: "metric_modal.dimension", as: "title", subtitleKey: "assignment", subtitleFormat: "text" },
  { key: "assignment", label: "metric_modal.assignment", visible: false },
  { key: "value", label: "metric_modal.value", visible: true },
  { key: "measured_at", label: "metric_modal.measured_at", as: "date" },
];
const data = metrics.map((item) => ({
  id: item.id,
  dimension: item.dimension,
  assignment: item.assignment,
  value: item.value,
  observation: item.observation,
  measured_at: item.measured_at,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));
const tableFields = [
  {
    key: "dimension",
    label: "metric_modal.dimension",
    type: "select" as const,
    options: dimensions,
    pk: true,
    required: true,
  },
  {
    key: "assignment",
    label: "metric_modal.assignment",
    type: "select" as const,
    options: assignmentOptions,
    pk: true,
    required: true,
  },
  { key: "value", label: "metric_modal.value", required: true, placeholder: "e.g. 85" },
  {
    key: "observation",
    label: "metric_modal.observation",
    type: "textarea" as const,
    placeholder: "Optional observation",
  },
  { key: "measured_at", label: "metric_modal.measured_at", type: "text" as const, placeholder: "e.g. 2026-04-03T10:00" },
];
const fieldKeys = ["id", ...tableFields.map((f) => f.key)];
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto w-full max-w-full md:p-0">
    <!-- Breadcrumb Start -->
    <Breadcrumb
      moduleName="Collaboration"
      pageName="Metrics"
      pageTitle="Metrics"
      homeLink="/"
      moduleNameKey="modules.COLLAB"
      pageNameKey="menu_options.metrics"
      pageTitleKey="menu_options.metrics"
    />
    <!-- Breadcrumb End -->

    <CrudModal
      mode="create"
      modalId="metric-create-modal"
      entityName="Metric"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="edit"
      modalId="metric-edit-modal"
      entityName="Metric"
      fields={tableFields}
      showTrigger={false}
    />
    <CrudModal
      mode="delete"
      modalId="metric-delete-modal"
      entityName="Metric"
      fields={tableFields}
      showTrigger={false}
    />

    <div
      id="metrics-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      data-dimension-filter={dimensionFilter}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      import { initCrudPage } from "/scripts/crudClient.js";
      import {
        createMetric,
        updateMetric,
        deleteMetric,
      } from "/src/lib/metrics";

      initCrudPage({
        dataId: "metrics-data",
        editModalId: "metric-edit-modal",
        deleteModalId: "metric-delete-modal",
      });

      // Pre-select dimension filter from URL query param
      const metricsData = document.getElementById("metrics-data");
      const dimensionFilter = metricsData?.dataset.dimensionFilter;
      if (dimensionFilter) {
        const filterSelect = document.getElementById("metrics-filter");
        if (filterSelect) {
          filterSelect.value = dimensionFilter;
          filterSelect.dispatchEvent(new Event("change"));
        }
      }

      // Helper function to show toast notifications
      function showToast(message, variant = "info") {
        const toast = document.createElement("div");
        toast.className = `fixed top-4 right-4 z-50 max-w-md p-4 rounded-lg border shadow-lg transition-all duration-300 ${
          variant === "error"
            ? "bg-red-50 text-red-800 border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800"
            : "bg-green-50 text-green-800 border-green-200 dark:bg-green-900/20 dark:text-green-400 dark:border-green-800"
        }`;
        toast.innerHTML = `
          <div class="flex items-start gap-3">
            <div class="flex-1 text-sm font-medium">${message}</div>
            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="this.parentElement.parentElement.remove()">✕</button>
          </div>
        `;
        document.body.appendChild(toast);

        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateX(100%)";
          setTimeout(() => toast.remove(), 300);
        }, 5000);
      }

      // Handle CRUD form submissions
      document.addEventListener("crud-submit", async (e) => {
        const { modalId, mode, data } = e.detail;

        try {
          if (mode === "create") {
            await createMetric({
              dimension: data.dimension,
              assignment: parseInt(data.assignment, 10),
              value: data.value,
              observation: data.observation || undefined,
              measured_at: data.measured_at || undefined,
              is_active: true,
            });
            showToast("Metric created successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "edit") {
            await updateMetric(parseInt(data.id, 10), {
              value: data.value,
              observation: data.observation || undefined,
              measured_at: data.measured_at || undefined,
              is_active: data.is_active !== false,
            });
            showToast("Metric updated successfully!");
            setTimeout(() => window.location.reload(), 1000);
          } else if (mode === "delete") {
            await deleteMetric(parseInt(data.id, 10));
            showToast("Metric deleted successfully!");
            setTimeout(() => window.location.reload(), 1000);
          }
        } catch (error) {
          console.error("CRUD operation failed:", error);
          showToast(error instanceof Error ? error.message : "An error occurred", "error");
        }
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="border-0 p-0">
        <!-- ====== Table Start -->
        <DataTable
          columns={columns}
          data={data}
          tableId="metrics"
          i18Item="metric"
          columnFilter="dimension"
          filterOptions={dimensions}
          masterPage="/collab/dimensions"
          mdItem="dimension"
        />
        <!-- ====== Table End -->
      </div>
    </div>
  </div>
</BaseLayout>
