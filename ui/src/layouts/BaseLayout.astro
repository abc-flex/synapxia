---
import "../styles/globals.css";
import Header from "../components/core/header/Header.astro";
import SideBar from "../components/core/sidebar/SideBar.astro";
import ClientTranslations from "../components/ClientTranslations.astro";
import { getNavigationData } from "@/lib/navigation";

interface Props {
  title?: string;
}

const {
  title = "SynapxIA",
} = Astro.props as Props;

// SSR-fetch the sidebar nav data. The Astro middleware has already put the
// JWT (read from the auth_token cookie) into AsyncLocalStorage, so apiGet
// forwards it as a Bearer header to the API. If the user is unauthenticated
// they'd already have been redirected by the middleware, so this call
// always runs in an authenticated context. On API failure the helper
// returns empty arrays — the SideBar renders gracefully.
let primaryNav: import("@/types/nav").NavModule[] = [];
let itemsNav: import("@/types/nav").NavOption[] = [];
try {
  const nav = await getNavigationData();
  primaryNav = nav.primaryNav;
  itemsNav = nav.itemsNav;
} catch {
  /* swallow — SideBar will fall back to its localStorage cache + client refetch */
}

// Get current path for sidebar active state
const currentPath = Astro.url.pathname;

// Extract current module from path (first segment after /)
const pathSegments = currentPath.split('/').filter(Boolean);
const currentModuleName = pathSegments[0] || "";
---

<!doctype html>
<html lang="en">
  <head>
    {/* Auth gate runs server-side in src/middleware.ts (cookie-based).
        Pages reach this layout already authenticated (or already redirected
        to /login). No flash-of-empty-content, no localStorage round-trip. */}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-slate-50 text-slate-900 dark:bg-gray-950 dark:text-white">
    <ClientTranslations />
    <div class="min-h-screen flex">
      <SideBar modules={primaryNav} options={itemsNav} brandTitle={title} currentPath={currentPath} currentModuleName={currentModuleName} />

      <div class="flex-1 flex flex-col min-h-screen">
        <Header title={title} subtitle="Dashboard" />

        <main>
          <div class="mx-auto max-w-(--breakpoint-2xl) md:p-0">
            <slot />
          </div>
        </main>
      </div>
    </div>
  </body>
</html>

<script src="https://unpkg.com/flowbite@latest/dist/flowbite.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/simple-datatables@9.0.3"></script>

<script>
  (() => {
    if (typeof window === "undefined") return;

    const storageKey = "sidebar-collapsed";
    const body = document.body;
    const toggle = document.querySelector("[data-sidebar-toggle]");
    const sidebar = document.querySelector(".sidebar");

    if (!toggle || !sidebar) return;

    const apply = (collapsed) => {
      body.classList.toggle("sidebar-collapsed", collapsed);
      toggle.setAttribute("aria-pressed", String(collapsed));
    };

    const saved = localStorage.getItem(storageKey);
    apply(saved === "true");

    toggle.addEventListener("click", () => {
      const next = !body.classList.contains("sidebar-collapsed");
      apply(next);
      localStorage.setItem(storageKey, String(next));
    });
  })();

  (() => {
    if (typeof window === "undefined") return;

    const storageKey = "theme";
    const toggle = document.querySelector<HTMLElement>("[data-theme-toggle]");
    const root = document.documentElement;

    const apply = (theme: "light" | "dark") => {
      if (theme === "dark") {
        root.classList.add("dark");
      } else {
        root.classList.remove("dark");
      }
      toggle?.setAttribute("aria-pressed", String(theme === "dark"));
      localStorage.setItem(storageKey, theme);
    };

    const saved = localStorage.getItem(storageKey) as "light" | "dark" | null;
    const prefersDark =
      window.matchMedia &&
      window.matchMedia("(prefers-color-scheme: dark)").matches;
    apply(saved ?? (prefersDark ? "dark" : "light"));

    toggle?.addEventListener("click", () => {
      const next = root.classList.contains("dark") ? "light" : "dark";
      apply(next as "light" | "dark");
    });
  })();
</script>
