---
import BaseLayout from "../../layouts/BaseLayout.astro";
import modules from "../../data/modules.json";
import options from "../../data/options.json";
import roles from "../../data/roles.json";

const title = "SynapxIA";
const primaryNav = modules.map(module => ({
  code: module.code,
  name: module.name,
  icon: `${module.icon}`
}));
const itemsNav = options.map(option => ({
  module: option.module,
  name: option.name,
  path: option.path
}));
const dbRoles = roles.map(rol => ({
  code: rol.code,
  name: rol.name,
  description: rol.description
}));
---

<BaseLayout title={title} navModules={primaryNav} navOptions={itemsNav}>
  <div class="rounded-2xl border border-dashed border-slate-200 bg-white/70 p-10 text-center shadow-sm">
    <p class="text-sm uppercase tracking-[0.2em] text-slate-400">Administration : Roles</p>
    <h1 class="mt-3 text-3xl font-bold text-slate-900">Roles List</h1>
    <p class="mt-3 text-slate-600">
      Sidebar and header are now reusable components. Plug your content here.
    </p>
  </div>
</BaseLayout>
