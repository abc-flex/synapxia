---
import "../styles/globals.css";

interface Props {
  title?: string;
}

const {
  title = "SynapxIA",
} = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    {/* Client-side auth gate — see comment in BaseLayout.astro. Kept here
        too because Layout is used by /dashboard (gated) AND by /login,
        /signup, /index (public). The publicRoutes check inside the
        script handles both cases with the same logic. */}
    <script is:inline define:vars={{ publicRoutes: ['/login', '/signup', '/', '/index'] }}>
      const path = window.location.pathname;
      const isPublic = publicRoutes.includes(path);
      const hasToken = !!localStorage.getItem('auth_token');
      if (!hasToken && !isPublic) {
        window.location.replace('/login');
      } else if (hasToken && (path === '/login' || path === '/signup')) {
        window.location.replace('/dashboard');
      }
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
