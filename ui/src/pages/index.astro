---
import "../styles/globals.css";

const title = "Synapxia";

---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body
    style="font-family: system-ui, -apple-system, sans-serif; display: grid; place-items: center; min-height: 100vh; margin: 0; background: #f7f7f7; color: #111;"
  >
    <main
      style="text-align: center; padding: 2rem; background: white; border-radius: 12px; box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);"
    >
      <h1 style="font-size: 3rem; margin: 0 0 0.5rem;">{title}</h1>
      <p style="margin: 0; font-size: 1.1rem; color: #555;">
        A fresh Astro starter page.
      </p>
    </main>
  </body>
</html>
