---
/**
 * PromptCard — Prompt Gallery card. Wraps the reusable GalleryCard scaffold and
 * supplies prompt-specific rendering: a chat-bubble icon, a clamped description,
 * model / platform / temperature meta chips + tags, and edit/delete actions.
 *
 * This is the per-catalog "custom style + rendering" layer; sibling catalogs
 * (MCP, Agent, …) get their own {X}Card.astro built the same way.
 */
import GalleryCard from "@/components/lib/gallery/GalleryCard.astro";

export interface Props {
  id: number | string;
  name: string;
  subtitle?: string;
  description?: string;
  statusLabel?: string;
  statusValue?: string;
  favorite?: string;
  searchText?: string;
  editModalId?: string;
  model?: string;
  platform?: string;
  temperature?: string;
  tags?: string[];
}

const {
  id,
  name,
  subtitle,
  description,
  statusLabel,
  statusValue,
  favorite,
  searchText,
  editModalId = "prompt-detail-modal",
  model,
  platform,
  temperature,
  tags = [],
} = Astro.props as Props;

const chips = [
  { labelKey: "prompt_card.model", value: model },
  { labelKey: "prompt_card.platform", value: platform },
  { labelKey: "prompt_card.temperature", value: temperature },
].filter((c) => c.value);
---

<GalleryCard
  id={id}
  name={name}
  subtitle={subtitle}
  statusLabel={statusLabel}
  statusValue={statusValue}
  favorite={favorite}
  searchText={searchText}
  editModalId={editModalId}
>
  <span slot="icon" class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-indigo-50 text-indigo-600 dark:bg-indigo-500/15 dark:text-indigo-300">
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="M8 10h8M8 14h5M21 12a8 8 0 0 1-8 8H7l-4 3v-5a8 8 0 1 1 18-6z" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </span>

  {description && (
    <p slot="body" class="line-clamp-2 text-sm text-gray-500 dark:text-gray-400">{description}</p>
  )}

  <Fragment slot="chips">
    {chips.map((c) => (
      <span class="inline-flex items-center gap-1 rounded-md bg-gray-100 px-2 py-0.5 text-xs text-gray-600 dark:bg-gray-800 dark:text-gray-300">
        <span class="opacity-60" data-i18n={c.labelKey}>{c.labelKey}</span>
        <span class="font-medium">{c.value}</span>
      </span>
    ))}
    {tags.map((tag) => (
      <span class="inline-flex items-center rounded-md bg-indigo-50 px-2 py-0.5 text-xs font-medium text-indigo-700 dark:bg-indigo-500/15 dark:text-indigo-300">#{tag}</span>
    ))}
  </Fragment>

  <Fragment slot="actions">
    <button
      type="button"
      data-modal-open={editModalId}
      data-asset-mode="edit"
      data-asset-id={String(id)}
      class="rounded-lg px-3 py-1.5 text-sm font-medium text-gray-600 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-800"
      data-i18n="common.edit"
    >
      Edit
    </button>
    <button
      type="button"
      data-action="delete"
      data-id={String(id)}
      data-name={name}
      class="rounded-lg px-3 py-1.5 text-sm font-medium text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-900/20"
      data-i18n="common.delete"
    >
      Delete
    </button>
  </Fragment>
</GalleryCard>
