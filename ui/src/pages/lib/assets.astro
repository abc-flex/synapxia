---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import DataTable from "../../components/table/DataTable.astro";
import CrudModal from "../../components/forms/CrudModal.astro";
import Toast from "../../components/Toast.astro";
import AssetDetailModal from "../../components/lib/AssetDetailModal.astro";
import { getAssets } from "@/lib/assets";
import { getCategoriesSelect } from "@/lib/categories";
import { getListItemsbyList } from "@/lib/list_items";

// ── Fetch data for the list view ──────────────────────────────────────────
let assets: any[] = [];
let errorMessage: string | null = null;

try {
  assets = await getAssets();
} catch (error) {
  console.error("Failed to fetch assets:", error);
  errorMessage =
    error instanceof Error ? error.message : "Failed to fetch assets from API";
  assets = [];
}

// Status list (ASSET_STATUS) for the in-row label + status filter dropdown
let status: any[] = [];
try {
  status = await getListItemsbyList("ASSET_STATUS");
} catch {
  status = [];
}

// Categories for the in-row label + category filter dropdown + AssetDetailModal
let categories: any[] = [];
try {
  categories = await getCategoriesSelect();
} catch (error) {
  console.error("Failed to fetch categories:", error);
  categories = [];
}

// Columns shown in the table
const columns = [
  { key: "name", label: "asset_modal.name" },
  { key: "category", label: "asset_modal.category", visible: false },
  { key: "category_name", label: "asset_modal.category" },
  { key: "status", label: "asset_modal.status", visible: false },
  { key: "status_name", label: "asset_modal.status" },
  { key: "tags_display", label: "asset_modal.tags" },
];

// Flatten rows for the table; keep raw category/status as hidden columns so
// the dropdown filters can match them by value.
const data = assets.map((item) => ({
  id: item.id,
  name: item.name,
  description: item.description,
  category: item.category,
  category_name:
    categories.find((c) => String(c.value) === String(item.category))?.label ||
    item.category ||
    "",
  reference: item.reference,
  status: item.status,
  status_name: status.find((s) => s.value === item.status)?.label || item.status,
  tags: item.tags,
  tags_display: Array.isArray(item.tags) ? item.tags.join(", ") : item.tags || "",
  detail: item.detail,
  is_active: item.is_active,
  created_at: item.created_at,
  updated_at: item.updated_at,
}));

// Delete-only fields for the small confirmation CrudModal
const deleteFields = [
  { key: "name", label: "asset_modal.name", pk: true, disabled: true },
];
const fieldKeys = deleteFields.map((f) => f.key);
---

<BaseLayout>
  {errorMessage && <Toast message={errorMessage} variant="error" open={true} />}

  <div class="mx-auto max-w-(--breakpoint-2xl) md:p-6">
    <Breadcrumb
      moduleName="AI Library"
      pageName="Assets"
      pageTitle="Assets"
      homeLink="/"
      moduleNameKey="modules.LIB"
      pageNameKey="menu_options.assets"
      pageTitleKey="menu_options.assets"
    />

    {/* Wide create/edit modal — the main piece of UI here */}
    <AssetDetailModal
      modalId="asset-detail-modal"
      categories={categories}
      statuses={status.map((s) => ({ value: s.value, label: s.label }))}
    />

    {/* Slim delete confirmation (reuses existing CrudModal) */}
    <CrudModal
      mode="delete"
      modalId="asset-delete-modal"
      entityName="Asset"
      fields={deleteFields}
      showTrigger={false}
    />

    <div
      id="assets-data"
      data-rows={encodeURIComponent(JSON.stringify(data))}
      data-keys={encodeURIComponent(JSON.stringify(fieldKeys))}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <script type="module">
      // Inline module so we can import crudClient from /public/ (Astro's
      // hoisted bundler forbids importing /public/* files).
      import { initCrudPage } from "/scripts/crudClient.js";
      import { deleteAsset } from "/src/lib/assets";

      // CrudClient still drives the delete modal's prefill flow.
      initCrudPage({
        dataId: "assets-data",
        editModalId: "asset-edit-modal", // shim — DataTable still emits this id
        deleteModalId: "asset-delete-modal",
      });

      // Toast helper
      function showToast(message, variant = "info") {
        const toast = document.createElement("div");
        toast.className = `fixed top-4 right-4 z-50 max-w-md p-4 rounded-lg border shadow-lg transition-all duration-300 ${
          variant === "error"
            ? "bg-red-50 text-red-800 border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800"
            : "bg-green-50 text-green-800 border-green-200 dark:bg-green-900/20 dark:text-green-400 dark:border-green-800"
        }`;
        toast.innerHTML = `
          <div class="flex items-start gap-3">
            <div class="flex-1 text-sm font-medium">${message}</div>
            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="this.parentElement.parentElement.remove()">✕</button>
          </div>
        `;
        document.body.appendChild(toast);
        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateX(100%)";
          setTimeout(() => toast.remove(), 300);
        }, 5000);
      }

      // ── Bridge: DataTable's "asset-create-modal" / "asset-edit-modal"
      // buttons → AssetDetailModal. We intercept the DataTable's
      // data-modal-open clicks BEFORE the default modal-open handler runs
      // and reroute them to our wider modal.
      document.addEventListener(
        "click",
        (e) => {
          const create = e.target.closest?.('[data-modal-open="asset-create-modal"]');
          const edit = e.target.closest?.('[data-modal-open="asset-edit-modal"]');
          const proxy = create || edit;
          if (!proxy) return;
          // Stop the default modal opener (it would try to open a dialog
          // that no longer exists with those ids).
          e.preventDefault();
          e.stopImmediatePropagation();
          // Synthesize a click on the AssetDetailModal trigger.
          const synthetic = document.createElement("button");
          synthetic.style.display = "none";
          synthetic.setAttribute("data-modal-open", "asset-detail-modal");
          synthetic.setAttribute(
            "data-asset-mode",
            create ? "create" : "edit",
          );
          if (edit) {
            const id = edit.getAttribute("data-id");
            if (id) synthetic.setAttribute("data-asset-id", id);
          }
          document.body.appendChild(synthetic);
          synthetic.click();
          synthetic.remove();
        },
        true /* capture phase so we run before crudClient.js */,
      );

      // ── Delete handler stays on the standard CrudModal pattern.
      document.addEventListener("crud-submit", async (e) => {
        const { mode, data } = e.detail;
        if (mode !== "delete") return; // create/edit handled by AssetDetailModal
        try {
          await deleteAsset(Number(data.id));
          showToast("Asset deleted successfully!");
          setTimeout(() => window.location.reload(), 800);
        } catch (error) {
          console.error("Delete failed:", error);
          showToast(
            error instanceof Error ? error.message : "An error occurred",
            "error",
          );
        }
      });
    </script>

    <div class="space-y-5 sm:space-y-6">
      <div class="border-0 p-0">
        <DataTable
          columns={columns}
          data={data}
          tableId="assets"
          i18Item="asset"
          columnFilter="category"
          filterOptions={categories}
          columnFilter2="status"
          filterOptions2={status.map((s) => ({ value: s.value, label: s.label }))}
        />
      </div>
    </div>
  </div>
</BaseLayout>
